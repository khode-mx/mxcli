-- ============================================================================
-- Materials Domain Model
-- ============================================================================
-- Inventory and raw materials management. Tracks material categories,
-- individual materials, suppliers, stock movements, and purchase orders.
-- ============================================================================

-- MARK: MODULE

/**
 * Materials module
 *
 * Manages raw materials inventory, suppliers, stock tracking,
 * and purchase ordering for the furniture manufacturing process.
 *
 * @since 1.0.0
 */
create module Materials;

-- MARK: ENUMERATIONS

/**
 * Material unit of measure
 *
 * Standard measurement units for raw materials
 * used in furniture manufacturing.
 *
 * @since 1.0.0
 */
create enumeration Materials.MaterialUnit (
  Piece 'Piece',
  Meter 'Meter',
  SquareMeter 'Square Meter',
  CubicMeter 'Cubic Meter',
  Kilogram 'Kilogram',
  Liter 'Liter',
  Sheet 'Sheet',
  Roll 'Roll'
);

/**
 * Stock movement type
 *
 * Classifies the reason for inventory changes.
 *
 * @since 1.0.0
 */
create enumeration Materials.MovementType (
  Incoming 'Incoming',
  Outgoing 'Outgoing',
  Adjustment 'Adjustment',
  ReturnToSupplier 'Return to Supplier',
  ProductionConsumption 'Production Consumption'
);

/**
 * Purchase order status
 *
 * Tracks the lifecycle of a material purchase order.
 *
 * @since 1.0.0
 */
create enumeration Materials.PurchaseOrderStatus (
  Draft 'Draft',
  Ordered 'Ordered',
  PartiallyReceived 'Partially Received',
  Received 'Received',
  Cancelled 'Cancelled'
);

-- MARK: ENTITIES

/**
 * Material category entity
 *
 * Groups materials by type (e.g. Hardwood, Softwood, Hardware,
 * Fabric, Adhesives, Finishing Products).
 *
 * @since 1.0.0
 */
@position(50, 50)
create persistent entity Materials.MaterialCategory (
  /** Category name */
  CategoryName: string(200) not null error 'Category name is required',
  /** Category description */
  CategoryDescription: string(1000),
  /** Whether this category is active */
  IsActive: boolean default true
);

/**
 * Material entity
 *
 * Individual raw material or component used in furniture production.
 * Tracks specifications, pricing, and current stock levels.
 *
 * @since 1.0.0
 * @see Materials.MaterialCategory
 * @see Materials.Supplier
 */
@position(350, 50)
create persistent entity Materials.Material (
  /** Unique material code */
  MaterialCode: string(50) not null error 'Material code is required' unique error 'Material code must be unique',
  /** Material display name */
  MaterialName: string(200) not null error 'Material name is required',
  /** Detailed description */
  MaterialDescription: string(2000),
  /** Unit of measure */
  UnitOfMeasure: enumeration(Materials.MaterialUnit) not null error 'Unit of measure is required',
  /** Unit cost (last purchase price) */
  UnitCost: decimal default 0,
  /** Current quantity in stock */
  QuantityInStock: decimal default 0,
  /** Minimum stock level (triggers reorder alert) */
  MinimumStockLevel: decimal default 0,
  /** Standard reorder quantity */
  ReorderQuantity: decimal default 0,
  /** Whether this material is active */
  IsActive: boolean default true,
  /** Storage location code */
  StorageLocation: string(50),
  /** Additional specifications */
  Specifications: string(2000)
)
index (MaterialCode)
index (IsActive);

/**
 * Supplier entity
 *
 * Companies that supply raw materials and components.
 *
 * @since 1.0.0
 * @see Materials.Material
 */
@position(50, 250)
create persistent entity Materials.Supplier (
  /** Unique supplier code */
  SupplierCode: string(50) not null error 'Supplier code is required' unique error 'Supplier code must be unique',
  /** Company name */
  SupplierName: string(200) not null error 'Supplier name is required',
  /** Primary contact person */
  ContactPerson: string(200),
  /** Email address */
  Email: string(200),
  /** Phone number */
  Phone: string(50),
  /** Street address */
  Street: string(200),
  /** City */
  City: string(100),
  /** Postal code */
  PostalCode: string(20),
  /** Country */
  Country: string(100),
  /** Website URL */
  Website: string(500),
  /** Payment terms (e.g. 'Net 30') */
  PaymentTerms: string(100),
  /** Whether this supplier is active */
  IsActive: boolean default true,
  /** General notes */
  Notes: string(2000)
)
index (SupplierCode);

/**
 * Stock movement entity
 *
 * Records every in/out movement of materials.
 * Provides a full audit trail of inventory changes.
 *
 * @since 1.0.0
 * @see Materials.Material
 */
@position(650, 50)
create persistent entity Materials.StockMovement (
  /** Type of movement */
  MovementType: enumeration(Materials.MovementType) not null error 'Movement type is required',
  /** Quantity moved (positive for in, negative for out) */
  Quantity: decimal not null error 'Quantity is required',
  /** Date and time of the movement */
  MovementDate: datetime not null error 'Movement date is required',
  /** Reference number (PO number, work order number, etc.) */
  ReferenceNumber: string(100),
  /** Reason or notes for this movement */
  MovementReason: string(500),
  /** Stock level after this movement */
  BalanceAfter: decimal
)
index (MovementDate desc)
index (MovementType);

/**
 * Purchase order entity
 *
 * Orders placed with suppliers for raw materials.
 *
 * @since 1.0.0
 * @see Materials.Supplier
 * @see Materials.PurchaseOrderLine
 */
@position(350, 250)
create persistent entity Materials.PurchaseOrder (
  /** Auto-generated PO number */
  PONumber: autonumber default 1,
  /** Current order status */
  POStatus: enumeration(Materials.PurchaseOrderStatus) not null error 'PO status is required',
  /** Date the order was placed */
  OrderDate: datetime,
  /** Expected delivery date */
  ExpectedDeliveryDate: datetime,
  /** Actual delivery date */
  ActualDeliveryDate: datetime,
  /** Total order amount */
  TotalAmount: decimal default 0,
  /** Supplier's reference or confirmation number */
  SupplierReference: string(100),
  /** Notes about this order */
  Notes: string(2000)
)
index (POStatus);

/**
 * Purchase order line entity
 *
 * Individual material items on a purchase order.
 *
 * @since 1.0.0
 * @see Materials.PurchaseOrder
 * @see Materials.Material
 */
@position(650, 250)
create persistent entity Materials.PurchaseOrderLine (
  /** Line number */
  LineNumber: integer not null error 'Line number is required',
  /** Quantity ordered */
  QuantityOrdered: decimal not null error 'Quantity ordered is required',
  /** Quantity received so far */
  QuantityReceived: decimal default 0,
  /** Unit price */
  UnitPrice: decimal not null error 'Unit price is required',
  /** Line total */
  LineTotal: decimal default 0
);

-- MARK: ASSOCIATIONS

/**
 * Links material to its category
 *
 * Each material belongs to one category.
 *
 * @since 1.0.0
 */
create association Materials.Material_MaterialCategory
  from Materials.Material to Materials.MaterialCategory
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links material to its preferred supplier
 *
 * Each material has one preferred supplier.
 *
 * @since 1.0.0
 */
create association Materials.Material_Supplier
  from Materials.Material to Materials.Supplier
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links stock movement to its material
 *
 * Each movement affects one material.
 *
 * @since 1.0.0
 */
create association Materials.StockMovement_Material
  from Materials.StockMovement to Materials.Material
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links purchase order to its supplier
 *
 * Each PO is placed with one supplier.
 *
 * @since 1.0.0
 */
create association Materials.PurchaseOrder_Supplier
  from Materials.PurchaseOrder to Materials.Supplier
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links PO line to its purchase order
 *
 * Each line belongs to one purchase order.
 *
 * @since 1.0.0
 */
create association Materials.PurchaseOrderLine_PurchaseOrder
  from Materials.PurchaseOrderLine to Materials.PurchaseOrder
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links PO line to the material being ordered
 *
 * Each line orders one material.
 *
 * @since 1.0.0
 */
create association Materials.PurchaseOrderLine_Material
  from Materials.PurchaseOrderLine to Materials.Material
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;
