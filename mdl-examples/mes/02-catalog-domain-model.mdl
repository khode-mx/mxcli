-- ============================================================================
-- Product Catalog Domain Model
-- ============================================================================
-- Standard (off-the-shelf) furniture designs with categories, variants,
-- and product images. Supports hierarchical categorization and
-- multiple product variants per design.
-- ============================================================================

-- MARK: MODULE

/**
 * Product Catalog module
 *
 * Manages standard furniture product designs, categories,
 * variants (size/material/finish combinations), and product images.
 *
 * @since 1.0.0
 */
create module ProductCatalog;

-- MARK: ENUMERATIONS

/**
 * Product lifecycle status
 *
 * Tracks whether a product is actively available for sale.
 *
 * @since 1.0.0
 */
create enumeration ProductCatalog.ProductStatus (
  Draft 'Draft',
  Active 'Active',
  Discontinued 'Discontinued'
);

/**
 * Furniture finish type
 *
 * Common finish options for furniture surfaces.
 *
 * @since 1.0.0
 */
create enumeration ProductCatalog.FinishType (
  Natural 'Natural',
  Stained 'Stained',
  Painted 'Painted',
  Lacquered 'Lacquered',
  Oiled 'Oiled',
  Waxed 'Waxed'
);

-- MARK: ENTITIES

/**
 * Product category entity
 *
 * Hierarchical categorization of furniture products.
 * Supports parent-child relationships for nested categories
 * (e.g. Seating > Chairs > Dining Chairs).
 *
 * @since 1.0.0
 * @see ProductCatalog.CatalogProduct
 */
@position(50, 50)
create persistent entity ProductCatalog.ProductCategory (
  /** Category display name */
  CategoryName: string(200) not null error 'Category name is required',
  /** Brief description of this category */
  CategoryDescription: string(1000),
  /** Sort position for display ordering */
  SortOrder: integer default 0,
  /** Whether this category is visible to users */
  IsActive: boolean default true
);

/**
 * Catalog product entity
 *
 * A standard furniture design available for purchase.
 * Each product can have multiple variants (size, material, finish)
 * and multiple images.
 *
 * @since 1.0.0
 * @see ProductCatalog.ProductCategory
 * @see ProductCatalog.ProductVariant
 */
@position(350, 50)
create persistent entity ProductCatalog.CatalogProduct (
  /** Unique product code / SKU prefix */
  ProductCode: string(50) not null error 'Product code is required' unique error 'Product code must be unique',
  /** Product display name */
  ProductName: string(200) not null error 'Product name is required',
  /** Detailed product description */
  ProductDescription: string(4000),
  /** Base price before variant adjustments */
  BasePrice: decimal,
  /** Estimated production lead time in days */
  LeadTimeDays: integer default 14,
  /** Overall dimensions description */
  Dimensions: string(200),
  /** Primary material used */
  PrimaryMaterial: string(100),
  /** Weight in kilograms */
  WeightKg: decimal,
  /** Lifecycle status */
  ProductStatus: enumeration(ProductCatalog.ProductStatus) not null error 'Product status is required',
  /** Date when product was first made available */
  LaunchDate: datetime
)
index (ProductStatus)
index (ProductCode);

/**
 * Product variant entity
 *
 * A specific size/material/finish combination of a catalog product.
 * Each variant has its own SKU and price adjustment.
 *
 * @since 1.0.0
 * @see ProductCatalog.CatalogProduct
 */
@position(650, 50)
create persistent entity ProductCatalog.ProductVariant (
  /** Full SKU for this variant */
  SKU: string(50) not null error 'SKU is required' unique error 'SKU must be unique',
  /** Variant label (e.g. 'Large Oak Natural') */
  VariantLabel: string(200) not null error 'Variant label is required',
  /** Size descriptor (e.g. 'Small', 'Medium', 'Large', '120x80cm') */
  SizeDescription: string(100),
  /** Material used for this variant */
  MaterialDescription: string(100),
  /** Finish type for this variant */
  FinishType: enumeration(ProductCatalog.FinishType),
  /** Price adjustment from base (can be negative) */
  PriceAdjustment: decimal default 0,
  /** Whether this variant is currently available */
  IsAvailable: boolean default true,
  /** Current stock quantity */
  StockQuantity: integer default 0
)
index (SKU);

/**
 * Product image entity
 *
 * Images associated with a catalog product.
 * Inherits from System.Image for file storage.
 *
 * @since 1.0.0
 * @see ProductCatalog.CatalogProduct
 */
@position(350, 250)
create persistent entity ProductCatalog.ProductImage
extends System.Image (
  /** Caption describing the image */
  ImageCaption: string(500),
  /** Whether this is the primary display image */
  IsPrimary: boolean default false,
  /** Sort order for gallery display */
  SortIndex: integer default 0
);

-- MARK: ASSOCIATIONS

/**
 * Self-referencing category hierarchy
 *
 * Links a subcategory to its parent category.
 * Top-level categories have no parent.
 *
 * @since 1.0.0
 */
create association ProductCatalog.ProductCategory_ParentCategory
  from ProductCatalog.ProductCategory to ProductCatalog.ProductCategory
  type reference
  owner default;

/**
 * Links products to their category
 *
 * Each product belongs to one category.
 *
 * @since 1.0.0
 */
create association ProductCatalog.CatalogProduct_ProductCategory
  from ProductCatalog.CatalogProduct to ProductCatalog.ProductCategory
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links variants to their parent product
 *
 * Each variant belongs to exactly one product.
 *
 * @since 1.0.0
 */
create association ProductCatalog.ProductVariant_CatalogProduct
  from ProductCatalog.ProductVariant to ProductCatalog.CatalogProduct
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links images to their product
 *
 * Each image belongs to one product. A product can have many images.
 *
 * @since 1.0.0
 */
create association ProductCatalog.ProductImage_CatalogProduct
  from ProductCatalog.ProductImage to ProductCatalog.CatalogProduct
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;
