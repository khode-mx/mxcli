-- ============================================================================
-- Bespoke Design Domain Model
-- ============================================================================
-- Custom furniture design management with full approval workflow.
-- Tracks the lifecycle from customer request through design drafts,
-- revisions, and approval before feeding into production.
-- ============================================================================

-- MARK: MODULE

/**
 * Bespoke Design module
 *
 * Manages custom furniture design requests, drafts, revisions,
 * and the design approval workflow. Supports document attachments
 * for sketches, renderings, and technical drawings.
 *
 * @since 1.0.0
 */
create module BespokeDesign;

-- MARK: ENUMERATIONS

/**
 * Design request lifecycle status
 *
 * Tracks the full lifecycle of a bespoke design request
 * from initial submission through approval to production handoff.
 *
 * @since 1.0.0
 */
create enumeration BespokeDesign.DesignRequestStatus (
  Submitted 'Submitted',
  UnderReview 'Under Review',
  DesignInProgress 'Design In Progress',
  PendingApproval 'Pending Approval',
  Approved 'Approved',
  Rejected 'Rejected',
  Cancelled 'Cancelled'
);

/**
 * Furniture style preference
 *
 * Common furniture design styles to guide the design process.
 *
 * @since 1.0.0
 */
create enumeration BespokeDesign.FurnitureStyle (
  Modern 'Modern',
  Traditional 'Traditional',
  Rustic 'Rustic',
  Industrial 'Industrial',
  Scandinavian 'Scandinavian',
  MidCentury 'Mid-Century Modern',
  ArtDeco 'Art Deco',
  CustomStyle 'Custom / Other'
);

-- MARK: ENTITIES

/**
 * Design request entity
 *
 * A customer's request for a custom piece of furniture.
 * Contains high-level requirements and preferences that
 * guide the designer during the drafting phase.
 *
 * @since 1.0.0
 * @see CRM.Customer
 * @see BespokeDesign.DesignDraft
 */
@position(50, 50)
create persistent entity BespokeDesign.DesignRequest (
  /** Auto-generated request number */
  RequestNumber: autonumber default 1,
  /** Brief title for the request */
  RequestTitle: string(200) not null error 'Request title is required',
  /** Detailed description of what the customer wants */
  RequestDescription: string(4000),
  /** Preferred furniture style */
  PreferredStyle: enumeration(BespokeDesign.FurnitureStyle),
  /** Budget indication from the customer */
  BudgetIndication: decimal,
  /** Customer's desired delivery date */
  DesiredDeliveryDate: datetime,
  /** Current lifecycle status */
  RequestStatus: enumeration(BespokeDesign.DesignRequestStatus) not null error 'Request status is required',
  /** Date when the request was submitted */
  SubmittedDate: datetime,
  /** Date when the request was last updated */
  LastUpdatedDate: datetime,
  /** Internal notes (not visible to customer) */
  InternalNotes: string(4000)
)
index (RequestStatus);

/**
 * Design draft entity
 *
 * A designer's proposal/draft for a bespoke request.
 * A request can have multiple drafts as the design evolves.
 * Contains the proposed specifications and pricing.
 *
 * @since 1.0.0
 * @see BespokeDesign.DesignRequest
 * @see BespokeDesign.DesignRevision
 */
@position(350, 50)
create persistent entity BespokeDesign.DesignDraft (
  /** Draft version number */
  VersionNumber: integer not null error 'Version number is required' default 1,
  /** Draft title or summary */
  DraftTitle: string(200) not null error 'Draft title is required',
  /** Detailed design description */
  DesignDescription: string(4000),
  /** Proposed price for this design */
  ProposedPrice: decimal,
  /** Estimated production time in days */
  EstimatedProductionDays: integer,
  /** Whether this is the active/current draft */
  IsCurrentDraft: boolean default true,
  /** Date this draft was created */
  CreatedDate: datetime,
  /** Designer's notes */
  DesignerNotes: string(4000)
);

/**
 * Design specification entity
 *
 * Detailed technical specifications for a design draft.
 * Captures dimensions, materials, finishes, and other
 * manufacturing-relevant details.
 *
 * @since 1.0.0
 * @see BespokeDesign.DesignDraft
 */
@position(350, 250)
create persistent entity BespokeDesign.DesignSpecification (
  /** Overall width in millimeters */
  WidthMM: integer,
  /** Overall height in millimeters */
  HeightMM: integer,
  /** Overall depth in millimeters */
  DepthMM: integer,
  /** Primary wood type */
  PrimaryWoodType: string(100),
  /** Secondary wood type (if applicable) */
  SecondaryWoodType: string(100),
  /** Finish specification */
  FinishDescription: string(500),
  /** Upholstery fabric (if applicable) */
  UpholsteryFabric: string(200),
  /** Hardware specification (handles, hinges, etc.) */
  HardwareDescription: string(500),
  /** Additional technical notes */
  TechnicalNotes: string(4000),
  /** Estimated weight in kilograms */
  EstimatedWeightKg: decimal
);

/**
 * Design revision entity
 *
 * Tracks changes between draft versions. Records what changed,
 * why, and who requested the change. Provides an audit trail
 * of the design evolution.
 *
 * @since 1.0.0
 * @see BespokeDesign.DesignDraft
 */
@position(650, 50)
create persistent entity BespokeDesign.DesignRevision (
  /** Revision number within this draft */
  RevisionNumber: integer not null error 'Revision number is required',
  /** Summary of what changed */
  ChangeDescription: string(2000) not null error 'Change description is required',
  /** Who requested this change */
  RequestedBy: string(200),
  /** Date of this revision */
  RevisionDate: datetime,
  /** Whether this revision was accepted */
  IsAccepted: boolean default false
);

/**
 * Design document entity
 *
 * File attachments for design drafts: sketches, renderings,
 * technical drawings, material samples, etc.
 * Inherits from System.FileDocument for file storage.
 *
 * @since 1.0.0
 * @see BespokeDesign.DesignDraft
 */
@position(650, 250)
create persistent entity BespokeDesign.DesignDocument
extends System.FileDocument (
  /** Document description */
  DocumentDescription: string(500),
  /** Document category (Sketch, Rendering, Technical Drawing, etc.) */
  DocumentCategory: string(100),
  /** Upload date */
  UploadDate: datetime
);

-- MARK: ASSOCIATIONS

/**
 * Links design request to the customer
 *
 * Each design request comes from one customer.
 *
 * @since 1.0.0
 */
create association BespokeDesign.DesignRequest_Customer
  from BespokeDesign.DesignRequest to CRM.Customer
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links design draft to its request
 *
 * Each draft belongs to one design request.
 * A request can have multiple drafts.
 *
 * @since 1.0.0
 */
create association BespokeDesign.DesignDraft_DesignRequest
  from BespokeDesign.DesignDraft to BespokeDesign.DesignRequest
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links specification to its draft
 *
 * Each specification belongs to one draft. One-to-one relationship.
 *
 * @since 1.0.0
 */
create association BespokeDesign.DesignSpecification_DesignDraft
  from BespokeDesign.DesignSpecification to BespokeDesign.DesignDraft
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links revisions to their draft
 *
 * Each revision belongs to one draft.
 *
 * @since 1.0.0
 */
create association BespokeDesign.DesignRevision_DesignDraft
  from BespokeDesign.DesignRevision to BespokeDesign.DesignDraft
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links documents to their draft
 *
 * Each document belongs to one draft.
 *
 * @since 1.0.0
 */
create association BespokeDesign.DesignDocument_DesignDraft
  from BespokeDesign.DesignDocument to BespokeDesign.DesignDraft
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;
