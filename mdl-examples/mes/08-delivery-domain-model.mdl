-- ============================================================================
-- Delivery Domain Model
-- ============================================================================
-- Shipping and installation management for completed furniture.
-- Handles delivery scheduling, line-item tracking, and on-site
-- installation appointments.
-- ============================================================================

-- MARK: MODULE

/**
 * Delivery module
 *
 * Manages delivery scheduling for completed furniture orders
 * and on-site installation appointments. Links deliveries to
 * customer orders and specific order lines.
 *
 * @since 1.0.0
 */
create module Delivery;

-- MARK: ENUMERATIONS

/**
 * Delivery lifecycle status
 *
 * Tracks the progress of a furniture delivery.
 *
 * @since 1.0.0
 */
create enumeration Delivery.DeliveryStatus (
  Scheduled 'Scheduled',
  InTransit 'In Transit',
  Delivered 'Delivered',
  Failed 'Failed',
  Returned 'Returned'
);

/**
 * Installation appointment status
 *
 * Tracks the status of on-site furniture installation.
 *
 * @since 1.0.0
 */
create enumeration Delivery.InstallationStatus (
  Scheduled 'Scheduled',
  InProgress 'In Progress',
  Completed 'Completed',
  Rescheduled 'Rescheduled',
  Cancelled 'Cancelled'
);

-- MARK: ENTITIES

/**
 * Delivery order entity
 *
 * A delivery shipment to a customer. Groups one or more
 * order lines that are shipped together. Links to the customer
 * address for delivery.
 *
 * @since 1.0.0
 * @see SalesOrder.CustomerOrder
 * @see CRM.CustomerAddress
 */
@position(50, 50)
create persistent entity Delivery.DeliveryOrder (
  /** Auto-generated delivery number */
  DeliveryNumber: autonumber default 1,
  /** Current delivery status */
  DeliveryStatus: enumeration(Delivery.DeliveryStatus) not null error 'Delivery status is required',
  /** Scheduled delivery date */
  ScheduledDate: datetime,
  /** Actual delivery date */
  ActualDeliveryDate: datetime,
  /** Delivery time window start */
  TimeWindowStart: datetime,
  /** Delivery time window end */
  TimeWindowEnd: datetime,
  /** Delivery driver or carrier name */
  CarrierName: string(200),
  /** Tracking number (if applicable) */
  TrackingNumber: string(100),
  /** Delivery instructions */
  DeliveryInstructions: string(2000),
  /** Customer signature confirmation */
  IsSignedOff: boolean default false,
  /** Notes from the delivery */
  DeliveryNotes: string(2000)
)
index (DeliveryStatus)
index (ScheduledDate);

/**
 * Delivery line entity
 *
 * An individual item included in a delivery.
 * Links to the order line for traceability.
 *
 * @since 1.0.0
 * @see Delivery.DeliveryOrder
 * @see SalesOrder.OrderLine
 */
@position(350, 50)
create persistent entity Delivery.DeliveryLine (
  /** Line number */
  LineNumber: integer not null error 'Line number is required',
  /** Item description */
  ItemDescription: string(500) not null error 'Item description is required',
  /** Quantity being delivered */
  QuantityDelivered: integer not null error 'Quantity is required' default 1,
  /** Condition on delivery (for damage tracking) */
  DeliveryCondition: string(500),
  /** Whether the item was accepted by customer */
  IsAccepted: boolean default true
);

/**
 * Installation appointment entity
 *
 * On-site furniture installation scheduling.
 * Some furniture requires professional assembly or placement.
 * Links to the delivery order for coordination.
 *
 * @since 1.0.0
 * @see Delivery.DeliveryOrder
 */
@position(50, 250)
create persistent entity Delivery.InstallationAppointment (
  /** Auto-generated appointment number */
  AppointmentNumber: autonumber default 1,
  /** Current appointment status */
  AppointmentStatus: enumeration(Delivery.InstallationStatus) not null error 'Status is required',
  /** Scheduled date and start time */
  ScheduledDateTime: datetime not null error 'Scheduled date is required',
  /** Estimated duration in hours */
  EstimatedDurationHours: decimal default 2,
  /** Actual duration in hours */
  ActualDurationHours: decimal,
  /** Assigned installer name */
  InstallerName: string(200),
  /** Customer contact for appointment */
  CustomerContactName: string(200),
  /** Customer contact phone */
  CustomerContactPhone: string(50),
  /** Installation instructions */
  InstallationInstructions: string(2000),
  /** Notes from the installation */
  InstallationNotes: string(2000),
  /** Whether the customer signed off on installation */
  IsSignedOff: boolean default false
)
index (AppointmentStatus)
index (ScheduledDateTime);

-- MARK: ASSOCIATIONS

/**
 * Links delivery order to the customer order
 *
 * Each delivery is for one customer order.
 *
 * @since 1.0.0
 */
create association Delivery.DeliveryOrder_CustomerOrder
  from Delivery.DeliveryOrder to SalesOrder.CustomerOrder
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links delivery order to the delivery address
 *
 * Specifies where to deliver.
 *
 * @since 1.0.0
 */
create association Delivery.DeliveryOrder_CustomerAddress
  from Delivery.DeliveryOrder to CRM.CustomerAddress
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links delivery line to its delivery order
 *
 * Each line belongs to one delivery.
 *
 * @since 1.0.0
 */
create association Delivery.DeliveryLine_DeliveryOrder
  from Delivery.DeliveryLine to Delivery.DeliveryOrder
  type reference
  owner default
  delete_behavior DELETE_AND_REFERENCES;

/**
 * Links delivery line to the order line
 *
 * Traces what order item this delivery line fulfills.
 *
 * @since 1.0.0
 */
create association Delivery.DeliveryLine_OrderLine
  from Delivery.DeliveryLine to SalesOrder.OrderLine
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;

/**
 * Links installation to its delivery order
 *
 * Each installation appointment is for one delivery.
 *
 * @since 1.0.0
 */
create association Delivery.InstallationAppointment_DeliveryOrder
  from Delivery.InstallationAppointment to Delivery.DeliveryOrder
  type reference
  owner default
  delete_behavior DELETE_BUT_KEEP_REFERENCES;
