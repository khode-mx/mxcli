-- =============================================================================
-- Shop Module - E-commerce Domain Model Example
-- =============================================================================
-- This MDL file demonstrates a complete e-commerce domain model including:
-- - Customer management with addresses
-- - Order processing with line items
-- - Product catalog with categories, tags, and pricing
-- - Payment and delivery tracking
-- - Multi-tenancy support
-- =============================================================================

create module Shop;

-- MARK: CORE ORDER ENTITIES

/**
 * Customer purchase order
 *
 * Represents a customer's order containing order metadata, pricing,
 * and links to customer, order lines, payment, and delivery status.
 *
 * @since 1.0.0
 * @see Shop.OrderLine
 * @see Shop.Customer
 */
@position(560, 260)
create persistent entity Shop.Order (
  /** Unique identifier for the order. Auto-generated sequence. */
  OrderId: long not null unique default 0,
  /** Date and time when the order was placed. */
  OrderDate: datetime,
  /** Discount percentage applied to the order (0-100). */
  Discount: integer default 0,
  /** Calculated total price after discount, in euros. */
  TotalPrice: decimal default 0
)
index (OrderId)
index (OrderDate);

grant Shop.ShopUser, Shop.UserRole on Shop.Order (delete, read *, write *);
/

/**
 * Order line item
 *
 * Represents a single line item in an order. Links a product
 * to an order with quantity and optional notes.
 *
 * @since 1.0.0
 * @see Shop.Order
 * @see Shop.Product
 */
@position(870, 260)
create persistent entity Shop.OrderLine (
  /** Unique identifier for the order line. */
  OrderLineId: long not null unique default 0,
  /** Quantity of the product ordered. */
  Amount: long default 0,
  /** Optional note or special instructions for this line item. */
  Note: string
)
index (OrderLineId)
index (Note);

grant Shop.ShopUser on Shop.OrderLine (delete, read *, write *);
/

/**
 * Archived orders
 *
 * Archive table for historical orders. Mirrors the Order entity
 * structure for long-term storage and reporting.
 *
 * @since 1.0.0
 */
@position(570, 400)
create persistent entity Shop.OrdersArchived (
  /** Original order identifier from the archived order. */
  OrderId: long not null unique default 0,
  /** Original date when the order was placed. */
  OrderDate: datetime,
  /** Discount percentage that was applied to the order. */
  Discount: integer default 0,
  /** Final total price of the archived order. */
  TotalPrice: decimal default 0
)
index (OrderId);
/

-- MARK: CUSTOMER ENTITIES

/**
 * Shop customer
 *
 * Represents a customer in the shop. Contains personal information
 * and supports multi-tenancy through TenantId.
 *
 * @since 1.0.0
 * @see Shop.Address
 * @see Shop.Order
 */
@position(560, 50)
create persistent entity Shop.Customer (
  /** Unique identifier for the customer. */
  CustomerId: long not null unique default 0,
  /** Customer first name. */
  FirstName: string,
  /** Customer last name. Indexed for fast lookup. */
  LastName: string,
  /** Customer email address for communications and login. */
  EmailAddress: string,
  /** Customer date of birth for age verification and marketing. */
  DateOfBirth: datetime,
  /** Tenant identifier for multi-tenant deployments. */
  TenantId: long default 0
)
index (CustomerId)
index (LastName);

grant Shop.ShopUser on Shop.Customer (delete, read *, write *);
/

/**
 * Customer address
 *
 * Represents a physical address. Used for both billing and delivery
 * addresses via separate associations to Customer.
 *
 * @since 1.0.0
 * @see Shop.Customer
 */
@position(950, 50)
create persistent entity Shop.Address (
  /** Unique identifier for the address. */
  AddressId: long not null unique default 0,
  /** Street name of the address. */
  Streetname: string,
  /** Street/house number. */
  StreetNumber: integer default 0,
  /** Postal/ZIP code. */
  Zipcode: string,
  /** City name. Indexed for geographic queries. */
  City: string,
  /** Country name. Indexed for geographic queries and reporting. */
  Country: string
)
index (AddressId)
index (City)
index (Country);

grant Shop.ShopUser on Shop.Address (delete, read *, write *);
/

/**
 * User tenant
 *
 * Defines tenants for multi-tenant deployments.
 * Links users to their organizational context.
 *
 * @since 1.0.0
 */
@position(580, 640)
create persistent entity Shop.UserTenant (
  /** Unique identifier for the tenant. */
  TenantId: long default 0,
  /** Display name of the tenant organization. */
  TenantName: string
);
/

-- MARK: PRODUCT CATALOG ENTITIES

/**
 * Product
 *
 * Represents a product in the catalog. Contains core product information;
 * pricing is managed separately via the Price entity for time-based pricing support.
 *
 * @since 1.0.0
 * @see Shop.Price
 * @see Shop.Category
 */
@position(1150, 210)
create persistent entity Shop.Product (
  /** Unique identifier for the product (SKU). */
  ProductId: integer not null unique default 0,
  /** Product display name. Indexed for search. */
  Name: string,
  /** Detailed product description for display. */
  description: string,
  /** Product weight in grams for shipping calculations. */
  WeightInGrams: long default 0,
  /** Whether the product is active and available for sale. */
  IsActive: boolean default true
)
index (ProductId)
index (Name)
index (IsActive);

grant Shop.ShopUser on Shop.Product (delete, read *, write *);
/

/**
 * Product price
 *
 * Represents a price point for a product. Supports time-based pricing
 * with start dates, enabling historical price tracking and future price scheduling.
 *
 * @since 1.0.0
 * @see Shop.Product
 */
@position(1150, 40)
create persistent entity Shop.Price (
  /** Unique identifier for the price record. */
  PriceId: long not null unique default 0,
  /** Product price in euros. */
  PriceInEuro: decimal default 0,
  /** Date when this price becomes effective. */
  StartDate: datetime,
  /** Composite key combining ProductId and StartDate for uniqueness. */
  ProductIdPriceDate: string unique
)
index (PriceId)
index (StartDate)
index (PriceInEuro);

grant Shop.ShopUser on Shop.Price (delete, read *, write *);
/

/**
 * Product category
 *
 * Represents a product category. Supports hierarchical categorization
 * through self-referencing ParentCategoryId.
 *
 * @since 1.0.0
 */
@position(1480, 220)
create persistent entity Shop.Category (
  /** Unique identifier for the category. */
  CategoryId: long not null unique default 0,
  /** Category display name. Required and indexed. */
  Name: string not null,
  /** Detailed description of the category. */
  description: string,
  /** Reference to parent category for hierarchical structure. 0 indicates root category. */
  ParentCategoryId: long default 0
)
index (CategoryId)
index (Name)
index (ParentCategoryId);

grant Shop.ShopUser on Shop.Category (delete, read *, write *);
/

/**
 * Product translations
 *
 * Stores translations of product name and description for
 * internationalization (i18n) support.
 *
 * @since 1.0.0
 * @see Shop.Product
 */
@position(1170, 410)
create persistent entity Shop.ProductTranslations (
  /** Reference to the product being translated. */
  ProductId: integer default 0,
  /** ISO language code (e.g., en, nl, de, fr). */
  LanguageCode: string,
  /** Translated product name. */
  Name: string,
  /** Translated product description. */
  description: string
);

grant Shop.ShopUser on Shop.ProductTranslations (create, delete, read *, write *);
/

-- MARK: TAGGING SYSTEM

/**
 * Tag type
 *
 * Defines a tag type for product categorization.
 * Examples: Color, Size, Material. Products are associated
 * with TagValues, not directly with Tags.
 *
 * @since 1.0.0
 * @see Shop.TagValue
 */
@position(820, 640)
create persistent entity Shop.Tag (
  /** Unique identifier for the tag type. */
  TagId: long not null unique default 0,
  /** Tag type name (e.g., Color, Size, Material). Must be unique. */
  Name: string unique,
  /** Description of what this tag type represents. */
  description: string
)
index (TagId);

grant Shop.ShopUser on Shop.Tag (delete, read *, write *);
/

/**
 * Tag value
 *
 * Represents a specific value for a tag type. Examples: Red (for Color),
 * Large (for Size). Products link to TagValues via a many-to-many relationship.
 *
 * @since 1.0.0
 * @see Shop.Tag
 * @see Shop.Product
 */
@position(980, 490)
create persistent entity Shop.TagValue (
  /** Unique identifier for the tag value. */
  TagValueId: long not null unique default 0,
  /** Reference to the parent Tag type. */
  TagId: long not null default 0,
  /** The actual tag value (e.g., Red, Large, Cotton). */
  value: string not null,
  /** Optional description of this tag value. */
  description: string
)
index (TagValueId)
index (TagId);

grant Shop.ShopUser on Shop.TagValue (delete, read *, write *);
/

-- MARK: PAYMENT AND DELIVERY ENTITIES

/**
 * Payment transaction
 *
 * Records payment transactions for orders. Stores payment timestamp
 * and payment method reference.
 *
 * @since 1.0.0
 * @see Shop.Order
 */
@position(220, 440)
create persistent entity Shop.Payment (
  /** Unique identifier for the payment transaction. */
  PaymentId: long not null unique default 0,
  /** Date and time when the payment was processed. */
  PaymentTimestamp: datetime,
  /** Masked or tokenized credit card number for reference. */
  CreditcardNumber: string
)
index (PaymentId);

grant Shop.ShopUser on Shop.Payment (delete, read *, write *);
/

/**
 * Delivery status
 *
 * Tracks delivery progress for an order. Multiple status records
 * per order create a delivery history timeline.
 *
 * @since 1.0.0
 * @see Shop.Order
 */
@position(220, 310)
create persistent entity Shop.DeliveryStatus (
  /** Unique identifier for the delivery status record. */
  DeliveryStatusId: long not null unique default 0,
  /** Current delivery status (Pending, Shipped, InTransit, Delivered, etc.). */
  status: enumeration(Shop.DeliveryStatusEnum),
  /** Date and time when this status was recorded. */
  DeliveryStatusTimestamp: datetime,
  /** Current location or tracking information. */
  Location: string
);

grant Shop.ShopUser on Shop.DeliveryStatus (delete, read *, write *);
/

-- MARK: VIEW ENTITIES

/**
 * Task queue view
 *
 * Unified view combining queued and processed tasks.
 * Provides a single view for monitoring all task queue activity.
 *
 * @since 1.0.0
 */
@position(2340, 410)
create view entity Shop.TaskQueue (
  /** Sequence number of the task. */
  TaskSequence: long,
  /** Current status of the task. */
  status: enumeration(System.QueueTaskStatus),
  /** Identifier of the queue. */
  QueueId: string,
  /** Name of the queue. */
  QueueName: string,
  /** Name of the microflow being executed. */
  MicroflowName: string,
  /** When the task was created. */
  created: datetime,
  /** Scheduled start time. */
  StartedAt: datetime,
  /** Actual start time. */
  Started: datetime,
  /** Completion time. */
  Finished: datetime,
  /** Duration in seconds. */
  Duration: long
) as (
  from System.ProcessedQueueTask as pqt
  select
    pqt.Sequence as TaskSequence
  , pqt.status as status
  , pqt.QueueId as QueueId
  , pqt.QueueName as QueueName
  , pqt.MicroflowName as MicroflowName
  , pqt.created as created
  , pqt.StartAt as StartedAt
  , pqt.Started as Started
  , pqt.Finished as Finished
  , pqt.Duration as Duration
  union
  from System.QueuedTask as qt
  select
    qt.Sequence as TaskSequence
  , qt.status as status
  , qt.QueueId as QueueId
  , qt.QueueName as QueueName
  , qt.MicroflowName as MicroflowName
  , qt.created as created
  , qt.StartAt as StartedAt
  , qt.Started as Started
  , '[%CurrentDateTime%]' as Finished
  , datediff(SECOND, qt.Started, '[%CurrentDateTime%]') as Duration
);

grant Shop.ShopUser on Shop.TaskQueue (read *, write *);
/

/**
 * EU customer count by country
 *
 * Aggregates customer counts by EU country based on billing addresses.
 * Useful for geographic distribution analysis and reporting.
 *
 * @since 1.0.0
 */
@position(820, 840)
create view entity Shop.OrderTotalsVE (
  /** EU country name. */
  Country: string,
  /** Number of customers with billing addresses in this country. */
  CustomerCount: integer
) as (
  from Shop.Address as a
    inner join Shop.BillingAddress_Customer/Shop.Customer as c
  where a.Country in ('Austria', 'Belgium', 'Bulgaria', 'Croatia', 'Cyprus', 'Czech Republic', 'Denmark', 'Estonia', 'Finland', 'France', 'Germany', 'Greece', 'Hungary', 'Ireland', 'Italy', 'Latvia', 'Lithuania', 'Luxembourg', 'Malta', 'Netherlands', 'Poland', 'Portugal', 'Romania', 'Slovakia', 'Slovenia', 'Spain', 'Sweden')
  group by a.Country
  select a.Country as Country,
         count(c.CustomerId) as CustomerCount
  order by CustomerCount desc limit 1000
);
/

/**
 * Key European markets customer count
 *
 * Customer count for key European markets (Netherlands, Germany, Italy)
 * based on delivery addresses.
 *
 * @since 1.0.0
 */
@position(580, 840)
create view entity Shop.EuropeanCountryCustomerCountVe (
  /** Country name (Netherlands, Germany, or Italy). */
  Country: string,
  /** Number of customers with delivery addresses in this country. */
  CustomerCount: integer
) as (
  select
    a.Country as Country,
    count(c.CustomerId) as CustomerCount
  from
    Shop.Customer as c
    inner join c/Shop.DeliveryAddress_Customer/Shop.Address as a
  where
    a.Country = 'Netherlands'
    or a.Country = 'Germany'
    or a.Country = 'Italy'
  GROUP by
    a.Country
);
/

-- MARK: ASSOCIATIONS

/**
 * Order line to order
 *
 * Links order lines to their parent order.
 * Each order line belongs to exactly one order.
 *
 * @since 1.0.0
 */
create association Shop.OrderLine_Order
from Shop.OrderLine to Shop.Order
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Order to customer
 *
 * Links orders to the customer who placed them.
 * Each order is placed by one customer.
 *
 * @since 1.0.0
 */
create association Shop.Order_Customer
from Shop.Order to Shop.Customer
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Order line to product
 *
 * Links order lines to the purchased product.
 * Each order line references one product.
 *
 * @since 1.0.0
 */
create association Shop.OrderLine_Product
from Shop.OrderLine to Shop.Product
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Payment to order
 *
 * Links payment transactions to orders.
 * Each payment is associated with one order.
 *
 * @since 1.0.0
 */
create association Shop.Payment_Order
from Shop.Payment to Shop.Order
type reference
owner both
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Delivery status to order
 *
 * Links delivery status updates to orders.
 * Multiple status updates can exist per order (tracking history).
 *
 * @since 1.0.0
 */
create association Shop.DeliveryStatus_Order
from Shop.DeliveryStatus to Shop.Order
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Price to product
 *
 * Links prices to products.
 * Multiple prices per product for historical/scheduled pricing.
 *
 * @since 1.0.0
 */
create association Shop.Price_Product
from Shop.Price to Shop.Product
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Billing address to customer
 *
 * Links billing addresses to customers.
 * Customer's billing address.
 *
 * @since 1.0.0
 */
create association Shop.BillingAddress_Customer
from Shop.Address to Shop.Customer
type reference
owner both
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Delivery address to customer
 *
 * Links delivery addresses to customers.
 * Customer's delivery address (can differ from billing).
 *
 * @since 1.0.0
 */
create association Shop.DeliveryAddress_Customer
from Shop.Address to Shop.Customer
type reference
owner both
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Product to tag values
 *
 * Links products to their tag values.
 * Products can have multiple tag values (e.g., Color: Red, Size: Large).
 *
 * @since 1.0.0
 */
create association Shop.Product_TagValue
from Shop.Product to Shop.TagValue
type ReferenceSet
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Tag value to tag
 *
 * Links tag values to their parent tag type.
 * Each tag value belongs to one tag type.
 *
 * @since 1.0.0
 */
create association Shop.TagValue_Tag
from Shop.TagValue to Shop.Tag
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Product to category
 *
 * Links products to their category.
 * Each product belongs to one category.
 *
 * @since 1.0.0
 */
create association Shop.Product_Category
from Shop.Product to Shop.Category
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/

/**
 * Product translations to product
 *
 * Links translations to their product.
 * Multiple translations per product for i18n support.
 *
 * @since 1.0.0
 */
create association Shop.ProductTranslations_Product
from Shop.ProductTranslations to Shop.Product
type reference
owner default
delete_behavior DELETE_BUT_KEEP_REFERENCES;
/
