-- ============================================================================
-- System Attribute Examples (Issue #182)
-- ============================================================================
--
-- Mendix persistent entities support four optional system attributes for
-- built-in auditing. Declare them as pseudo-types (like AutoNumber):
--
--   AutoOwner          -> System.owner association (auto-set on create)
--   AutoChangedBy      -> System.changedBy association (auto-set on commit)
--   AutoCreatedDate    -> CreatedDate: DateTime (auto-set on create)
--   AutoChangedDate    -> ChangedDate: DateTime (auto-set on commit)
--
-- This file demonstrates enabling these both during CREATE ENTITY
-- (as pseudo-typed attributes) and via ALTER ENTITY (SET / DROP STORE).
--
-- ============================================================================

CREATE MODULE SysAttrTest;

-- ============================================================================
-- Example 1: All four system attributes set during CREATE
-- ============================================================================

/**
 * Audited entity that uses all four built-in system attributes.
 */
CREATE OR MODIFY PERSISTENT ENTITY SysAttrTest.AuditedRecord (
  Title: String(200) NOT NULL,
  Amount: Decimal,
  Owner: AutoOwner,
  ChangedBy: AutoChangedBy,
  CreatedDate: AutoCreatedDate,
  ChangedDate: AutoChangedDate
);

-- ============================================================================
-- Example 2: Subset of system attributes
-- ============================================================================

CREATE OR MODIFY PERSISTENT ENTITY SysAttrTest.LogEntry (
  Message: String(500),
  Level: String(20),
  CreatedDate: AutoCreatedDate
);

-- ============================================================================
-- Example 3: ALTER ENTITY to enable flags after creation
-- ============================================================================

CREATE OR MODIFY PERSISTENT ENTITY SysAttrTest.Customer (
  Name: String(100) NOT NULL,
  Email: String(200)
);

ALTER ENTITY SysAttrTest.Customer SET STORE OWNER;
ALTER ENTITY SysAttrTest.Customer SET STORE CHANGED BY;
ALTER ENTITY SysAttrTest.Customer SET STORE CREATED DATE;
ALTER ENTITY SysAttrTest.Customer SET STORE CHANGED DATE;

-- ============================================================================
-- Example 4: ALTER ENTITY to disable previously enabled flags
-- ============================================================================

CREATE OR MODIFY PERSISTENT ENTITY SysAttrTest.TempRecord (
  Payload: String(100),
  Owner: AutoOwner,
  CreatedDate: AutoCreatedDate
);

-- Disable both flags
ALTER ENTITY SysAttrTest.TempRecord DROP STORE OWNER;
ALTER ENTITY SysAttrTest.TempRecord DROP STORE CREATED DATE;

-- ============================================================================
-- Example 5: Entity with event handlers
-- ============================================================================

CREATE MICROFLOW SysAttrTest.ACT_ValidateOrder ($Order: SysAttrTest.AuditedRecord)
RETURNS Boolean
BEGIN
  RETURN true;
END;

CREATE MICROFLOW SysAttrTest.ACT_AfterCommitOrder ($Order: SysAttrTest.AuditedRecord)
BEGIN
  RETURN empty;
END;

-- RAISE ERROR: only valid on BEFORE handlers (microflow returns Boolean, false = abort)
ALTER ENTITY SysAttrTest.AuditedRecord
  ADD EVENT HANDLER ON BEFORE COMMIT CALL SysAttrTest.ACT_ValidateOrder RAISE ERROR;

-- AFTER handlers cannot RAISE ERROR (microflow returns Void)
ALTER ENTITY SysAttrTest.AuditedRecord
  ADD EVENT HANDLER ON AFTER COMMIT CALL SysAttrTest.ACT_AfterCommitOrder;
