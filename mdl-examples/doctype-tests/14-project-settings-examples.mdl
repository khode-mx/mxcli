-- ============================================================================
-- Project Settings Examples - Comprehensive Parser Feature Showcase
-- ============================================================================
--
-- This file demonstrates all project settings features supported by the
-- Mendix REPL parser.
--
-- Usage:
--   1. Connect to your project
--   2. Execute: EXECUTE SCRIPT 'examples/14-project-settings-examples.mdl';
--   3. Verify with: SHOW SETTINGS;
--
-- NOTE: These ALTER SETTINGS commands modify the project's settings in place.
-- Always use DESCRIBE SETTINGS first to capture current values before changes.
--
-- ============================================================================

-- MARK: Model Settings

-- ============================================================================
-- PART 1: Model Settings
-- ============================================================================

-- Create prerequisites used in settings examples below.
create module MyModule;
create microflow MyModule.ASU_Startup() returns boolean
begin
  return true;
end;
/

/**
 * Example 1.1: Set after-startup microflow
 */
alter settings model AfterStartupMicroflow = 'MyModule.ASU_Startup';

/**
 * Example 1.2: Configure hash algorithm and Java version
 */
alter settings model HashAlgorithm = 'BCrypt', JavaVersion = 'Java21';

/**
 * Example 1.3: Multiple model settings at once
 */
alter settings model
  RoundingMode = 'HalfUp',
  BcryptCost = 12,
  AllowUserMultipleSessions = true;

-- MARK: Configuration Settings

-- ============================================================================
-- PART 2: Database Configuration
-- ============================================================================

/**
 * Example 2.1: Configure PostgreSQL database connection
 */
alter settings configuration 'Default'
  DatabaseType = 'PostgreSql',
  DatabaseUrl = 'localhost:5432',
  DatabaseName = 'myapp',
  DatabaseUserName = 'mendix',
  DatabasePassword = 'mendix',
  HttpPortNumber = 8080;

-- MARK: Constant Overrides

-- ============================================================================
-- PART 3: Constant Value Overrides
-- ============================================================================

/**
 * Example 3.1: Override a constant value in a specific configuration
 */
create constant MyModule.ServerUrl type string default 'localhost:9092';
alter settings constant 'MyModule.ServerUrl' value 'kafka:9092'
  in configuration 'Default';

/**
 * Example 3.2: Remove a constant override (reset to default)
 */
alter settings drop constant 'MyModule.ServerUrl' in configuration 'Default';

/**
 * Example 3.3: Alternative syntax for removing a constant override
 * (Re-set the value first so there is something to drop)
 */
alter settings constant 'MyModule.ServerUrl' value 'kafka:9092'
  in configuration 'Default';
alter settings constant 'MyModule.ServerUrl' drop in configuration 'Default';

-- MARK: Create / Drop Configuration

-- ============================================================================
-- PART 3B: Create and Drop Configurations
-- ============================================================================

/**
 * Example 3B.1: Create a new configuration with defaults
 */
create configuration 'Staging';

/**
 * Example 3B.2: Create a configuration with properties
 */
create configuration 'Production'
  DatabaseType = 'POSTGRESQL',
  DatabaseUrl = 'prod-db:5432',
  DatabaseName = 'myapp_prod',
  HttpPortNumber = 8080;

/**
 * Example 3B.3: Drop a configuration
 */
drop configuration 'Staging';

-- MARK: Language Settings

-- ============================================================================
-- PART 4: Language and Workflow Settings
-- ============================================================================

/**
 * Example 4.1: Set default language
 */
alter settings language DefaultLanguageCode = 'en_US';

/**
 * Example 4.2: Configure workflow settings
 */
alter settings workflows UserEntity = 'System.User';

-- ============================================================================
-- SUMMARY
-- ============================================================================
--
-- Covered:
-- ALTER SETTINGS MODEL (microflows, hash algorithm, Java version)
-- ALTER SETTINGS CONFIGURATION (database connection, HTTP port)
-- ALTER SETTINGS CONSTANT with IN CONFIGURATION
-- ALTER SETTINGS DROP CONSTANT (remove override, both syntax forms)
-- CREATE CONFIGURATION (with and without properties)
-- DROP CONFIGURATION
-- ALTER SETTINGS LANGUAGE
-- ALTER SETTINGS WORKFLOWS
-- SHOW SETTINGS / DESCRIBE SETTINGS (read-only)
--
-- ============================================================================
