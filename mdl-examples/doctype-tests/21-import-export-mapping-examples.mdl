-- ============================================================================
-- Import & Export Mapping Examples
-- ============================================================================
--
-- This file demonstrates import and export mapping features.
--
-- IMPORTANT: Import and export mappings require different domain models
-- when dealing with nested JSON. The association direction and entity
-- structure must match what Mendix expects for each mapping type:
--
--   Import: The child entity owns the FK to the parent (FROM child TO parent).
--           Arrays are represented as a single object at the item path.
--
--   Export: Studio Pro generates entities that mirror the JSON structure,
--           with an intermediate entity for array containers.
--           Arrays have two levels: container + item.
--
-- This file shows both patterns with separate domain models.
--
-- ============================================================================

-- ############################################################################
-- PART 0: MODULE SETUP
-- ############################################################################

CREATE MODULE MapTest;

-- ============================================================================
-- JSON Structures
-- ============================================================================

CREATE JSON STRUCTURE MapTest.JSON_Pet
SNIPPET '{"id": 1, "name": "Fido", "status": "available"}';

CREATE JSON STRUCTURE MapTest.JSON_Order
SNIPPET '{"orderId": 100, "customer": {"name": "Alice", "email": "alice@example.com"}, "items": [{"sku": "A1", "quantity": 2, "price": 9.99}]}';

-- ############################################################################
-- PART 1: SIMPLE MAPPINGS (flat JSON, shared domain model)
-- ############################################################################

-- ============================================================================
-- Entities for flat JSON (used by both import and export)
-- ============================================================================

CREATE NON-PERSISTENT ENTITY MapTest.PetResponse (
  PetId: Integer,
  Name: String,
  Status: String
);
/

-- ============================================================================
-- Level 1.1: Simple Import Mapping
-- ============================================================================

CREATE IMPORT MAPPING MapTest.IMM_SimplePet
  WITH JSON STRUCTURE MapTest.JSON_Pet
{
  CREATE MapTest.PetResponse {
    PetId = id,
    Name = name,
    Status = status
  }
};

DESCRIBE IMPORT MAPPING MapTest.IMM_SimplePet;

-- ============================================================================
-- Level 1.2: Simple Export Mapping
-- ============================================================================

CREATE EXPORT MAPPING MapTest.EMM_Pet
  WITH JSON STRUCTURE MapTest.JSON_Pet
{
  MapTest.PetResponse {
    id = PetId,
    name = Name,
    status = Status
  }
};

DESCRIBE EXPORT MAPPING MapTest.EMM_Pet;

-- ============================================================================
-- Level 1.3: Find Or Create (upsert pattern)
-- ============================================================================
--
-- FIND OR CREATE looks up an existing object by KEY attributes.
-- If not found, creates a new one. Useful for idempotent imports.

CREATE IMPORT MAPPING MapTest.IMM_UpsertPet
  WITH JSON STRUCTURE MapTest.JSON_Pet
{
  FIND OR CREATE MapTest.PetResponse {
    PetId = id KEY,
    Name = name,
    Status = status
  }
};

DESCRIBE IMPORT MAPPING MapTest.IMM_UpsertPet;

-- ============================================================================
-- Level 1.4: Export with NULL VALUES option
-- ============================================================================
--
-- NULL VALUES controls how null attributes are serialized:
--   LeaveOutElement — omit the JSON key entirely (default)
--   SendAsNil      — include the key with null value

CREATE EXPORT MAPPING MapTest.EMM_PetNullable
  WITH JSON STRUCTURE MapTest.JSON_Pet
  NULL VALUES SendAsNil
{
  MapTest.PetResponse {
    id = PetId,
    name = Name,
    status = Status
  }
};

DESCRIBE EXPORT MAPPING MapTest.EMM_PetNullable;

-- ############################################################################
-- PART 2: NESTED IMPORT MAPPING
-- ############################################################################
--
-- For import mappings with nested JSON objects and arrays:
--   - The child entity owns the FK (FROM child TO parent)
--   - Arrays map directly to the item entity (no intermediate container)
--   - Association name format: ChildEntity_ParentEntity
--
-- JSON_Order has: { orderId, customer: { name, email }, items: [{ sku, quantity, price }] }

-- ============================================================================
-- Import Domain Model
-- ============================================================================

CREATE NON-PERSISTENT ENTITY MapTest.OrderResponse (
  OrderId: Integer
);
/

CREATE NON-PERSISTENT ENTITY MapTest.CustomerInfo (
  Name: String,
  Email: String
);
/

CREATE NON-PERSISTENT ENTITY MapTest.OrderItem (
  Sku: String,
  Quantity: Integer,
  Price: Decimal
);
/

-- Associations: child entity FROM, parent entity TO
CREATE ASSOCIATION MapTest.CustomerInfo_OrderResponse
  FROM MapTest.CustomerInfo
  TO MapTest.OrderResponse;
/

CREATE ASSOCIATION MapTest.OrderItem_OrderResponse
  FROM MapTest.OrderItem
  TO MapTest.OrderResponse;
/

-- ============================================================================
-- Level 2.1: Nested Import Mapping
-- ============================================================================

CREATE IMPORT MAPPING MapTest.IMM_Order
  WITH JSON STRUCTURE MapTest.JSON_Order
{
  CREATE MapTest.OrderResponse {
    OrderId = orderId,
    CREATE MapTest.CustomerInfo_OrderResponse/MapTest.CustomerInfo = customer {
      Name = name,
      Email = email
    },
    CREATE MapTest.OrderItem_OrderResponse/MapTest.OrderItem = items {
      Sku = sku,
      Quantity = quantity,
      Price = price
    }
  }
};

DESCRIBE IMPORT MAPPING MapTest.IMM_Order;

-- ############################################################################
-- PART 3: NESTED EXPORT MAPPING
-- ############################################################################
--
-- For export mappings, Studio Pro generates a domain model that mirrors
-- the JSON structure. Key differences from import:
--   - A root entity matches the top-level JSON object
--   - Array fields need an intermediate container entity (e.g., Items)
--     plus an item entity (e.g., ItemsItem)
--   - Associations: child entity FROM, parent entity TO (same direction)
--
-- This means import and export of the same JSON typically use DIFFERENT
-- entity structures. You cannot reuse the import domain model for export.

-- ============================================================================
-- Export Domain Model (mirrors JSON_Order structure)
-- ============================================================================

CREATE NON-PERSISTENT ENTITY MapTest.ExRoot (
  OrderId: Integer
);
/

CREATE NON-PERSISTENT ENTITY MapTest.ExCustomer (
  Name: String,
  Email: String
);
/

-- Container entity for the "items" array (no attributes)
CREATE NON-PERSISTENT ENTITY MapTest.ExItems;
/

-- Item entity for each element in the "items" array
CREATE NON-PERSISTENT ENTITY MapTest.ExItemsItem (
  Sku: String,
  Quantity: Integer,
  Price: Decimal
);
/

CREATE ASSOCIATION MapTest.ExCustomer_ExRoot
  FROM MapTest.ExCustomer
  TO MapTest.ExRoot
  OWNER Both;
/

CREATE ASSOCIATION MapTest.ExItems_ExRoot
  FROM MapTest.ExItems
  TO MapTest.ExRoot;
/

CREATE ASSOCIATION MapTest.ExItemsItem_ExItems
  FROM MapTest.ExItemsItem
  TO MapTest.ExItems;
/

-- ============================================================================
-- Level 3.1: Nested Export Mapping
-- ============================================================================

CREATE EXPORT MAPPING MapTest.EMM_Order
  WITH JSON STRUCTURE MapTest.JSON_Order
{
  MapTest.ExRoot {
    orderId = OrderId,
    MapTest.ExCustomer_ExRoot/MapTest.ExCustomer AS customer {
      name = Name,
      email = Email
    },
    MapTest.ExItems_ExRoot/MapTest.ExItems AS items {
      MapTest.ExItemsItem_ExItems/MapTest.ExItemsItem AS ItemsItem {
        sku = Sku,
        quantity = Quantity,
        price = Price
      }
    }
  }
};

DESCRIBE EXPORT MAPPING MapTest.EMM_Order;

-- ############################################################################
-- PART 4: SHOW AND LIST COMMANDS
-- ############################################################################

SHOW IMPORT MAPPINGS;
SHOW IMPORT MAPPINGS IN MapTest;
SHOW EXPORT MAPPINGS;
SHOW EXPORT MAPPINGS IN MapTest;

-- ############################################################################
-- PART 5: DROP COMMANDS
-- ############################################################################

DROP IMPORT MAPPING MapTest.IMM_UpsertPet;
DROP EXPORT MAPPING MapTest.EMM_PetNullable;

SHOW IMPORT MAPPINGS IN MapTest;
SHOW EXPORT MAPPINGS IN MapTest;

-- ############################################################################
-- PART 6: MICROFLOW ACTIONS (IMPORT FROM / EXPORT TO MAPPING)
-- ############################################################################

-- ============================================================================
-- Level 6.1: Import from mapping (JSON string → entity)
-- ============================================================================

CREATE MICROFLOW MapTest.ACT_ImportPet ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;
  DECLARE $Json String = '{{\"id\": 1, \"name\": \"Fido\", \"status\": \"available\"}';

  $PetResponse = IMPORT FROM MAPPING MapTest.IMM_SimplePet($Json);

  IF $PetResponse != empty THEN
    SET $Success = true;
    LOG INFO NODE 'MapTest' 'Imported pet: ' + $PetResponse/Name;
  END IF;

  RETURN $Success;
END;
/

-- ============================================================================
-- Level 6.2: Export to mapping (entity → JSON string)
-- ============================================================================

CREATE MICROFLOW MapTest.ACT_ExportPet ($PetResponse: MapTest.PetResponse)
RETURNS String AS $JsonOutput
BEGIN
  $JsonOutput = EXPORT TO MAPPING MapTest.EMM_Pet($PetResponse);
  LOG INFO NODE 'MapTest' 'Exported: ' + $JsonOutput;
  RETURN $JsonOutput;
END;
/

-- ============================================================================
-- Level 6.3: Import → Process → Export pipeline
-- ============================================================================

CREATE MICROFLOW MapTest.ACT_RoundTrip ()
BEGIN
  DECLARE $Json String = '{{\"id\": 42, \"name\": \"Rex\", \"status\": \"pending\"}';
  $Pet = IMPORT FROM MAPPING MapTest.IMM_SimplePet($Json);
  $Output = EXPORT TO MAPPING MapTest.EMM_Pet($Pet);
  LOG INFO NODE 'MapTest' 'Round-trip result: ' + $Output;
END;
/

-- ============================================================================
-- END OF IMPORT/EXPORT MAPPING EXAMPLES
-- ============================================================================
