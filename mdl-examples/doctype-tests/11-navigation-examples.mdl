-- ============================================================================
-- Navigation Examples
-- ============================================================================
--
-- These commands inspect and modify the project's navigation structure:
-- profiles, home pages, menu items, and role-based routing.
--
-- ============================================================================

-- MARK: Setup

-- ============================================================================
-- Setup: Create a module and page so this example is self-contained
-- ============================================================================

create module NavTest;

create page NavTest.NavTest_Home
(
  title: 'Navigation Test Home',
  layout: Atlas_Core.Atlas_Default
)
{
  container ctnMain {
    dynamictext txtWelcome (content: 'Welcome to the Navigation Test page.')
  }
}

-- MARK: Show Commands

-- ============================================================================
-- SHOW NAVIGATION — summary of all profiles
-- ============================================================================

show navigation;

-- ============================================================================
-- DESCRIBE NAVIGATION — full detail for a specific profile
-- ============================================================================

describe navigation Responsive;

-- ============================================================================
-- SHOW NAVIGATION MENU — menu tree for a specific profile
-- ============================================================================

show navigation menu Responsive;

-- ============================================================================
-- SHOW NAVIGATION MENU (all) — menu tree for all profiles
-- ============================================================================

show navigation menu;

-- ============================================================================
-- SHOW NAVIGATION HOMES — home page assignments across all profiles and roles
-- ============================================================================

show navigation homes;

-- MARK: CREATE OR REPLACE NAVIGATION

-- ============================================================================
-- CREATE OR REPLACE NAVIGATION — full replacement of a navigation profile
-- Sets home page, login page, and menu tree in one statement.
-- Output from DESCRIBE NAVIGATION can be pasted back directly.
-- ============================================================================

-- Set the home page and login page for Responsive profile
create or replace navigation Responsive
  home page NavTest.NavTest_Home
  login page Administration.login;

-- Set home page with a role-based override
create or replace navigation Responsive
  home page NavTest.NavTest_Home
  home page NavTest.NavTest_Home for Administration.Administrator
  login page Administration.login;

-- Replace the entire menu tree
create or replace navigation Responsive
  home page NavTest.NavTest_Home
  login page Administration.login
  menu (
    menu item 'Home' page NavTest.NavTest_Home;
    menu 'Admin' (
      menu item 'Users' page Administration.Account_Overview;
    );
  );

-- Clear the menu (empty MENU block removes all items)
create or replace navigation Responsive
  home page NavTest.NavTest_Home
  menu ();

-- Verify the changes
describe navigation Responsive;

-- MARK: Catalog Queries

-- ============================================================================
-- Navigation refs in the catalog
-- After REFRESH CATALOG FULL, navigation references appear in the refs table
-- with kinds: home_page, menu_item, login_page
-- ============================================================================

refresh catalog full;

-- Find all pages that are navigation entry points
select SourceName, TargetName, RefKind
from catalog.REFS
where RefKind in ('home_page', 'menu_item', 'login_page');

-- ============================================================================
-- Impact & context analysis on the page we created
-- ============================================================================

show impact of NavTest.NavTest_Home;

show context of NavTest.NavTest_Home;

/**
 * Responsive navigation
 */
create or replace navigation Responsive
  home page MyFirstModule.Home_Web
  menu (
    menu item 'Home' page MyFirstModule.Home_Web;
  )
;
