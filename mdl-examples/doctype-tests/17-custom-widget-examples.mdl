-- @version: 11.0+
-- ============================================================================
-- Custom Widget Examples - GALLERY, COMBOBOX & IMAGE
-- ============================================================================
--
-- Tests for pluggable widget MDL syntax (GALLERY, COMBOBOX, IMAGE).
--
-- Test matrix:
--   1. GALLERY basic       — DATABASE datasource + TEMPLATE (PASS)
--   2. GALLERY with FILTER — TEXTFILTER in FILTER block    (KNOWN BUG: CE0463)
--   3. COMBOBOX enum       — Enum attribute                (KNOWN BUG: CE1613)
--   4. COMBOBOX association — DataSource + CaptionAttribute (FIXED: Issue #21)
--   5. IMAGE basic         — Default pluggable Image widget
--   6. IMAGE dimensions    — Custom pixel dimensions + alt text
--   7. IMAGE with OnClick  — Action binding on click
--
-- Known engine bugs (do not affect MDL syntax correctness):
--   - CE0463 on TEXTFILTER: embedded template property count mismatch
--   - CE1613 on COMBOBOX enum: enum attribute written as association pointer (pending)
--
-- ============================================================================

-- MARK: Setup

-- ============================================================================
-- Module & Domain Model
-- ============================================================================

CREATE MODULE CWTest;

CREATE ENUMERATION CWTest.Priority (
  LOW 'Low',
  MEDIUM 'Medium',
  HIGH 'High',
  CRITICAL 'Critical'
);
/

@Position(100,300)
CREATE PERSISTENT ENTITY CWTest.Category (
  Name: String(200) NOT NULL,
  Description: String(500)
);

@Position(300,300)
CREATE PERSISTENT ENTITY CWTest.Task (
  Title: String(200) NOT NULL,
  Description: String(1000),
  Priority: Enumeration(CWTest.Priority),
  DueDate: DateTime,
  IsCompleted: Boolean DEFAULT false
);

CREATE ASSOCIATION CWTest.Task_Category
FROM CWTest.Task TO CWTest.Category
TYPE Reference
OWNER Both;

-- MARK: GALLERY basic (PASS)

-- ============================================================================
-- Test 1: GALLERY basic — DATABASE datasource + TEMPLATE with DYNAMICTEXT
-- Result: PASS (0 errors)
-- ============================================================================

/**
 * Basic Gallery showing Task cards with title and description.
 * Validates: GALLERY widget, DATABASE datasource, TEMPLATE with DYNAMICTEXT.
 */
CREATE PAGE CWTest.P_Gallery_Basic
(
  Title: 'Gallery Basic',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'CustomWidgets'
)
{
  LAYOUTGRID lgMain {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        GALLERY galTasks (
          DataSource: DATABASE CWTest.Task SORT BY Title ASC
        ) {
          TEMPLATE tpl1 {
            DYNAMICTEXT dtTitle (Content: '{1}', ContentParams: [{1} = Title], RenderMode: H4)
            DYNAMICTEXT dtDesc (Content: '{1}', ContentParams: [{1} = Description])
          }
        }
      }
    }
  }
}

-- MARK: GALLERY with FILTER (KNOWN BUG: CE0463)

-- ============================================================================
-- Test 2: GALLERY with FILTER — TEXTFILTER in FILTER block
-- Result: CE0463 on TextFilter (template property count mismatch)
-- ============================================================================

/**
 * Gallery with filter bar for text search.
 * KNOWN BUG: CE0463 on TEXTFILTER due to embedded template mismatch.
 * The MDL syntax is correct; the engine template needs re-extraction.
 */
CREATE PAGE CWTest.P_Gallery_Filtered
(
  Title: 'Gallery with Filter',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'CustomWidgets'
)
{
  LAYOUTGRID lgMain {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        GALLERY galFiltered (
          DataSource: DATABASE CWTest.Task SORT BY DueDate DESC
        ) {
          TEMPLATE tpl1 {
            DYNAMICTEXT dtTitle (Content: '{1}', ContentParams: [{1} = Title], RenderMode: H4)
            DYNAMICTEXT dtPriority (Content: 'Priority: {1}', ContentParams: [{1} = Priority])
          }
          FILTER flt1 {
            TEXTFILTER tfSearch (Attribute: Title)
          }
        }
      }
    }
  }
}

-- MARK: COMBOBOX enum (KNOWN BUG: CE1613)

-- ============================================================================
-- Test 3: COMBOBOX enum mode — Attribute bound to an enumeration
-- Result: CE1613 (association pointer written instead of attribute reference)
-- ============================================================================

/**
 * Task edit form with a COMBOBOX selecting the Priority enumeration.
 * KNOWN BUG: CE1613 — engine writes enum attribute as association.
 *
 * @param $Task The task to edit
 */
CREATE PAGE CWTest.P_ComboBox_Enum
(
  Params: {
    $Task: CWTest.Task
  },
  Title: 'ComboBox Enum',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'CustomWidgets'
)
{
  DATAVIEW dvTask (DataSource: $Task) {
    LAYOUTGRID lg1 {
      ROW row1 {
        COLUMN col1 (DesktopWidth: 12) {
          TEXTBOX txtTitle (Label: 'Title', Attribute: Title)
          COMBOBOX cmbPriority (Label: 'Priority', Attribute: Priority)
          DATEPICKER dpDue (Label: 'Due Date', Attribute: DueDate)
        }
      }
    }
    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

-- MARK: COMBOBOX association (KNOWN BUG: CE1613)

-- ============================================================================
-- Test 4: COMBOBOX association mode — DataSource + CaptionAttribute
-- Result: FIXED (Issue #21) — Attribute now correctly reads back as association name
-- ============================================================================

/**
 * Task edit form with a COMBOBOX for selecting Category via association.
 * FIXED (Issue #21): Attribute now correctly roundtrips as association name.
 *
 * @param $Task The task to edit
 */
CREATE PAGE CWTest.P_ComboBox_Assoc
(
  Params: {
    $Task: CWTest.Task
  },
  Title: 'ComboBox Association',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'CustomWidgets'
)
{
  DATAVIEW dvTask (DataSource: $Task) {
    LAYOUTGRID lg1 {
      ROW row1 {
        COLUMN col1 (DesktopWidth: 12) {
          TEXTBOX txtTitle (Label: 'Title', Attribute: Title)
          COMBOBOX cmbCategory (
            Label: 'Category',
            Attribute: Task_Category,
            DataSource: DATABASE CWTest.Category,
            CaptionAttribute: Name
          )
        }
      }
    }
    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

-- MARK: IMAGE basic

-- ============================================================================
-- Test 5: IMAGE basic — Default pluggable Image widget
-- Result: Pending validation
-- ============================================================================

/**
 * Page with a basic pluggable Image widget using default settings.
 * The IMAGE keyword creates a com.mendix.widget.web.image.Image widget.
 */
CREATE PAGE CWTest.P_Image_Basic
(
  Title: 'Image Basic',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'CustomWidgets'
)
{
  LAYOUTGRID lgMain {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        IMAGE imgLogo
      }
    }
  }
}

-- MARK: IMAGE with dimensions

-- ============================================================================
-- Test 6: IMAGE with custom dimensions
-- Result: Pending validation
-- ============================================================================

/**
 * Page with an Image widget with custom pixel dimensions.
 * Note: ImageUrl mode (imageUrl TextTemplate) is not yet supported —
 * the template's imageUrl property is null and cannot be created from
 * scratch without triggering CE0463.
 */
CREATE PAGE CWTest.P_Image_Dimensions
(
  Title: 'Image Dimensions',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'CustomWidgets'
)
{
  LAYOUTGRID lgMain {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        IMAGE imgBanner (
          AlternativeText: 'Company banner',
          WidthUnit: pixels,
          Width: 800,
          HeightUnit: pixels,
          Height: 200,
          Responsive: false
        )
      }
    }
  }
}

-- MARK: IMAGE with OnClick

-- ============================================================================
-- Test 7: IMAGE with OnClick — Action binding on click
-- Result: Pending validation
-- ============================================================================

/**
 * Page with an Image widget that navigates to a detail page on click.
 * Tests the action operation in the pluggable engine.
 *
 * @param $Task The task whose image to display
 */
CREATE PAGE CWTest.P_Image_OnClick
(
  Params: {
    $Task: CWTest.Task
  },
  Title: 'Image with OnClick',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'CustomWidgets'
)
{
  DATAVIEW dvTask (DataSource: $Task) {
    LAYOUTGRID lgMain {
      ROW row1 {
        COLUMN col1 (DesktopWidth: 6) {
          IMAGE imgTask (
            AlternativeText: 'Task image',
            DisplayAs: thumbnail,
            WidthUnit: pixels,
            Width: 300
          )
        }
        COLUMN col2 (DesktopWidth: 6) {
          DYNAMICTEXT dtTitle (Content: '{1}', ContentParams: [{1} = Title], RenderMode: H3)
          DYNAMICTEXT dtDesc (Content: '{1}', ContentParams: [{1} = Description])
        }
      }
    }
  }
}
