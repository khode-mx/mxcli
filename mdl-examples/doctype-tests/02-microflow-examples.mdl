/**
 * Example 11.1: COUNT - Count elements in list
 *
 * Returns the number of elements.
 */
create microflow MfTest.M051_AggregateCount (
  $ProductList: list of MfTest.Product
)
returns integer as $ProductCount
begin
  $ProductCount = count($ProductList);
  return $ProductCount;
end;
/

/**
 * Example 11.2: SUM - Sum attribute values
 *
 * Returns the sum of an attribute across all elements.
 */
create microflow MfTest.M052_AggregateSum (
  $ProductList: list of MfTest.Product
)
returns decimal as $TotalPrice
begin
  $TotalPrice = sum($ProductList.Price);
  return $TotalPrice;
end;
/

/**
 * Example 11.3: AVERAGE - Calculate average
 *
 * Returns the average of an attribute.
 */
create microflow MfTest.M053_AggregateAverage (
  $ProductList: list of MfTest.Product
)
returns decimal as $AveragePrice
begin
  $AveragePrice = average($ProductList.Price);
  return $AveragePrice;
end;
/

/**
 * Example 11.4: MINIMUM - Find minimum value
 *
 * Returns the minimum value of an attribute.
 */
create microflow MfTest.M054_AggregateMinimum (
  $ProductList: list of MfTest.Product
)
returns decimal as $MinPrice
begin
  $MinPrice = minimum($ProductList.Price);
  return $MinPrice;
end;
/

/**
 * Example 11.5: MAXIMUM - Find maximum value
 *
 * Returns the maximum value of an attribute.
 */
create microflow MfTest.M055_AggregateMaximum (
  $ProductList: list of MfTest.Product
)
returns decimal as $MaxPrice
begin
  $MaxPrice = maximum($ProductList.Price);
  return $MaxPrice;
end;
/

/**
 * Example 11.6: Combined list operations
 *
 * Demonstrates chaining multiple list operations.
 */
create microflow MfTest.M056_CombinedListOps (
  $ProductList: list of MfTest.Product
)
returns decimal as $AverageActivePrice
begin
  -- Filter to active products
  $ActiveProducts = filter($ProductList, $currentObject/IsActive = true);

  -- Sort by price
  $SortedProducts = sort($ActiveProducts, Price desc);

  -- Get count and average
  $count = count($SortedProducts);
  $AverageActivePrice = average($SortedProducts.Price);

  log info node 'ListOps' 'Processed ' + toString($count) + ' active products';

  return $AverageActivePrice;
end;
/

/**
 * Example 11.7: CREATE LIST - Create empty list
 *
 * Creates an empty list of a specific entity type.
 */
create microflow MfTest.M057_CreateList ()
returns list of MfTest.Product as $EmptyList
begin
  $EmptyList = create list of MfTest.Product;
  return $EmptyList;
end;
/

/**
 * Example 11.8: List with ADD operation
 *
 * Demonstrates adding elements to a list.
 */
create microflow MfTest.M058_ListAdd (
  $ProductList: list of MfTest.Product,
  $NewProduct: MfTest.Product
)
returns list of MfTest.Product as $UpdatedList
begin
  $UpdatedList = create list of MfTest.Product;
  add $ProductList to $UpdatedList;
  add $NewProduct to $UpdatedList;
  return $UpdatedList;
end;
/

/**
 * Example 11.9: List with REMOVE operation
 *
 * Demonstrates removing elements from a list.
 */

create microflow MfTest.M059_ListRemove (
  $ProductList: list of MfTest.Product,
  $ProductToRemove: MfTest.Product
)
returns list of MfTest.Product as $UpdatedList
begin
  $UpdatedList = create list of MfTest.Product;
  add $ProductList to $UpdatedList;
  remove $ProductToRemove from $UpdatedList;
  return $UpdatedList;
end;
/

-- ============================================================================
-- LEVEL 12: Validation
-- ============================================================================
--
-- Validation feedback shows messages next to specific entity attributes.
-- Useful for form validation in page-triggered microflows.

/**
 * Example 12.1: Basic validation feedback
 *
 * Validates a Product entity and shows feedback on specific attributes.
 */
create microflow MfTest.M060_ValidateProduct (
  $Product: MfTest.Product
)
returns boolean as $IsValid
begin
  -- SET $IsValid = true;
  declare $IsValid boolean = true;

  if $Product/Code = empty then
    validation feedback $Product/Code message 'Product code is required';
    set $IsValid = false;
  end if;

  if $Product/Name = empty then
    validation feedback $Product/Name message 'Product name is required';
    set $IsValid = false;
  end if;

  return $IsValid;
end;
/

/**
 * Example 12.2: Validation with business rules
 *
 * More complex validation including business logic checks.
 */
create microflow MfTest.M061_ValidateProductPrice (
  $Product: MfTest.Product
)
returns boolean as $IsValid
begin
  declare $IsValid boolean = true;

  if $Product/Price < 0 then
    validation feedback $Product/Price message 'Price cannot be negative';
    set $IsValid = false;
  end if;

  if $Product/Price = 0 and $Product/IsActive = true then
    validation feedback $Product/Price message 'Active products must have a price greater than zero';
    set $IsValid = false;
  end if;

  return $IsValid;
end;
/

-- MARK: ERROR HANDLING

-- ============================================================================
-- LEVEL 13: Error Handling
-- ============================================================================
--
-- Error handling controls what happens when an activity fails.
-- Options:
--   - ON ERROR CONTINUE - Ignore error and continue execution
--   - ON ERROR ROLLBACK - Rollback transaction and abort
--   - ON ERROR { ... } - Execute custom error handler statements
--   - ON ERROR WITHOUT ROLLBACK { ... } - Custom handler without rollback

/**
 * Example 13.1: Continue on error
 *
 * If the microflow call fails, execution continues without error.
 * Useful for non-critical operations like logging or notifications.
 */
create microflow MfTest.M062_ErrorContinue (
  $ProductCode: string
)
returns boolean as $success
begin
  declare $success boolean = false;

  -- Try to find and process the product
  retrieve $Product from MfTest.Product
    where Code = $ProductCode
    limit 1;

  if $Product != empty then
    -- This call will continue even if the submicroflow fails
    call microflow MfTest.M013_SaveEntity(Product = $Product) on error continue;
    log info node 'ErrorHandling' 'Attempted to save product';
  end if;

  set $success = true;
  return $success;
end;
/

/**
 * Example 13.2: Rollback on error
 *
 * If the operation fails, rollback all changes in the current transaction.
 * Use for operations where partial changes would be inconsistent.
 */
create microflow MfTest.M063_ErrorRollback (
  $Order: MfTest.Order,
  $NewStatus: string
)
returns boolean as $success
begin
  declare $success boolean = false;

  -- Update order status - rollback all changes if commit fails
  change $Order (status = $NewStatus);
  commit $Order with events on error rollback;

  set $success = true;
  return $success;
end;
/

/**
 * Example 13.3: Custom error handler without rollback
 *
 * Execute custom logic when an error occurs, without rolling back.
 * The error handler block contains statements to execute on failure.
 */
create microflow MfTest.M064_ErrorCustomHandler (
  $ProductCode: string
)
returns MfTest.Product as $Result
begin
  -- Try to find the product
  retrieve $Product from MfTest.Product
    where Code = $ProductCode
    limit 1;

  if $Product != empty then
    -- Call external service with custom error handling
    $Result = call microflow MfTest.M012_CreateEntity(
      Name = $Product/Name,
      Code = $ProductCode
    ) on error without rollback {
      log error node 'ErrorHandling' 'Failed to create entity for: ' + $ProductCode;
      return empty;
    };
    return $Result;
  else
    return $Product;
  end if;
end;
/

/**
 * Example 13.4: Error handling in loops
 *
 * Continue processing remaining items even if one fails.
 */
create microflow MfTest.M065_ErrorInLoop (
  $ProductList: list of MfTest.Product
)
returns integer as $ProcessedCount
begin
  declare $ProcessedCount integer = 0;
  declare $ErrorCount integer = 0;

  loop $Product in $ProductList
  begin
    -- Try to save each product, continue if one fails
    commit $Product on error rollback;
    set $ProcessedCount = $ProcessedCount + 1;
  end loop;

  log info node 'BatchProcess' 'Processed: ' + toString($ProcessedCount) + ' products';
  return $ProcessedCount;
end;
/

/**
 * Example 13.5: Nested error handling with logging
 *
 * Multiple activities with different error handling strategies.
 */
create microflow MfTest.M066_NestedErrorHandling (
  $Order: MfTest.Order
)
returns boolean as $success
begin
  declare $success boolean = false;

  -- Step 1: Validate order (continue on error)
  call microflow MfTest.M029_ProcessOrder(
    OrderNumber = $Order/OrderNumber
  ) on error continue;

  -- Step 2: Update status with custom error handler
  change $Order (status = 'VALIDATED');
  commit $Order on error without rollback {
    log error node 'OrderService' 'Failed to update order status';
    change $Order (status = 'ERROR');
    commit $Order;
    raise error
  };

  set $success = true;
  return $success;
end;
/

/**
 * Example 13.6: Error handling with explicit RAISE ERROR
 *
 * Uses RAISE ERROR to terminate the error path with an ErrorEvent
 * instead of merging back to the main flow.
 */
create microflow MfTest.M067_ErrorWithRaise (
  $Order: MfTest.Order
)
returns boolean as $success
begin
  declare $success boolean = false;

  -- Commit with error handler that raises an error
  commit $Order on error without rollback {
    log error node 'OrderService' 'Failed to commit order - raising error';
    raise error;  -- Terminates with ErrorEvent
  };

  -- This only executes if commit succeeds
  set $success = true;
  return $success;
end;
/

-- MARK: REST CALLS

-- ============================================================================
-- LEVEL 14: REST Calls (PROPOSED - NOT YET IMPLEMENTED)
-- ============================================================================
--
-- REST call action allows calling external HTTP APIs from microflows.
-- This section documents the proposed MDL syntax based on the BSON structure
-- of RestTemplate.GetWebpage microflow in the test project.
--
-- BSON Structure Analysis (from RestTemplate.GetWebpage):
-- - $Type: Microflows$RestCallAction
-- - HttpConfiguration: method, URL template, headers, auth
-- - RequestHandling: body content (for POST/PUT/PATCH)
-- - ResultHandling: how to process response (String, Mapping, File, None)
-- - TimeoutExpression: timeout in seconds
-- - ErrorHandlingType: Rollback, Continue, Custom

/**
 * Example 14.1: Simple GET request returning string
 *
 * Fetches a webpage and returns the HTML content as a string.
 * Based on RestTemplate.GetWebpage from test project.
 *
 * Proposed MDL syntax for REST calls:
 *   $Variable = REST CALL <METHOD> <URL>
 *       [HEADER <name> = <expression>, ...]
 *       [BODY <template> | BODY MAPPING <MappingName> FROM <Variable>]
 *       [TIMEOUT <expression>]
 *       RETURNS <ResultType>
 *       [ON ERROR <error_handling>];
 *
 * Result types:
 *   - String          : Returns response body as string
 *   - HttpResponse    : Returns System.HttpResponse object
 *   - MAPPING <Name> AS <Entity> : Uses import mapping
 *   - FILE <FileEntity>: Stores response as file document
 *   - Nothing         : Ignores response
 */
create microflow MfTest.M067_RestGetWebpage ()
returns string as $PageContent
begin
  -- Fetch a webpage using HTTP GET
  -- The URL is a string template with parameters using {1}, {2}, etc.
  $PageContent = rest call get 'http://news.ycombinator.com'
    header Accept = 'text/html'
    timeout 300
    returns string;

  return $PageContent;
end;
/

/**
 * Example 14.2: GET request with URL parameters
 *
 * Demonstrates URL template with parameter substitution.
 */
create microflow MfTest.M068_RestGetWithParams (
  $SearchTerm: string,
  $page: integer
)
returns string as $response
begin
  -- URL template with {1} and {2} placeholders
  $response = rest call get 'https://api.example.com/search?q={1}&page={2}' with (
    {1} = urlEncode($SearchTerm),
    {2} = toString($page)
  )
    header Accept = 'application/json'
    timeout 60
    returns string;

  return $response;
end;
/

/**
 * Example 14.3: POST request with JSON body
 *
 * Sends data to an API using POST method.
 */
create microflow MfTest.M069_RestPostJson (
  $CustomerName: string,
  $Email: string
)
returns string as $response
begin
  -- POST with custom JSON body template
  $response = rest call post 'https://api.example.com/customers'
    header 'Content-Type' = 'application/json'
    header Accept = 'application/json'
    body '{{"name": "{1}", "email": "{2}"}' with (
      {1} = $CustomerName,
      {2} = $Email
    )
    timeout 30
    returns string
    on error rollback;

  return $response;
end;
/

-- TODO: Examples with import/export mappings (not yet supported)
-- Example 14.4: POST with export mapping
-- CREATE MICROFLOW MfTest.M070_RestPostMapping ($Product: MfTest.Product)
--   BODY MAPPING MfTest.ExportProduct FROM $Product
--
-- Example 14.5: GET with import mapping
-- CREATE MICROFLOW MfTest.M071_RestGetMapping ()
--   RETURNS MAPPING MfTest.ImportProduct AS MfTest.Product

/**
 * Example 14.6: REST call with authentication
 *
 * Demonstrates basic HTTP authentication.
 */
create microflow MfTest.M072_RestWithAuth (
  $username: string,
  $password: string
)
returns string as $response
begin
  -- REST call with basic authentication
  $response = rest call get 'https://api.example.com/secure/data'
    header Accept = 'application/json'
    auth basic $username password $password
    timeout 30
    returns string;

  return $response;
end;
/

/**
 * Example 14.7: REST call with error handling
 *
 * Demonstrates custom error handling for REST calls.
 */
create microflow MfTest.M073_RestWithErrorHandling (
  $url: string
)
returns boolean as $success
begin
  declare $success boolean = false;

  -- REST call with custom error handler
  $response = rest call get $url
    header Accept = 'application/json'
    timeout 30
    returns string
    on error without rollback {
      log error node 'RestService' 'Failed to fetch: ' + $url;
      return false;
    };

  set $success = true;
  return $success;
end;
/

/**
 * Example 14.8: PUT request to update resource
 *
 * Updates an existing resource using PUT method.
 */
create microflow MfTest.M074_RestPutUpdate (
  $ProductId: integer,
  $NewPrice: decimal
)
returns boolean as $success
begin
  declare $success boolean = false;

  $response = rest call put 'https://api.example.com/products/{1}' with (
    {1} = toString($ProductId)
  )
    header 'Content-Type' = 'application/json'
    body '{{"price": {1}}' with ({1} = toString($NewPrice))
    timeout 30
    returns string
    on error continue;

  set $success = true;
  return $success;
end;
/

/**
 * Example 14.9: DELETE request
 *
 * Deletes a resource using DELETE method.
 */
create microflow MfTest.M075_RestDelete (
  $ResourceId: string
)
returns boolean as $Deleted
begin
  declare $Deleted boolean = false;

  -- DELETE request - typically returns nothing
  rest call delete 'https://api.example.com/resources/{1}' with (
    {1} = $ResourceId
  )
    header Accept = 'application/json'
    timeout 30
    returns nothing
    on error continue;

  set $Deleted = true;
  return $Deleted;
end;
/

-- MARK: MOVE

-- ============================================================================
-- LEVEL 15: MOVE - Organizing Elements into Folders and Modules
-- ============================================================================
--
-- MOVE relocates microflows, pages, snippets, nanoflows, enumerations, and
-- entities to folders or other modules. Folders are created automatically
-- if they don't exist. Nested folders use '/' separators.
--
-- WARNING: Moving across modules changes the qualified name. Any by-name
-- references (microflow calls, page navigation, etc.) will break.
-- Use `SHOW IMPACT OF Module.Element` before cross-module moves.

-- Example 15.1: Move microflows to folders within the same module
move microflow MfTest.M001_HelloWorld to folder 'Basic';
move microflow MfTest.M001_HelloWorld_1 to folder 'Basic';
move microflow MfTest.M001_HelloWorld_2 to folder 'Basic';
move microflow MfTest.M002_BasicVariables to folder 'Basic';
move microflow MfTest.M003_StringOperations to folder 'Basic';
move microflow MfTest.M004_BooleanLogic to folder 'Basic';

-- Example 15.2: Move to nested folders (auto-created)
move microflow MfTest.M005_1_LogParameter to folder 'Basic/Logging';
move microflow MfTest.M005_2_LogParameter to folder 'Basic/Logging';
move microflow MfTest.M005_3_LogParameter to folder 'Basic/Logging';
move microflow MfTest.M009_Logging to folder 'Basic/Logging';
move microflow MfTest.M009_2_LogWithTemplate to folder 'Basic/Logging';

-- Example 15.3: Organize by feature area
move microflow MfTest.M006_SimpleIf to folder 'ControlFlow';
move microflow MfTest.M007_IfElse to folder 'ControlFlow';
move microflow MfTest.M008_NestedIf to folder 'ControlFlow';

move microflow MfTest.M021_SimpleLoop to folder 'ControlFlow/Loops';
move microflow MfTest.M022_LoopWithChange to folder 'ControlFlow/Loops';
move microflow MfTest.M023_LoopWithCondition to folder 'ControlFlow/Loops';
move microflow MfTest.M024_NestedLoops to folder 'ControlFlow/Loops';
move microflow MfTest.M024_2_DeclareInLoop to folder 'ControlFlow/Loops';

-- Example 15.4: Move object operation microflows
move microflow MfTest.M012_CreateEntity to folder 'ObjectOps';
move microflow MfTest.M013_SaveEntity to folder 'ObjectOps';
move microflow MfTest.M014_SaveEntityWithEvents to folder 'ObjectOps';
move microflow MfTest.M015_UpdateEntity to folder 'ObjectOps';
move microflow MfTest.M015_2_CreateUpdateEntity to folder 'ObjectOps';

-- Example 15.5: Move retrieval microflows
move microflow MfTest.M025_SimpleRetrieve to folder 'Retrieve';
move microflow MfTest.M026_RetrieveWithWhere to folder 'Retrieve';
move microflow MfTest.M027_RetrieveMultipleConditions to folder 'Retrieve';
move microflow MfTest.M027_2_RetrieveMultipleConditions to folder 'Retrieve';
move microflow MfTest.M028_RetrieveSingleObject to folder 'Retrieve';
move microflow MfTest.M028_DataForm_Getter_2 to folder 'Retrieve';

-- Example 15.6: Move list operations to deep nested folder
move microflow MfTest.M040_ListHead to folder 'ListOps/Basic';
move microflow MfTest.M041_ListTail to folder 'ListOps/Basic';
move microflow MfTest.M042_ListFind to folder 'ListOps/Search';
move microflow MfTest.M043_ListFilter to folder 'ListOps/Search';
move microflow MfTest.M044_ListSort to folder 'ListOps/Sort';
move microflow MfTest.M045_ListSortMultiple to folder 'ListOps/Sort';
move microflow MfTest.M046_ListUnion to folder 'ListOps/SetOps';
move microflow MfTest.M047_ListIntersect to folder 'ListOps/SetOps';
move microflow MfTest.M048_ListSubtract to folder 'ListOps/SetOps';
move microflow MfTest.M049_ListContains to folder 'ListOps/SetOps';
move microflow MfTest.M050_ListEquals to folder 'ListOps/SetOps';

-- Example 15.7: Move aggregates
move microflow MfTest.M051_AggregateCount to folder 'ListOps/Aggregates';
move microflow MfTest.M052_AggregateSum to folder 'ListOps/Aggregates';
move microflow MfTest.M053_AggregateAverage to folder 'ListOps/Aggregates';
move microflow MfTest.M054_AggregateMinimum to folder 'ListOps/Aggregates';
move microflow MfTest.M055_AggregateMaximum to folder 'ListOps/Aggregates';
move microflow MfTest.M056_CombinedListOps to folder 'ListOps/Aggregates';

-- Example 15.8: Move validation microflows
move microflow MfTest.M060_ValidateProduct to folder 'Validation';
move microflow MfTest.M061_ValidateProductPrice to folder 'Validation';

-- Example 15.9: Move error handling microflows
move microflow MfTest.M062_ErrorContinue to folder 'ErrorHandling';
move microflow MfTest.M063_ErrorRollback to folder 'ErrorHandling';
move microflow MfTest.M064_ErrorCustomHandler to folder 'ErrorHandling';
move microflow MfTest.M065_ErrorInLoop to folder 'ErrorHandling';
move microflow MfTest.M066_NestedErrorHandling to folder 'ErrorHandling';
move microflow MfTest.M067_ErrorWithRaise to folder 'ErrorHandling';

-- Example 15.10: Move enumerations to folders
-- (First create an enumeration so we can move it)
create enumeration MfTest.OrderStatus (
  Pending 'Pending',
  Processing 'Processing',
  Completed 'Completed',
  Cancelled 'Cancelled'
);
move enumeration MfTest.OrderStatus to folder 'Shared';

-- Example 15.11: Cross-module move
-- WARNING: Moving across modules changes the qualified name (MfTest.X → MfTest2.X).
-- Any by-name references (microflow calls, page navigation, etc.) will break.
-- Use `SHOW IMPACT OF Module.Element` before cross-module moves.

-- Create target module
create module MfTest2;

-- Create microflows specifically for cross-module move demos
create microflow MfTest.M076_CrossModuleDemo ()
returns boolean as $success
begin
  declare $success boolean = true;
  log info node 'CrossModule' 'This microflow will be moved to MfTest2';
  return $success;
end;
/

create microflow MfTest.M077_CrossModuleFolderDemo ()
returns boolean as $Done
begin
  declare $Done boolean = true;
  log info node 'CrossModule' 'This microflow will be moved to a folder in MfTest2';
  return $Done;
end;
/

-- Move microflow to another module (root)
move microflow MfTest.M076_CrossModuleDemo to MfTest2;

-- Move microflow to a folder in another module
move microflow MfTest.M077_CrossModuleFolderDemo to folder 'Imported' in MfTest2;

show microflows;
show microflows in MfTest;
show microflows in MfTest2;

-- MARK: ENUM RETURN TYPES

-- ============================================================================
-- LEVEL 16: Enumeration Return Types and Parameters
-- ============================================================================
--
-- Microflows can return enumerations and accept them as parameters.
-- Use ENUM Module.EnumName or Enumeration(Module.EnumName) syntax.

/**
 * Example 16.1: Microflow returning an enumeration
 *
 * Demonstrates ENUM return type with ENUM keyword syntax.
 */
create microflow MfTest.M092_GetDefaultCountry ()
returns enum MfTest.Country as $DefaultCountry
begin
  declare $DefaultCountry enum MfTest.Country = empty;
  set $DefaultCountry = MfTest.Country.NL;
  return $DefaultCountry;
end;
/

/**
 * Example 16.2: Microflow with enumeration parameter
 *
 * Accepts an enumeration parameter and returns a string.
 */
create microflow MfTest.M093_GetCountryLabel (
  $Country: enum MfTest.Country
)
returns string as $label
begin
  declare $label string = 'Unknown';

  if $Country = MfTest.Country.US then
    set $label = 'United States';
  else
    if $Country = MfTest.Country.NL then
      set $label = 'Netherlands';
    end if;
  end if;

  return $label;
end;
/

/**
 * Example 16.3: Enumeration parameter with alternative syntax
 *
 * Uses Enumeration(Module.EnumName) syntax instead of ENUM keyword.
 */
create microflow MfTest.M094_IsEuropean (
  $Country: enumeration(MfTest.Country)
)
returns boolean as $IsEU
begin
  declare $IsEU boolean = false;
  if $Country = MfTest.Country.NL or $Country = MfTest.Country.DE or $Country = MfTest.Country.FR then
    set $IsEU = true;
  end if;
  return $IsEU;
end;
/

-- MARK: ANNOTATIONS

-- ============================================================================
-- Annotations (@annotation, @position, @caption, @color)
-- ============================================================================
--
-- Activity annotations use @ prefix syntax placed before the activity:
--   @position(x, y)    - canvas position (always present in DESCRIBE output)
--   @caption 'text'    - custom caption (only when auto-generate is off)
--   @color Color        - background color (only when not Default)
--   @annotation 'text' - visual note attached to the activity
--
-- Multiple annotations can be stacked before a single activity.
-- @annotation without a following activity creates a free-floating note.
--

/**
 * M078: Annotation attached to an activity.
 */
create microflow MfTest.M078_AnnotationAttached ()
begin
  @annotation 'Log a welcome message to the console'
  log info node 'App' 'Hello from annotated microflow';
  return;
end;
/

/**
 * M079: Multiple annotations on different activities.
 */
create microflow MfTest.M079_MultipleAnnotations ()
returns boolean as $Result
begin
  @annotation 'Step 1: Create the object'
  $Obj = create MfTest.Product (Name = 'Annotated Product', Price = 9.99);
  @annotation 'Step 2: Persist to database'
  commit $Obj;
  declare $Result boolean = true;
  return $Result;
end;
/

/**
 * M080: Free-floating annotation (not attached to any activity).
 */
create microflow MfTest.M080_FreeAnnotation ()
begin
  log info node 'App' 'Working...';
  @annotation 'This is a free-floating note, not attached to any activity'
  return;
end;
/

/**
 * M081: Annotation with special characters (escaped single quotes).
 */
create microflow MfTest.M081_AnnotationEscaping ()
begin
  @annotation 'Don''t forget to validate the user''s input'
  log info node 'App' 'Validated';
  return;
end;
/

create microflow MfTest.M082_ShowMessage_2 ()
begin
  show message 'Hello {1}' type Information objects ['World'];
  show message 'Goodbye {1}' type error objects ['User'];
end;
/

/**
 * M083: Explicit canvas positions on activities.
 * @position(x, y) controls where the activity appears on the canvas.
 */
create microflow MfTest.M083_Position ()
begin
  @position(200, 200)
  $Obj = create MfTest.Product (Name = 'Positioned', Price = 1.00);
  @position(400, 200)
  commit $Obj;
end;
/

/**
 * M084: Custom caption on an activity.
 * @caption overrides the auto-generated caption shown on the canvas.
 */
create microflow MfTest.M084_Caption ()
begin
  @caption 'Create the product'
  $Obj = create MfTest.Product (Name = 'Captioned', Price = 5.00);
  @caption 'Save to database'
  commit $Obj;
end;
/

/**
 * M085: Background color on an activity.
 * @color sets the activity background color (Blue, Green, Red, Yellow, Purple, Gray).
 */
create microflow MfTest.M085_Color ()
begin
  @color Green
  log info node 'App' 'This activity has a green background';
  @color Red
  log error node 'App' 'This activity has a red background';
end;
/

/**
 * M086: Combined annotations on a single activity.
 * Multiple @ annotations can be stacked before one activity.
 */
create microflow MfTest.M086_CombinedAnnotations ()
begin
  @position(200, 200)
  @caption 'Create and persist product'
  @color Blue
  @annotation 'This is the main step of the microflow'
  $Obj = create MfTest.Product (Name = 'Full Annotations', Price = 42.00);
  @position(500, 200)
  commit $Obj;
end;
/

/**
 * M087: Annotations on CLOSE PAGE activity.
 */
create microflow MfTest.M087_AnnotatedClosePage ()
begin
  @position(200, 200)
  @caption 'Done editing'
  @color Green
  close page;
end;
/

/**
 * M088: Annotations on SHOW HOME PAGE activity.
 */
create microflow MfTest.M088_AnnotatedShowHomePage ()
begin
  @position(200, 200)
  @caption 'Go home'
  @color Blue
  @annotation 'Navigate the user back to the home page'
  show home page;
end;
/

/**
 * M089: Annotations on SHOW MESSAGE activity.
 */
create microflow MfTest.M089_AnnotatedShowMessage ()
begin
  @position(200, 200)
  @caption 'Warn the user'
  @color Yellow
  show message 'Please review your data before submitting.' type warning;
  @position(400, 200)
  @color Red
  show message 'Operation failed: {1}' type error objects ['unknown error'];
end;
/

-- @version: 11.0+
/**
 * Helper page for M090 — requires Mendix 11.0+ (page parameters).
 */
create page MfTest.ProductDetail
(
  params: {
    $Product: MfTest.Product
  },
  title: 'Product Detail',
  layout: Atlas_Core.Atlas_Default
)
{
  dynamictext text1 (content: 'Product Detail', rendermode: H4)
}
/

/**
 * M090: Annotations on SHOW PAGE activity.
 * Uses the canonical microflow syntax: $Param = $value
 */
create microflow MfTest.M090_AnnotatedShowPage (
  $Product: MfTest.Product
)
begin
  @position(200, 200)
  @caption 'Open product detail'
  @color Purple
  @annotation 'Shows the product edit page'
  show page MfTest.ProductDetail($Product = $Product);
end;
/

/**
 * M090b: SHOW PAGE using widget-style parameter syntax.
 * Both ($Param = $value) and (Param: $value) are accepted in microflows.
 */
create microflow MfTest.M090b_ShowPageWidgetStyle (
  $Product: MfTest.Product
)
begin
  show page MfTest.ProductDetail(Product: $Product);
end;
/

-- @version: any
/**
 * M091: Annotations on VALIDATION FEEDBACK activity.
 */
create microflow MfTest.M091_AnnotatedValidationFeedback (
  $Product: MfTest.Product
)
returns boolean as $IsValid
begin
  declare $IsValid boolean = true;
  if $Product/Name = empty then
    @position(400, 100)
    @caption 'Name is required'
    @color Red
    validation feedback $Product/Name message 'Product name cannot be empty';
    set $IsValid = false;
  end if;
  if $Product/Price < 0 then
    @position(400, 300)
    @color Red
    @annotation 'Negative prices are not allowed'
    validation feedback $Product/Price message 'Price must be zero or greater';
    set $IsValid = false;
  end if;
  return $IsValid;
end;
/

-- ============================================================================
-- Summary
-- ============================================================================
--
-- This file demonstrates ALL currently supported microflow features:
--
-- ✅ Variables: DECLARE, SET (for primitive variables only)
-- ✅ Control Flow: IF/THEN/ELSE/END IF with nesting
-- ✅ Loops: LOOP...IN (FOR EACH) and WHILE...BEGIN/END WHILE
-- ✅ Logging: LOG INFO/WARNING/ERROR with optional NODE and WITH template params
--            (unified syntax with pages - see STRING_TEMPLATE_SYNTAX.md)
-- ✅ Objects: CREATE, CHANGE, COMMIT (with/without EVENTS)
--    - CREATE: $var = CREATE Entity (attr = value);
--    - CHANGE: CHANGE $var (attr = value);  -- for entity attributes/associations
--    - SET: SET $var = value;  -- for primitive variables only
-- ✅ Queries: RETRIEVE with WHERE conditions
-- ✅ Arithmetic: +, -, *, div, with proper precedence
-- ✅ XPath Navigation: $Var/Attribute (read-only in expressions)
-- ✅ Boolean Logic: AND, OR, NOT, comparisons
-- ✅ Special Values: empty, [%CurrentDateTime%]
-- ✅ Functions: toString(), randomInt()
-- ✅ Submicroflow calls: CALL MICROFLOW with named params (Name = value)
-- ✅ Java action calls: CALL JAVA ACTION with named params (unified syntax)
-- ✅ List Operations:
--    - HEAD($List) - get first element
--    - TAIL($List) - get all but first
--    - FIND($List, expression) - find single element
--    - FILTER($List, expression) - filter by condition
--    - SORT($List, Attribute ASC/DESC) - sort by attribute(s)
--    - UNION($List1, $List2) - combine lists
--    - INTERSECT($List1, $List2) - common elements
--    - SUBTRACT($List1, $List2) - difference
--    - CONTAINS($List, $Object) - check membership
--    - EQUALS($List1, $List2) - compare lists
--    - CREATE LIST OF Entity - create empty list
--    - ADD $Object TO $List - add element
--    - REMOVE $Object FROM $List - remove element
-- ✅ Aggregate Functions:
--    - COUNT($List) - count elements
--    - SUM($List.Attribute) - sum values
--    - AVERAGE($List.Attribute) - calculate average
--    - MINIMUM($List.Attribute) - find minimum
--    - MAXIMUM($List.Attribute) - find maximum
-- ✅ Validation:
--    - VALIDATION FEEDBACK $Object/Attribute MESSAGE 'text' - show validation message
-- ✅ Error Handling:
--    - ON ERROR CONTINUE - ignore error and continue
--    - ON ERROR ROLLBACK - rollback transaction on error
--    - ON ERROR { ... } - execute custom error handler block
--    - ON ERROR WITHOUT ROLLBACK { ... } - custom handler without rollback
-- ✅ Annotations:
--    - @position(x, y) - canvas position of the activity
--    - @caption 'text' - custom caption (overrides auto-generated)
--    - @color Color - background color (Blue, Green, Red, Yellow, Purple, Gray)
--    - @annotation 'text' - attach visual note to the next activity
--    - Multiple annotations can be stacked before a single activity
--    - Free-floating annotations (not followed by an activity)
--    - Single quotes escaped by doubling: 'Don''t forget'
-- ✅ MOVE - Organize elements into folders and across modules:
--    - MOVE MICROFLOW Module.Name TO FOLDER 'path' - move to folder
--    - MOVE MICROFLOW Module.Name TO FOLDER 'a/b/c' - nested folders (auto-created)
--    - MOVE ENUMERATION Module.Name TO FOLDER 'path' - move enum to folder
--    - MOVE MICROFLOW Module.Name TO OtherModule - move to another module (root)
--    - MOVE MICROFLOW Module.Name TO FOLDER 'path' IN OtherModule - cross-module with folder
--    - MOVE ENTITY Module.Name TO OtherModule - move entity across modules
-- ✅ Enumeration Return Types and Parameters:
--    - RETURNS ENUM Module.EnumName AS $Var - enumeration return type
--    - $Param: ENUM Module.EnumName - enumeration parameter
--    - $Param: Enumeration(Module.EnumName) - alternative syntax
-- ⏳ REST Calls (PROPOSED - NOT YET IMPLEMENTED):
--    - REST CALL GET/POST/PUT/PATCH/DELETE <url>
--    - HEADER <name> = <expression> - custom HTTP headers
--    - BODY <template> WITH (...) - custom request body
--    - BODY MAPPING <MappingName> FROM <Variable> - export mapping
--    - AUTH BASIC <user> PASSWORD <pass> - HTTP basic auth
--    - TIMEOUT <expression> - timeout in seconds
--    - RETURNS String | HttpResponse | MAPPING <Name> AS <Entity> | FILE <Entity> | Nothing
--
-- Total: 78 example microflows + MOVE examples showcasing parser capabilities
--
-- ============================================================================
