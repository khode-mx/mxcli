-- MARK: LIST OPS

-- ============================================================================
-- LEVEL 10: List Operations
-- ============================================================================

/**
 * Example 10.1: HEAD - Get first element from list
 *
 * Returns the first element of a list.
 */
create microflow MfTest.M040_ListHead (
  $ProductList: list of MfTest.Product
)
returns MfTest.Product as $FirstProduct
begin
  $FirstProduct = head($ProductList);
  return $FirstProduct;
end;
/

/**
 * Example 10.2: TAIL - Get all but first element
 *
 * Returns a new list without the first element.
 */
create microflow MfTest.M041_ListTail (
  $ProductList: list of MfTest.Product
)
returns list of MfTest.Product as $RemainingProducts
begin
  $RemainingProducts = tail($ProductList);
  return $RemainingProducts;
end;
/

/**
 * Example 10.3: FIND - Find single element by expression
 *
 * Returns the first element matching the expression.
 */
create microflow MfTest.M042_ListFind (
  $ProductList: list of MfTest.Product,
  $SearchCode: string
)
returns MfTest.Product as $FoundProduct
begin
  $FoundProduct = find($ProductList, $currentObject/Code = $SearchCode);
  return $FoundProduct;
end;
/

/**
 * Example 10.4: FILTER - Filter list by expression
 *
 * Returns all elements matching the expression.
 */
create microflow MfTest.M043_ListFilter (
  $ProductList: list of MfTest.Product
)
returns list of MfTest.Product as $ActiveProducts
begin
  $ActiveProducts = filter($ProductList, $currentObject/IsActive = true);
  return $ActiveProducts;
end;
/

/**
 * Example 10.5: SORT - Sort list by attribute
 *
 * Returns a sorted list.
 */
create microflow MfTest.M044_ListSort (
  $ProductList: list of MfTest.Product
)
returns list of MfTest.Product as $SortedProducts
begin
  $SortedProducts = sort($ProductList, Name asc);
  return $SortedProducts;
end;
/

/**
 * Example 10.6: SORT descending with multiple columns
 *
 * Sort by Price descending, then by Name ascending.
 */
create microflow MfTest.M045_ListSortMultiple (
  $ProductList: list of MfTest.Product
)
returns list of MfTest.Product as $SortedProducts
begin
  $SortedProducts = sort($ProductList, Price desc, Name asc);
  return $SortedProducts;
end;
/

/**
 * Example 10.7: UNION - Combine two lists
 *
 * Returns combined list (may contain duplicates).
 */
create microflow MfTest.M046_ListUnion (
  $ProductList1: list of MfTest.Product,
  $ProductList2: list of MfTest.Product
)
returns list of MfTest.Product as $CombinedList
begin
  $CombinedList = union($ProductList1, $ProductList2);
  return $CombinedList;
end;
/

/**
 * Example 10.8: INTERSECT - Common elements
 *
 * Returns elements present in both lists.
 */
create microflow MfTest.M047_ListIntersect (
  $ProductList1: list of MfTest.Product,
  $ProductList2: list of MfTest.Product
)
returns list of MfTest.Product as $CommonProducts
begin
  $CommonProducts = intersect($ProductList1, $ProductList2);
  return $CommonProducts;
end;
/

/**
 * Example 10.9: SUBTRACT - Remove elements
 *
 * Returns elements in first list but not in second.
 */
create microflow MfTest.M048_ListSubtract (
  $ProductList1: list of MfTest.Product,
  $ProductList2: list of MfTest.Product
)
returns list of MfTest.Product as $DifferenceList
begin
  $DifferenceList = subtract($ProductList1, $ProductList2);
  return $DifferenceList;
end;
/

/**
 * Example 10.10: CONTAINS - Check if element in list
 *
 * Returns true if the object is in the list.
 */
create microflow MfTest.M049_ListContains (
  $ProductList: list of MfTest.Product,
  $Product: MfTest.Product
)
returns boolean as $IsInList
begin
  $IsInList = contains($ProductList, $Product);
  return $IsInList;
end;
/

/**
 * Example 10.11: EQUALS - Compare two lists
 *
 * Returns true if both lists contain the same elements.
 */
create microflow MfTest.M050_ListEquals (
  $ProductList1: list of MfTest.Product,
  $ProductList2: list of MfTest.Product
)
returns boolean as $AreEqual
begin
  $AreEqual = equals($ProductList1, $ProductList2);
  return $AreEqual;
end;
/

