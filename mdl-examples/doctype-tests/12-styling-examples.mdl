-- ============================================================================
-- Styling Examples - Classes, Inline Styles, and Design Properties
-- ============================================================================
--
-- This file demonstrates the three styling mechanisms available in MDL V3:
--
-- 1. Class: 'css-class-names'     - CSS classes (Atlas UI or custom)
-- 2. Style: 'inline-css'          - Inline CSS styles
-- 3. DesignProperties: [...]      - Atlas UI design properties (structured)
--
-- Design Properties use key-value pairs:
--   'Key': 'Value'   - Option (dropdown) properties
--   'Key': ON        - Toggle properties (ON = enabled, OFF = disabled/omit)
--
-- These map to Mendix Appearance settings and Atlas UI's design system.
--
-- ============================================================================

-- MARK: Setup

-- ============================================================================
-- Setup: Ensure StyleTest Entities Exist
-- ============================================================================

create module StyleTest;

@position(100,100)
create persistent entity StyleTest.Employee (
  Name: string(200) not null,
  Email: string(200),
  Department: string(100),
  IsActive: boolean default true,
  StartDate: datetime,
  Notes: string(1000),
  Salary: decimal
);

@position(300,100)
create persistent entity StyleTest.task (
  "title": string(200) not null,
  "description": string(500),
  DueDate: datetime,
  IsCompleted: boolean default false,
  Priority: string(50)
);

create association StyleTest.Task_Employee
from StyleTest.task to StyleTest.Employee
type reference
owner both;

-- @version: 11.0+
-- MARK: Class — pages with Params require Mendix 11.0+

-- ============================================================================
-- LEVEL 1: CSS Classes (Class property)
-- ============================================================================

/**
 * CSS classes applied to containers and widgets.
 * Atlas UI provides utility classes for spacing, colors, borders, etc.
 */
create page StyleTest.P001_CSS_Classes
(
  title: 'CSS Classes',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_001_css_classes/{Employee}',
  params: { $Employee: StyleTest.Employee }
)
{
  -- Single CSS class
  container ctnCard (class: 'card') {
    dynamictext txtTitle (content: 'Card Title', rendermode: H3)
    dynamictext txtBody (content: 'Card body content')
  }

  -- Multiple CSS classes (space-separated)
  container ctnSpaced (class: 'card mx-spacing-top-lg mx-spacing-bottom-lg') {
    dynamictext txtSpaced (content: 'Spaced card with margin')
  }

  -- Classes on input widgets
  dataview dvEmployee (datasource: $Employee) {
    textbox txtName (label: 'Name', attribute: Name, class: 'form-control-lg')
    textbox txtEmail (label: 'Email', attribute: Email, class: 'text-muted')

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary, class: 'btn-lg')
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes, class: 'btn-sm')
    }
  }
}

-- MARK: Style

-- ============================================================================
-- LEVEL 2: Inline Styles (Style property)
-- ============================================================================

/**
 * Inline CSS styles for quick one-off styling.
 * Use sparingly - prefer classes for reusable styles.
 */
create page StyleTest.P002_Inline_Styles
(
  title: 'Inline Styles',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_002_inline_styles'
)
{
  -- Inline style on a container
  container ctnCustom (style: 'background-color: #f8f9fa; padding: 24px; border-radius: 8px;') {
    dynamictext txtStyled (content: 'Custom styled container', rendermode: H4)
  }

  -- Combining class and style
  container ctnMixed (class: 'card', style: 'border-left: 4px solid #264AE5;') {
    dynamictext txtMixed (content: 'Card with accent border')
  }

  -- Layout grid with styled columns
  layoutgrid lgStyled {
    row row1 {
      column col1 (desktopwidth: 6) {
        container ctnLeft (style: 'min-height: 200px; background-color: #e3f2fd;') {
          dynamictext txtLeft (content: 'Left panel')
        }
      }
      column col2 (desktopwidth: 6) {
        container ctnRight (style: 'min-height: 200px; background-color: #fce4ec;') {
          dynamictext txtRight (content: 'Right panel')
        }
      }
    }
  }
}

-- @version: 11.0+
-- MARK: DesignProperties — requires Mendix 11.0+ (Atlas v3 design properties)

-- ============================================================================
-- LEVEL 3: Design Properties (Atlas UI structured properties)
-- ============================================================================

/**
 * Design Properties are Atlas UI's structured styling system.
 * They map to predefined theme options (spacing, colors, toggles).
 *
 * Two types:
 *   Option: 'Key': 'Value'   - Dropdown/enum selection
 *   Toggle: 'Key': ON        - Boolean on/off (OFF omits the property)
 */
create page StyleTest.P003_Design_Properties
(
  title: 'Design Properties',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_003_design_properties/{task}',
  params: { $task: StyleTest.task }
)
{
  -- Toggle property (ON) — 'Card style' is a genuine Toggle on Container
  container ctnFullWidth (designproperties: ['Card style': on]) {
    dynamictext txtFull (content: 'Container with card style', rendermode: H3)
  }

  -- Another Toggle property on Container
  container ctnBordered (designproperties: ['Disable row wrap': on]) {
    dynamictext txtSpacing (content: 'Container with flex nowrap')
  }

  -- Multiple Toggle design properties
  container ctnMultiProps (designproperties: ['Card style': on, 'Disable row wrap': on]) {
    dynamictext txtMulti (content: 'Multiple toggle properties applied')
  }

  -- Design properties on a layout grid (LayoutGrid has no theme-defined design properties)
  layoutgrid lgDesign {
    row row1 {
      column col1 (desktopwidth: 6) {
        dynamictext txtCol1 (content: 'Column 1')
      }
      column col2 (desktopwidth: 6) {
        dynamictext txtCol2 (content: 'Column 2')
      }
    }
  }

  -- Design properties on input widgets (DataView requires PARAMETER, not DATABASE)
  dataview dvTask (datasource: $task) {
    textbox txtTitle (label: 'Title', attribute: title)
    textarea txtDesc (label: 'Description', attribute: description)
    datepicker dpDue (label: 'Due Date', attribute: DueDate)
    checkbox chkDone (label: 'Completed', attribute: IsCompleted)

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary, designproperties: ['Full width': on])
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes)
    }
  }
}

-- MARK: Combined

-- ============================================================================
-- LEVEL 4: Combining All Three Styling Mechanisms
-- ============================================================================

/**
 * Real-world example combining Class, Style, and DesignProperties
 * on the same widgets. All three can coexist on any widget.
 */
create page StyleTest.P004_Combined_Styling
(
  title: 'Combined Styling',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_004_combined_styling/{Employee}',
  params: { $Employee: StyleTest.Employee }
)
{
  -- All three on a single container — Card style is a Toggle property
  container ctnHero (
    class: 'card',
    style: 'background: linear-gradient(135deg, #264AE5 0%, #1a237e 100%); color: white;',
    designproperties: ['Card style': on]
  ) {
    dynamictext txtHero (content: 'Hero Section', rendermode: H1)
    dynamictext txtSubtitle (content: 'Combining Class, Style, and DesignProperties')
  }

  -- Dashboard-style card grid
  layoutgrid lgDashboard (class: 'mx-spacing-top-lg') {
    row row1 {
      column col1 (desktopwidth: 4) {
        container ctnStat1 (
          class: 'card card-bordered',
          style: 'border-top: 3px solid #4caf50;',
          designproperties: ['Card style': on]
        ) {
          dynamictext txtStat1Title (content: 'Active Employees', rendermode: H5)
          dynamictext txtStat1Value (content: '42', class: 'text-primary')
        }
      }
      column col2 (desktopwidth: 4) {
        container ctnStat2 (
          class: 'card card-bordered',
          style: 'border-top: 3px solid #ff9800;',
          designproperties: ['Card style': on]
        ) {
          dynamictext txtStat2Title (content: 'Open Tasks', rendermode: H5)
          dynamictext txtStat2Value (content: '17', class: 'text-warning')
        }
      }
      column col3 (desktopwidth: 4) {
        container ctnStat3 (
          class: 'card card-bordered',
          style: 'border-top: 3px solid #f44336;',
          designproperties: ['Card style': on]
        ) {
          dynamictext txtStat3Title (content: 'Overdue', rendermode: H5)
          dynamictext txtStat3Value (content: '3', class: 'text-danger')
        }
      }
    }
  }

  -- Form with mixed styling
  dataview dvEmployee (datasource: $Employee) {
    container ctnFormHeader (class: 'card-header', designproperties: ['Card style': on]) {
      dynamictext txtFormTitle (content: 'Employee Details', rendermode: H4)
    }

    layoutgrid lgForm {
      row row1 {
        column col1 (desktopwidth: 6) {
          textbox txtName (label: 'Full Name', attribute: Name)
        }
        column col2 (desktopwidth: 6) {
          textbox txtEmail (label: 'Email', attribute: Email)
        }
      }
      row row2 {
        column col3 (desktopwidth: 6) {
          textbox txtDept (label: 'Department', attribute: Department)
        }
        column col4 (desktopwidth: 6) {
          datepicker dpStart (label: 'Start Date', attribute: StartDate)
        }
      }
      row row3 {
        column col5 (desktopwidth: 12) {
          textarea txtNotes (label: 'Notes', attribute: Notes, class: 'form-control-lg')
        }
      }
    }

    footer footer1 {
      actionbutton btnSave (
        caption: 'Save Employee',
        action: save_changes,
        buttonstyle: primary,
        class: 'btn-lg',
        designproperties: ['Full width': on, 'Border': on]
      )
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes)
    }
  }
}

-- MARK: OFF toggle

-- ============================================================================
-- LEVEL 5: Toggle OFF (explicitly disabling a design property)
-- ============================================================================

/**
 * OFF means the toggle property is disabled (omitted from serialization).
 * This is useful for documentation or when overriding a default.
 */
create page StyleTest.P005_Toggle_OFF
(
  title: 'Toggle OFF Example',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_005_toggle_off'
)
{
  -- ON enables a Toggle property — 'Card style' is a genuine Toggle on Container
  container ctnOn (designproperties: ['Card style': on]) {
    dynamictext txtOn (content: 'Card style is ON')
  }

  -- OFF disables/omits the toggle (equivalent to not setting it)
  container ctnOff (designproperties: ['Card style': off]) {
    dynamictext txtOff (content: 'Card style is OFF (omitted)')
  }

  -- Mix Toggle ON/OFF with option values (Shadow is a ToggleButtonGroup)
  container ctnMixed (designproperties: ['Card style': on, 'Disable row wrap': on]) {
    dynamictext txtMixed (content: 'Mixed Toggle with option values')
  }
}

-- MARK: Describe

-- ============================================================================
-- LEVEL 6: Describing Pages with Styling (DESCRIBE PAGE)
-- ============================================================================
-- DESCRIBE PAGE outputs the full MDL V3 definition of an existing page,
-- including all Class, Style, and DesignProperties on each widget.
-- Output includes round-trippable CREATE PAGE syntax.
-- DESCRIBE SNIPPET works the same way.

-- Describe a page to see its styling (Class, Style, DesignProperties)
describe page StyleTest.P004_Combined_Styling;

-- Describe a simpler page
describe page StyleTest.P001_CSS_Classes;

-- Describe a snippet (creates it first so it exists)
create snippet StyleTest.MySnippet
(
  params: { $Employee: StyleTest.Employee }
)
{
  container ctnSnippet (class: 'card', style: 'padding: 12px;') {
    dynamictext txtSnippetTitle (content: 'Employee Card', rendermode: H4)
  }
  dataview dvSnippetEmployee (datasource: $Employee) {
    textbox txtSnippetName (label: 'Name', attribute: Name)
  }
}

describe snippet StyleTest.MySnippet;

-- MARK: Show Widgets

-- ============================================================================
-- LEVEL 7: Discovering Widgets (SHOW WIDGETS)
-- ============================================================================
-- SHOW WIDGETS lists widgets across all pages/snippets in tabular form.
-- Use this to find widgets before applying bulk styling updates.
-- Supported filter fields: WidgetType, Name, Container, Module
-- Supported operators: = (exact), LIKE (pattern with % wildcards)

-- Show all widgets in the project
show widgets;

-- Show widgets in a specific module
show widgets in StyleTest;

-- Filter by widget type (LIKE supports % wildcards)
show widgets where widgettype like '%textbox%';
show widgets where widgettype like '%Container%';
show widgets where widgettype like '%ActionButton%';

-- Filter by widget name
show widgets where Name = 'btnSave';
show widgets where Name like 'ctn%';

-- Combine filters with AND
show widgets where widgettype like '%textbox%' and Name like 'txt%' in StyleTest;

-- Filter by container (page or snippet)
show widgets where Name like 'ctn%' in StyleTest;

-- MARK: Update Widgets

-- ============================================================================
-- LEVEL 8: Bulk Widget Updates (UPDATE WIDGETS)
-- ============================================================================
-- UPDATE WIDGETS applies property changes across matching widgets.
-- This is the main command for bulk styling changes.
-- IMPORTANT: Always use DRY RUN first to preview changes!
-- Property values: strings ('text'), numbers (123), booleans (true/false), null

-- Preview: Add CSS class to all containers in a module
update widgets
  set 'Class' = 'card'
  where widgettype like '%Container%'
  in StyleTest
  dry run;

-- Apply: Set inline style on all action buttons
update widgets
  set 'Style' = 'margin-top: 8px;'
  where widgettype like '%ActionButton%'
  in StyleTest
  dry run;

-- Set multiple properties at once
update widgets
  set 'showLabel' = false, 'labelWidth' = 4
  where widgettype like '%combobox%'
  dry run;

-- Hide labels on all checkboxes in a module
update widgets
  set 'showLabel' = false
  where widgettype like '%CheckBox%'
  in StyleTest
  dry run;

-- Reset styling by setting to empty string
update widgets
  set 'Class' = '', 'Style' = ''
  where widgettype like '%Container%'
  in StyleTest
  dry run;

-- MARK: Roundtrip

-- ============================================================================
-- LEVEL 9: Roundtrip Workflow (Create, Describe, Update)
-- ============================================================================
-- Typical workflow: CREATE page, DESCRIBE to inspect, UPDATE to modify.

-- Step 1: Create the page with initial styling
/**
 * Example page for roundtrip workflow.
 * Create it, then DESCRIBE it to see the styling output.
 */
create page StyleTest.P006_Roundtrip
(
  title: 'Roundtrip Example',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_006_roundtrip/{Employee}',
  params: { $Employee: StyleTest.Employee }
)
{
  container ctnHeader (
    class: 'card',
    style: 'padding: 16px;',
    designproperties: ['Card style': on]
  ) {
    dynamictext txtHeader (content: 'Employee Form', rendermode: H3)
  }

  dataview dvEmployee (datasource: $Employee) {
    textbox txtName (label: 'Name', attribute: Name)
    textbox txtEmail (label: 'Email', attribute: Email)
    checkbox chkActive (label: 'Active', attribute: IsActive)

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary)
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes)
    }
  }
}

-- Step 2: Describe to see current state (shows Class, Style, DesignProperties)
describe page StyleTest.P006_Roundtrip;

-- Step 3: Bulk update specific properties across widgets
update widgets
  set 'Class' = 'card card-bordered'
  where Name = 'ctnHeader' and widgettype like '%Container%'
  in StyleTest
  dry run;

-- Step 4: Or CREATE OR REPLACE to rewrite the entire page with new styling
create or replace page StyleTest.P006_Roundtrip
(
  title: 'Roundtrip Example',
  layout: Atlas_Core.Atlas_Default,
  url: 'style_006_roundtrip/{Employee}',
  params: { $Employee: StyleTest.Employee }
)
{
  container ctnHeader (
    class: 'card card-bordered',
    style: 'padding: 16px;',
    designproperties: ['Card style': on, 'Disable row wrap': on]
  ) {
    dynamictext txtHeader (content: 'Employee Form', rendermode: H3)
  }

  dataview dvEmployee (datasource: $Employee) {
    textbox txtName (label: 'Name', attribute: Name)
    textbox txtEmail (label: 'Email', attribute: Email)
    checkbox chkActive (label: 'Active', attribute: IsActive)

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary)
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes)
    }
  }
}

-- Step 5: Verify changes
show widgets in StyleTest;

-- MARK: Show Design Properties

-- ============================================================================
-- LEVEL 10: Discover Available Design Properties (SHOW DESIGN PROPERTIES)
-- ============================================================================
-- Show what design properties are available from the project's theme.
-- Reads themesource/*/web/design-properties.json files.

-- Show all available design properties
show design properties;

-- Show properties for a specific widget type
show design properties for container;
show design properties for actionbutton;
show design properties for datagrid;

-- MARK: Describe Styling

-- ============================================================================
-- LEVEL 11: Describe Styling on Widgets (DESCRIBE STYLING)
-- ============================================================================
-- Show current Class, Style, and DesignProperties on widgets in a page/snippet.
-- Without WIDGET filter, shows all widgets that have any styling.
-- With WIDGET filter, shows styling for that specific widget.

-- Show all styled widgets on a page
describe styling on page StyleTest.P004_Combined_Styling;

-- Show styling for a specific widget
describe styling on page StyleTest.P004_Combined_Styling widget ctnHero;
describe styling on page StyleTest.P006_Roundtrip widget ctnHeader;

-- Describe styling on a snippet
describe styling on snippet StyleTest.MySnippet;
describe styling on snippet StyleTest.MySnippet widget ctnSnippet;

-- MARK: Alter Styling

-- ============================================================================
-- LEVEL 12: Surgically Modify Styling (ALTER STYLING)
-- ============================================================================
-- Change Class, Style, or DesignProperties on a single widget without
-- rewriting the entire page. This is a targeted, in-place update.

-- TODO: ALTER STYLING cannot find widgets in pages created by the MDL page builder
-- because walkPageWidgets traverses LayoutCall.Arguments but the page parser doesn't
-- fully reconstruct the widget tree when re-reading builder-created pages.
-- These commands work on pages originally created in Studio Pro.

-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET Class = 'card card-bordered';
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET Style = 'padding: 24px; border-radius: 12px;';
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET 'Spacing bottom' = 'Large';
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET 'Full width' = ON;
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET 'Full width' = OFF;
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   SET Class = 'card card-bordered',
--       Style = 'padding: 24px;',
--       'Spacing bottom' = 'Large',
--       'Full width' = ON;
-- ALTER STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader
--   CLEAR DESIGN PROPERTIES;
-- DESCRIBE STYLING ON PAGE StyleTest.P006_Roundtrip WIDGET ctnHeader;
