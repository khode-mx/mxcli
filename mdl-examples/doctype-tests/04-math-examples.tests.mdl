/**
 * Unit test for MathTest.IsPrime
 *
 * Test: Verifies that negative numbers are correctly identified as not prime
 *
 * ARRANGE: Set up test input (-5 is not prime)
 * ACT: Call MathTest.IsPrime(-5)
 * ASSERT: Verify result is false
 */
create microflow MathTest.UT_IsPrime_Negative_ReturnsFalse ()
returns string as $TestResult
folder 'Tests/Math'
comment'UT_IsPrime_Negative_ReturnsFalse'
begin
  declare $TestResult string = empty;
  declare $Input integer = -5;
  declare $Expected boolean = false;

  $Actual = call microflow MathTest.IsPrime($Number = $Input);

  if $Actual = $Expected then
    set $TestResult = 'PASS: IsPrime(-5) returned false as expected';
  else
    set $TestResult = 'FAIL: IsPrime(-5) returned ' + toString($Actual) + ', expected false';
  end if;
  log info node 'TestSuite' '{1}' with ({1} = $TestResult);

  return $TestResult;
end;
/

/**
 * Test Suite: All tests for MathTest.IsPrime
 *
 * This microflow runs all unit tests for IsPrime and returns
 * a summary of results.
 */
create microflow MathTest.TestSuite_IsPrime ()
returns string as $Summary
folder 'Tests/Math'
comment'TestSuite_IsPrime'
begin
  declare $TestsPassed integer = 0;
  declare $TotalTests integer = 6;
  declare $Summary string = '';

  -- Run all IsPrime tests
  $Result1 = call microflow MathTest.UT_IsPrime_17_ReturnsTrue();
  if $Result1 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  $Result2 = call microflow MathTest.UT_IsPrime_20_ReturnsFalse();
  if $Result2 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  $Result3 = call microflow MathTest.UT_IsPrime_2_ReturnsTrue();
  if $Result3 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  $Result4 = call microflow MathTest.UT_IsPrime_1_ReturnsFalse();
  if $Result4 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  $Result5 = call microflow MathTest.UT_IsPrime_0_ReturnsFalse();
  if $Result5 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  $Result6 = call microflow MathTest.UT_IsPrime_Negative_ReturnsFalse();
  if $Result6 != empty then
    set $TestsPassed = $TestsPassed + 1;
  end if;

  set $Summary = 'Test Suite: IsPrime - Passed: ' + toString($TestsPassed) + ' / Total: ' + toString($TotalTests);
  log info node 'TestSuite' '{1}' with ({1} = $Summary);

  return $Summary;
end;
/

