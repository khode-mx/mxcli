-- ============================================================================
-- Business Event Examples - Comprehensive Parser Feature Showcase
-- ============================================================================
--
-- This file demonstrates all business event features supported by the
-- Mendix REPL parser.
--
-- Usage:
--   1. Connect to your project
--   2. Execute: EXECUTE SCRIPT 'examples/13-business-events-examples.mdl';
--   3. Verify with: DESCRIBE BUSINESS EVENT SERVICE BeTest.CustomerEventsApi;
--
-- ============================================================================

create module BeTest;

-- MARK: Prerequisites
-- Ensure BusinessEvents module exists with the parent entity required for EXTENDS.
-- When the marketplace module is imported, this is a no-op (CREATE OR MODIFY).
-- When running without the module, this creates the minimum stub.
create module BusinessEvents;
@position(100,100)
create or modify persistent entity BusinessEvents.PublishedBusinessEvent (
  EventId: long
);
create or modify constant BusinessEvents.ServerUrl
type string
default 'localhost:9092';
/

-- MARK: Supporting Entities

@position(100,100)
create persistent entity BeTest.PBE_CustomerChangedEvent extends BusinessEvents.PublishedBusinessEvent (
  CustomerId: long
);

@position(300,100)
create persistent entity BeTest.PBE_AddressChangedEvent extends BusinessEvents.PublishedBusinessEvent (
  AddressId: long
);

-- MARK: Business Event Services

-- ============================================================================
-- PART 1: Basic Business Event Service
-- ============================================================================

/**
 * Example 1.1: Simple service with single message
 */
create business event service BeTest.SimpleEvents
(
  ServiceName: 'SimpleEvents',
  EventNamePrefix: ''
)
{
  message CustomerChangedEvent (CustomerId: long) publish
    entity BeTest.PBE_CustomerChangedEvent;
};

-- ============================================================================
-- PART 2: Multi-Message Service
-- ============================================================================

/**
 * Example 2.1: Service with multiple messages and various attribute types
 */
create business event service BeTest.CustomerEventsApi
(
  ServiceName: 'CustomerEventsApi',
  EventNamePrefix: 'com.example'
)
{
  message CustomerChangedEvent (CustomerId: long) publish
    entity BeTest.PBE_CustomerChangedEvent;
  message AddressChangedEvent (AddressId: long) publish
    entity BeTest.PBE_AddressChangedEvent;
};

-- Verify: entity attributes must match message attributes exactly.
-- PBE_CustomerChangedEvent has CustomerId: Long → message defines (CustomerId: Long) ✓
-- PBE_AddressChangedEvent has AddressId: Long → message defines (AddressId: Long) ✓

-- ============================================================================
-- PART 3: Create Or Replace
-- ============================================================================

/**
 * Example 3.1: Overwrite existing service
 */
create or replace business event service BeTest.SimpleEvents
(
  ServiceName: 'SimpleEventsUpdated',
  EventNamePrefix: 'v2'
)
{
  message CustomerChangedEvent (CustomerId: long) publish
    entity BeTest.PBE_CustomerChangedEvent;
};

-- ============================================================================
-- PART 4: Show
-- ============================================================================


show business event services;
show business event services in BeTest;
describe business event service BeTest.SimpleEvents;
show business events;

-- ============================================================================
-- PART 5: Drop Service
-- ============================================================================

/**
 * Example 4.1: Delete a service
 */
drop business event service BeTest.SimpleEvents;

-- ============================================================================
-- SUMMARY
-- ============================================================================
--
-- Covered:
-- CREATE BUSINESS EVENT SERVICE with properties
-- MESSAGE with typed attributes (Long)
-- PUBLISH operation with ENTITY binding
-- Multiple messages per service
-- EventNamePrefix property
-- CREATE OR REPLACE
-- DROP BUSINESS EVENT SERVICE
-- Entity  (required for published events)
--
-- ============================================================================
