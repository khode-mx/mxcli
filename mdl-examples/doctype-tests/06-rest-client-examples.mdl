-- @version: 11.0+
-- ============================================================================
-- REST Client Examples - Consumed REST Service Showcase (requires Mendix 11.0+)
-- ============================================================================
--
-- This file demonstrates REST client features supported by the Mendix REPL,
-- organized by increasing complexity.
--
-- Prerequisites:
--   - Mendix 10.1.0+ (for ConsumedRestService support)
--   - Mendix 10.4.0+ (for method property)
--   - Mendix 11.0.0+ (for query parameters)
--
-- Usage:
--   1. Connect to your project
--   2. Execute: EXECUTE SCRIPT 'examples/rest-client-examples.mdl';
--   3. Test roundtrip with: DESCRIBE REST CLIENT RestTest.PetStoreAPI;
--   4. List all clients: SHOW REST CLIENTS;
--
-- Features demonstrated:
--   - Basic REST client with single operation
--   - Multiple HTTP methods (GET, POST, PUT, PATCH, DELETE)
--   - Path parameters
--   - Query parameters
--   - Custom headers (static and dynamic)
--   - Request body (JSON and FILE)
--   - Response handling (JSON, STRING, FILE, STATUS, NONE)
--   - Authentication (BASIC, NONE)
--   - Timeout configuration
--   - Documentation comments
--
-- ============================================================================

-- REST client support implemented

-- ############################################################################
-- PART 0: MODULE SETUP
-- ############################################################################

-- MARK: Module Setup

-- Create module for our REST client examples
CREATE MODULE RestTest;

-- ############################################################################
-- PART 1: BASIC REST CLIENTS
-- ############################################################################

-- MARK: Basic Examples

-- ============================================================================
-- Level 1.1: Minimal REST Client
-- ============================================================================
--
-- The simplest possible REST client with a single GET operation.

CREATE REST CLIENT RestTest.RC001_SimpleAPI
BASE URL 'https://reqbin.com'
AUTHENTICATION NONE
BEGIN
  OPERATION GetStatus
    METHOD GET
    PATH '/echo'
    HEADER 'Accept' = '*/*'
    RESPONSE NONE;
END;

-- ============================================================================
-- Level 1.2: REST Client with JSON Response
-- ============================================================================
--
-- A REST client that returns JSON data mapped to a variable.

CREATE REST CLIENT RestTest.RC002_JsonAPI
BASE URL 'https://jsonplaceholder.typicode.com'
AUTHENTICATION NONE
BEGIN
  OPERATION GetPosts
    METHOD GET
    PATH '/posts'
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Posts;
END;

-- ============================================================================
-- Level 1.3: REST Client with Path Parameter
-- ============================================================================
--
-- Demonstrates path parameters using {param} syntax in the path.

CREATE REST CLIENT RestTest.RC003_UserAPI
BASE URL 'https://jsonplaceholder.typicode.com'
AUTHENTICATION NONE
BEGIN
  OPERATION GetUser
    METHOD GET
    PATH '/users/{userId}'
    HEADER 'Accept' = 'application/json'
    PARAMETER $userId: Integer
    RESPONSE JSON AS $User;
END;

-- ############################################################################
-- PART 2: HTTP METHODS
-- ############################################################################

-- MARK: HTTP Methods

-- ============================================================================
-- Level 2.1: All HTTP Methods
-- ============================================================================
--
-- Demonstrates all supported HTTP methods in a single client.

CREATE REST CLIENT RestTest.RC004_CrudAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  /** Retrieve all resources */
  OPERATION GetAll
    METHOD GET
    PATH '/get'
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Resources;

  /** Create a new resource */
  OPERATION CreateResource
    METHOD POST
    PATH '/post'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $NewResource
    RESPONSE JSON AS $CreatedResource;

  /** Fully update an existing resource */
  OPERATION UpdateResource
    METHOD PUT
    PATH '/put'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $UpdatedResource
    RESPONSE JSON AS $Resource;

  /** Partially update an existing resource */
  OPERATION "PatchResource"
    METHOD PATCH
    PATH '/patch'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $PatchData
    RESPONSE JSON AS $Resource;

  /** Delete a resource */
  OPERATION "DeleteResource"
    METHOD DELETE
    PATH '/delete'
    RESPONSE NONE;
END;

-- ############################################################################
-- PART 3: QUERY PARAMETERS
-- ############################################################################

-- MARK: Query Parameters

-- ============================================================================
-- Level 3.1: Single Query Parameter
-- ============================================================================

CREATE REST CLIENT RestTest.RC005_SearchAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION Search
    METHOD GET
    PATH '/anything/search'
    QUERY $q: String
    RESPONSE JSON AS $Results;
END;

-- ============================================================================
-- Level 3.2: Multiple Query Parameters
-- ============================================================================
--
-- Demonstrates pagination and filtering with multiple query parameters.

CREATE REST CLIENT RestTest.RC006_PaginatedAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  /** Search with pagination */
  OPERATION SearchPaginated
    METHOD GET
    PATH '/anything/items'
    QUERY $search: String
    QUERY $page: Integer
    QUERY $limit: Integer
    QUERY $sortBy: String
    QUERY $ascending: Boolean
    RESPONSE JSON AS $Items;
END;

-- ============================================================================
-- Level 3.3: Mixed Path and Query Parameters
-- ============================================================================

CREATE REST CLIENT RestTest.RC007_FilteredAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  /** Get items in a category with filters */
  OPERATION GetCategoryItems
    METHOD GET
    PATH '/anything/categories/{categoryId}/items'
    PARAMETER $categoryId: Integer
    QUERY $status: String
    QUERY $minPrice: Decimal
    QUERY $maxPrice: Decimal
    RESPONSE JSON AS $Items;
END;

-- ############################################################################
-- PART 4: HEADERS
-- ############################################################################

-- MARK: Headers

-- ============================================================================
-- Level 4.1: Static Headers
-- ============================================================================
--
-- Headers with literal string values.

CREATE REST CLIENT RestTest.RC008_HeaderAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION GetData
    METHOD GET
    PATH '/headers'
    HEADER 'Accept' = 'application/json'
    HEADER 'X-API-Version' = '2.0'
    HEADER 'X-Client-ID' = 'mendix-repl'
    RESPONSE JSON AS $Data;
END;

-- ============================================================================
-- Level 4.2: Dynamic Headers with Parameters
-- ============================================================================
--
-- Headers that include parameter values using concatenation.

CREATE REST CLIENT RestTest.RC009_AuthHeaderAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION GetSecureData
    METHOD GET
    PATH '/headers'
    HEADER 'Accept' = 'application/json'
    HEADER 'Authorization' = 'Bearer my-api-token'
    HEADER 'X-Request-ID' = 'request-001'
    RESPONSE JSON AS $Data;
END;

-- ============================================================================
-- Level 4.3: Content-Type Headers for POST/PUT
-- ============================================================================

CREATE REST CLIENT RestTest.RC010_ContentTypeAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION PostJson
    METHOD POST
    PATH '/post'
    HEADER 'Content-Type' = 'application/json'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $Payload
    RESPONSE JSON AS $Result;
END;

-- ############################################################################
-- PART 5: AUTHENTICATION
-- ############################################################################

-- MARK: Authentication

-- ============================================================================
-- Level 5.1: No Authentication (explicit)
-- ============================================================================

CREATE REST CLIENT RestTest.RC011_PublicAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION GetPublicData
    METHOD GET
    PATH '/get'
    RESPONSE JSON AS $Data;
END;

-- ============================================================================
-- Level 5.2: Basic Authentication with Literals
-- ============================================================================

CREATE REST CLIENT RestTest.RC012_BasicAuthAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION BASIC (USERNAME = 'api_user', PASSWORD = 'api_secret')
BEGIN
  OPERATION GetProtectedData
    METHOD GET
    PATH '/basic-auth/api_user/api_secret'
    RESPONSE JSON AS $Data;
END;

-- ============================================================================
-- Level 5.3: Basic Authentication with Parameters
-- ============================================================================
--
-- For production use, credentials should come from constants.

CREATE REST CLIENT RestTest.RC013_SecureAuthAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION BASIC (USERNAME = 'testuser', PASSWORD = 'testpass')
BEGIN
  OPERATION GetSecureData
    METHOD GET
    PATH '/hidden-basic-auth/testuser/testpass'
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Data;
END;

-- ############################################################################
-- PART 6: REQUEST BODY
-- ############################################################################

-- MARK: Request Body

-- ============================================================================
-- Level 6.1: JSON Body
-- ============================================================================

CREATE REST CLIENT RestTest.RC014_JsonBodyAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION AddItem
    METHOD POST
    PATH '/post'
    HEADER 'Content-Type' = 'application/json'
    BODY JSON FROM $ItemData
    RESPONSE JSON AS $CreatedItem;
END;

-- ============================================================================
-- Level 6.2: File Upload
-- ============================================================================

CREATE REST CLIENT RestTest.RC015_FileUploadAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  OPERATION UploadFile
    METHOD POST
    PATH '/post'
    BODY FILE FROM $FileDocument
    RESPONSE JSON AS $UploadResult;
END;

-- ############################################################################
-- PART 7: RESPONSE HANDLING
-- ############################################################################

-- MARK: Response Handling

-- ============================================================================
-- Level 7.1: All Response Types
-- ============================================================================
--
-- Demonstrates all supported response handling types.

CREATE REST CLIENT RestTest.RC016_ResponseTypesAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  /** JSON response mapped to entity */
  OPERATION GetJson
    METHOD GET
    PATH '/json'
    RESPONSE JSON AS $JsonData;

  /** Raw string response */
  OPERATION GetString
    METHOD GET
    PATH '/robots.txt'
    RESPONSE STRING AS $TextContent;

  /** Binary file download */
  OPERATION DownloadFile
    METHOD GET
    PATH '/bytes/{fileId}'
    PARAMETER $fileId: String
    RESPONSE FILE AS $FileDocument;

  /** HTTP status code only */
  OPERATION CheckStatus
    METHOD GET
    PATH '/status/200'
    RESPONSE STATUS AS $StatusCode;

  /** No response expected */
  OPERATION Ping
    METHOD GET
    PATH '/status/204'
    RESPONSE NONE;
END;

-- ############################################################################
-- PART 8: TIMEOUT CONFIGURATION
-- ############################################################################

-- MARK: Timeout

-- ============================================================================
-- Level 8.1: Custom Timeout
-- ============================================================================
--
-- Default timeout is 300 seconds. Override for long-running operations.

CREATE REST CLIENT RestTest.RC017_LongRunningAPI
BASE URL 'https://httpbin.org'
AUTHENTICATION NONE
BEGIN
  /** Quick health check with short timeout */
  OPERATION HealthCheck
    METHOD GET
    PATH '/status/200'
    TIMEOUT 5
    RESPONSE STATUS AS $Status;

  /** Report generation with extended timeout (delay/10 waits 10 seconds) */
  OPERATION GenerateReport
    METHOD POST
    PATH '/delay/10'
    TIMEOUT 600
    BODY JSON FROM $ReportParams
    RESPONSE JSON AS $ReportResult;
END;

-- ############################################################################
-- PART 9: COMPLETE REAL-WORLD EXAMPLES
-- ############################################################################

-- MARK: Real-World Examples

-- ============================================================================
-- Level 9.1: Pet Store API (Classic Example)
-- ============================================================================

/**
 * Swagger Pet Store API
 * A complete REST client for the classic Pet Store demo API.
 * Demonstrates full CRUD operations with various features.
 */
CREATE REST CLIENT RestTest.RC018_PetStoreAPI
BASE URL 'https://petstore.swagger.io/v2'
AUTHENTICATION NONE
BEGIN
  /**
   * List all pets with optional filtering
   * @param status Filter by pet status (available, pending, sold)
   * @param limit Maximum number of pets to return
   */
  OPERATION ListPets
    METHOD GET
    PATH '/pet/findByStatus'
    QUERY $status: String
    HEADER 'Accept' = 'application/json'
    TIMEOUT 30
    RESPONSE JSON AS $PetList;

  /**
   * Get a single pet by ID
   * @param petId The unique identifier of the pet
   */
  OPERATION GetPet
    METHOD GET
    PATH '/pet/{petId}'
    PARAMETER $petId: Integer
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Pet;

  /**
   * Create a new pet
   * Adds a new pet to the store inventory.
   */
  OPERATION AddPet
    METHOD POST
    PATH '/pet'
    HEADER 'Content-Type' = 'application/json'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $NewPet
    RESPONSE JSON AS $CreatedPet;

  /**
   * Update an existing pet
   * Modifies all fields of an existing pet record.
   */
  OPERATION ModifyPet
    METHOD PUT
    PATH '/pet'
    HEADER 'Content-Type' = 'application/json'
    HEADER 'Accept' = 'application/json'
    BODY JSON FROM $UpdatedPet
    RESPONSE JSON AS $Pet;

  /**
   * Delete a pet
   * Removes a pet from the store inventory.
   * @param petId The unique identifier of the pet to delete
   */
  OPERATION RemovePet
    METHOD DELETE
    PATH '/pet/{petId}'
    PARAMETER $petId: Integer
    HEADER 'api_key' = 'special-key'
    RESPONSE NONE;

  /**
   * Upload pet image
   * @param petId The pet to associate the image with
   */
  OPERATION UploadImage
    METHOD POST
    PATH '/pet/{petId}/uploadImage'
    PARAMETER $petId: Integer
    BODY FILE FROM $ImageFile
    RESPONSE JSON AS $UploadResult;
END;

-- ============================================================================
-- Level 9.2: GitHub API Client
-- ============================================================================

/**
 * GitHub REST API Client
 * Demonstrates integration with GitHub's REST API v3.
 */
CREATE REST CLIENT RestTest.RC019_GitHubAPI
BASE URL 'https://api.github.com'
AUTHENTICATION NONE
BEGIN
  /** Get repository information */
  OPERATION GetRepository
    METHOD GET
    PATH '/repos/{owner}/{repo}'
    PARAMETER $owner: String
    PARAMETER $repo: String
    HEADER 'Accept' = 'application/vnd.github.v3+json'
    HEADER 'User-Agent' = 'Mendix-REPL'
    RESPONSE JSON AS $Repository;

  /** List repository issues */
  OPERATION ListIssues
    METHOD GET
    PATH '/repos/{owner}/{repo}/issues'
    PARAMETER $owner: String
    PARAMETER $repo: String
    QUERY $state: String
    QUERY $labels: String
    QUERY $page: Integer
    QUERY $per_page: Integer
    HEADER 'Accept' = 'application/vnd.github.v3+json'
    HEADER 'User-Agent' = 'Mendix-REPL'
    RESPONSE JSON AS $Issues;

  /** Create an issue (requires authentication) */
  OPERATION AddIssue
    METHOD POST
    PATH '/repos/{owner}/{repo}/issues'
    PARAMETER $owner: String
    PARAMETER $repo: String
    HEADER 'Accept' = 'application/vnd.github.v3+json'
    HEADER 'User-Agent' = 'Mendix-REPL'
    HEADER 'Authorization' = 'token ghp_exampletoken123'
    BODY JSON FROM $IssueData
    RESPONSE JSON AS $CreatedIssue;

  /** Get authenticated user */
  OPERATION GetAuthenticatedUser
    METHOD GET
    PATH '/user'
    HEADER 'Accept' = 'application/vnd.github.v3+json'
    HEADER 'User-Agent' = 'Mendix-REPL'
    HEADER 'Authorization' = 'token ghp_exampletoken123'
    RESPONSE JSON AS $User;
END;

-- ============================================================================
-- Level 9.3: Weather API Client
-- ============================================================================

/**
 * OpenWeatherMap API Client
 * Demonstrates API key authentication via query parameter.
 */
CREATE REST CLIENT RestTest.RC020_WeatherAPI
BASE URL 'https://api.openweathermap.org/data/2.5'
AUTHENTICATION NONE
BEGIN
  /** Get current weather for a city */
  OPERATION GetCurrentWeather
    METHOD GET
    PATH '/weather'
    QUERY $q: String
    QUERY $appid: String
    QUERY $units: String
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Weather;

  /** Get 5-day forecast */
  OPERATION GetForecast
    METHOD GET
    PATH '/forecast'
    QUERY $q: String
    QUERY $appid: String
    QUERY $units: String
    QUERY $cnt: Integer
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Forecast;

  /** Get weather by coordinates */
  OPERATION GetWeatherByCoords
    METHOD GET
    PATH '/weather'
    QUERY $lat: Decimal
    QUERY $lon: Decimal
    QUERY $appid: String
    QUERY $units: String
    HEADER 'Accept' = 'application/json'
    RESPONSE JSON AS $Weather;
END;

-- ============================================================================
-- Level 9.4: Stripe-style Payment API
-- ============================================================================

/**
 * Payment Processing API
 * Demonstrates secure API patterns for payment processing.
 */
CREATE REST CLIENT RestTest.RC021_PaymentAPI
BASE URL 'https://api.payments.example.com/v1'
AUTHENTICATION BASIC (USERNAME = 'sk_test_placeholder', PASSWORD = '')
BEGIN
  /** Create a payment intent */
  OPERATION InitiatePayment
    METHOD POST
    PATH '/payment_intents'
    HEADER 'Content-Type' = 'application/json'
    HEADER 'Accept' = 'application/json'
    HEADER 'Idempotency-Key' = 'idem-key-001'
    BODY JSON FROM $PaymentData
    TIMEOUT 30
    RESPONSE JSON AS $PaymentIntent;

  /** Retrieve a payment intent */
  OPERATION GetPaymentIntent
    METHOD GET
    PATH '/payment_intents/{paymentIntentId}'
    PARAMETER $paymentIntentId: String
    RESPONSE JSON AS $PaymentIntent;

  /** Confirm a payment */
  OPERATION ConfirmPayment
    METHOD POST
    PATH '/payment_intents/{paymentIntentId}/confirm'
    PARAMETER $paymentIntentId: String
    HEADER 'Content-Type' = 'application/json'
    BODY JSON FROM $ConfirmData
    RESPONSE JSON AS $PaymentIntent;

  /** Cancel a payment */
  OPERATION CancelPayment
    METHOD POST
    PATH '/payment_intents/{paymentIntentId}/cancel'
    PARAMETER $paymentIntentId: String
    RESPONSE JSON AS $PaymentIntent;

  /** List all payments */
  OPERATION ListPayments
    METHOD GET
    PATH '/payment_intents'
    QUERY $limit: Integer
    QUERY $starting_after: String
    QUERY $created: Integer
    RESPONSE JSON AS $PaymentList;
END;

-- ############################################################################
-- PART 10: MICROFLOWS THAT CALL REST SERVICES
-- ############################################################################

-- MARK: Test Microflows

-- ============================================================================
-- Two approaches for calling REST from microflows:
--
-- 1. SEND REST REQUEST — calls a consumed REST service operation (defined
--    above via CREATE REST CLIENT). URL, headers, auth, and response mapping
--    are configured in the REST client document.
--
-- 2. REST CALL — inline HTTP call with URL, headers, auth, body, and
--    response handling specified directly in the microflow. Useful for
--    one-off calls or when no REST client document exists.
--
-- Both are first-class citizens; use whichever fits the situation.
-- ============================================================================

-- ############################################################################
-- PART 10A: SEND REST REQUEST (Consumed REST Service Operations)
-- ############################################################################

-- MARK: SEND REST REQUEST

-- ----------------------------------------------------------------------------
-- 10A.1: Simple GET via REST client (RC001_SimpleAPI.GetStatus)
-- ----------------------------------------------------------------------------

/**
 * Test simple GET via consumed REST service
 *
 * Calls the GetStatus operation defined in RC001_SimpleAPI.
 * No response variable — fire and forget.
 */
CREATE MICROFLOW RestTest.ACT_TestSimpleGet ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  SEND REST REQUEST RestTest.RC001_SimpleAPI.GetStatus;

  SET $Success = true;
  LOG INFO NODE 'RestTest' 'ACT_TestSimpleGet: passed';
  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10A.2: GET with JSON response via REST client (RC008_HeaderAPI.GetData)
-- ----------------------------------------------------------------------------

/**
 * Test GET with response mapping via consumed REST service
 *
 * Calls the GetData operation defined in RC008_HeaderAPI.
 * The response is mapped to the $RootResult entity variable.
 * Use $latestHttpResponse (System.HttpResponse) to check call success.
 */
CREATE MICROFLOW RestTest.ACT_TestHeaders ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $RootResult = SEND REST REQUEST RestTest.RC008_HeaderAPI.GetData;

  -- $latestHttpResponse is a system variable (System.HttpResponse) that is
  -- automatically populated after SEND REST REQUEST. Check its Content
  -- attribute to determine if the call returned data.
  IF $latestHttpResponse/Content != empty THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestHeaders: headers echoed';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestHeaders: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ############################################################################
-- PART 10B: REST CALL (Inline HTTP Calls)
-- ############################################################################

-- MARK: REST CALL

-- ----------------------------------------------------------------------------
-- 10B.1: GET returning JSON string
-- ----------------------------------------------------------------------------

/**
 * Test inline GET returning JSON
 *
 * Fetches posts from jsonplaceholder via direct REST CALL.
 */
CREATE MICROFLOW RestTest.ACT_TestJsonGet ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL GET 'https://jsonplaceholder.typicode.com/posts'
    HEADER Accept = 'application/json'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestJsonGet: received ' + toString(length($Response)) + ' chars';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestJsonGet: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.2: GET with path parameter
-- ----------------------------------------------------------------------------

/**
 * Test GET with URL template parameters
 *
 * Fetches user #1 from jsonplaceholder using {1} placeholder.
 */
CREATE MICROFLOW RestTest.ACT_TestPathParams ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL GET 'https://jsonplaceholder.typicode.com/users/{1}' WITH (
    {1} = '1'
  )
    HEADER Accept = 'application/json'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestPathParams: received user data';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestPathParams: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.3: POST with JSON body
-- ----------------------------------------------------------------------------

/**
 * Test POST with inline JSON body
 */
CREATE MICROFLOW RestTest.ACT_TestPost ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL POST 'https://httpbin.org/post'
    HEADER 'Content-Type' = 'application/json'
    HEADER Accept = 'application/json'
    BODY '{{"title": "test", "body": "hello from MDL", "userId": 1}'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestPost: POST succeeded';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestPost: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.4: GET with query parameters
-- ----------------------------------------------------------------------------

/**
 * Test GET with query string parameters via URL template
 */
CREATE MICROFLOW RestTest.ACT_TestQueryParams ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL GET 'https://httpbin.org/anything/search?q={1}&page={2}' WITH (
    {1} = 'mendix',
    {2} = '1'
  )
    HEADER Accept = 'application/json'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestQueryParams: query echoed';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestQueryParams: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.5: PUT request
-- ----------------------------------------------------------------------------

/**
 * Test inline PUT request
 */
CREATE MICROFLOW RestTest.ACT_TestPut ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL PUT 'https://httpbin.org/put'
    HEADER 'Content-Type' = 'application/json'
    HEADER Accept = 'application/json'
    BODY '{{"name": "updated", "value": 42}'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestPut: PUT succeeded';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestPut: empty response';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.6: DELETE request
-- ----------------------------------------------------------------------------

/**
 * Test inline DELETE request
 */
CREATE MICROFLOW RestTest.ACT_TestDelete ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  REST CALL DELETE 'https://httpbin.org/delete'
    HEADER Accept = '*/*'
    TIMEOUT 15
    RETURNS Nothing
    ON ERROR CONTINUE;

  SET $Success = true;
  LOG INFO NODE 'RestTest' 'ACT_TestDelete: DELETE succeeded';
  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.7: Basic authentication
-- ----------------------------------------------------------------------------

/**
 * Test inline GET with basic auth
 */
CREATE MICROFLOW RestTest.ACT_TestBasicAuth ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  $Response = REST CALL GET 'https://httpbin.org/basic-auth/api_user/api_secret'
    HEADER Accept = 'application/json'
    AUTH BASIC 'api_user' PASSWORD 'api_secret'
    TIMEOUT 15
    RETURNS String
    ON ERROR CONTINUE;

  IF $Response != '' THEN
    SET $Success = true;
    LOG INFO NODE 'RestTest' 'ACT_TestBasicAuth: authenticated OK';
  ELSE
    LOG WARNING NODE 'RestTest' 'ACT_TestBasicAuth: auth failed';
  END IF;

  RETURN $Success;
END;
/

-- ----------------------------------------------------------------------------
-- 10B.8: Short timeout
-- ----------------------------------------------------------------------------

/**
 * Test timeout configuration
 */
CREATE MICROFLOW RestTest.ACT_TestTimeout ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  REST CALL GET 'https://httpbin.org/status/200'
    HEADER Accept = '*/*'
    TIMEOUT 5
    RETURNS Nothing
    ON ERROR CONTINUE;

  SET $Success = true;
  LOG INFO NODE 'RestTest' 'ACT_TestTimeout: completed within timeout';
  RETURN $Success;
END;
/

-- ############################################################################
-- PART 10C: Run All Tests
-- ############################################################################

-- MARK: Run All

/**
 * Run all REST client test microflows
 *
 * Calls each test microflow in sequence and logs a summary.
 * Includes both SEND REST REQUEST and REST CALL tests.
 */
CREATE MICROFLOW RestTest.ACT_RunAllRestTests ()
RETURNS Boolean AS $AllPassed
BEGIN
  DECLARE $AllPassed Boolean = true;
  DECLARE $Passed Integer = 0;
  DECLARE $Failed Integer = 0;

  LOG INFO NODE 'RestTest' '=== Running all REST client tests ===';

  $R1 = CALL MICROFLOW RestTest.ACT_TestSimpleGet();
  IF $R1 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R2 = CALL MICROFLOW RestTest.ACT_TestJsonGet();
  IF $R2 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R3 = CALL MICROFLOW RestTest.ACT_TestPathParams();
  IF $R3 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R4 = CALL MICROFLOW RestTest.ACT_TestPost();
  IF $R4 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R5 = CALL MICROFLOW RestTest.ACT_TestQueryParams();
  IF $R5 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R6 = CALL MICROFLOW RestTest.ACT_TestPut();
  IF $R6 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R7 = CALL MICROFLOW RestTest.ACT_TestDelete();
  IF $R7 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R8 = CALL MICROFLOW RestTest.ACT_TestBasicAuth();
  IF $R8 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R9 = CALL MICROFLOW RestTest.ACT_TestHeaders();
  IF $R9 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  $R10 = CALL MICROFLOW RestTest.ACT_TestTimeout();
  IF $R10 THEN SET $Passed = $Passed + 1; ELSE SET $Failed = $Failed + 1; SET $AllPassed = false; END IF;

  LOG INFO NODE 'RestTest' '=== REST tests complete: ' + toString($Passed) + ' passed, ' + toString($Failed) + ' failed ===';

  RETURN $AllPassed;
END;
/

-- ############################################################################
-- PART 11: TEST PAGE
-- ############################################################################

-- MARK: Test Page

-- ============================================================================
-- REST Client Test Page
-- ============================================================================
--
-- A page with buttons to invoke each test microflow.
