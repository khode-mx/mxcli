-- List all created REST clients
SHOW REST CLIENTS;

-- Show details of the Pet Store API
DESCRIBE REST CLIENT RestTest.RC018_PetStoreAPI;

-- Show JSON structures
SHOW JSON STRUCTURES;
DESCRIBE JSON STRUCTURE RestTest.JSON_Pet;

-- Show import and export mappings
SHOW IMPORT MAPPINGS;
DESCRIBE IMPORT MAPPING RestTest.IMM_Pet;
SHOW EXPORT MAPPINGS;
DESCRIBE EXPORT MAPPING RestTest.EMM_Pet;

