-- ############################################################################
-- PART 12: JSON STRUCTURES
-- ############################################################################

-- MARK: JSON Structures

-- ============================================================================
-- Level 12.1: Basic JSON Structure
-- ============================================================================
--
-- Create a JSON structure from a raw JSON snippet. The element tree is
-- automatically derived from the snippet.

create json structure RestTest.JSON_Pet
snippet '{"id": 1, "name": "Fido", "status": "available"}';

-- ============================================================================
-- Level 12.2: Nested JSON Structure
-- ============================================================================
--
-- Demonstrates a JSON structure with nested objects and arrays.

create json structure RestTest.JSON_Order
snippet '{"orderId": 100, "customer": {"name": "Alice", "email": "alice@example.com"}, "items": [{"sku": "A1", "quantity": 2, "price": 9.99}]}';

-- ############################################################################
-- PART 13: IMPORT MAPPINGS
-- ############################################################################

-- MARK: Import Mappings

-- ============================================================================
-- Level 13.1: Simple Import Mapping
-- ============================================================================
--
-- Maps a flat JSON structure to a single non-persistent entity.

create non-persistent entity RestTest.PetResponse (
  PetId: integer,
  Name: string,
  status: string
);
/

create import mapping RestTest.IMM_Pet
  with json structure RestTest.JSON_Pet
{
  create RestTest.PetResponse {
    PetId = id,
    Name = name,
    status = status
  }
};

-- ============================================================================
-- Level 13.2: Nested Import Mapping with Associations
-- ============================================================================
--
-- Maps a nested JSON structure to multiple entities linked by associations.

create non-persistent entity RestTest.OrderResponse (
  OrderId: integer
);
/

create non-persistent entity RestTest.CustomerInfo (
  Name: string,
  Email: string
);
/

create non-persistent entity RestTest.OrderItem (
  Sku: string,
  Quantity: integer,
  Price: decimal
);
/

create association RestTest.CustomerInfo_OrderResponse
  from RestTest.CustomerInfo
  to RestTest.OrderResponse;
/

create association RestTest.OrderItem_OrderResponse
  from RestTest.OrderItem
  to RestTest.OrderResponse;
/

create import mapping RestTest.IMM_Order
  with json structure RestTest.JSON_Order
{
  create RestTest.OrderResponse {
    OrderId = orderId,
    create RestTest.CustomerInfo_OrderResponse/RestTest.CustomerInfo = customer {
      Email = email,
      Name = name
    },
    create RestTest.OrderItem_OrderResponse/RestTest.OrderItem = items {
      Sku = sku,
      Quantity = quantity,
      Price = price
    }
  }
};

-- ============================================================================
-- Level 13.3: Find Or Create Import Mapping
-- ============================================================================
--
-- Uses FIND OR CREATE to upsert: find existing by KEY, create if not found.

create import mapping RestTest.IMM_UpsertPet
  with json structure RestTest.JSON_Pet
{
  find or create RestTest.PetResponse {
    PetId = id key,
    Name = name,
    status = status
  }
};

-- ============================================================================
-- Level 13.4: Import Mapping with Value Transform
-- ============================================================================
--
-- Demonstrates calling a microflow to transform a JSON value during import.
-- The microflow receives the raw JSON field value and returns the converted type.

-- CREATE IMPORT MAPPING RestTest.IMM_TransformPet
--   WITH JSON STRUCTURE RestTest.JSON_Pet
-- {
--   CREATE RestTest.PetResponse {
--     PetId = id,
--     Name = RestTest.TrimAndUpperCase(name),
--     Status = status
--   }
-- };

-- ############################################################################
-- PART 14: EXPORT MAPPINGS
-- ############################################################################

-- MARK: Export Mappings

-- ============================================================================
-- Level 14.1: Simple Export Mapping
-- ============================================================================
--
-- Maps an entity back to JSON for outgoing REST calls.

create export mapping RestTest.EMM_Pet
  with json structure RestTest.JSON_Pet
{
  RestTest.PetResponse {
    id = PetId,
    name = Name,
    status = status
  }
};

-- ============================================================================
-- Level 14.2: Export Mapping with Nested Objects and Arrays
-- ============================================================================
--
-- Export mappings need a domain model that mirrors the JSON structure.
-- Arrays require a container entity + item entity (two levels).
-- This is different from import mappings which map arrays directly.

create non-persistent entity RestTest.ExRoot (
  OrderId: integer
);
/

create non-persistent entity RestTest.ExCustomer (
  Name: string,
  Email: string
);
/

create non-persistent entity RestTest.ExItems;
/

create non-persistent entity RestTest.ExItemsItem (
  Sku: string,
  Quantity: integer,
  Price: decimal
);
/

create association RestTest.ExCustomer_ExRoot
  from RestTest.ExCustomer
  to RestTest.ExRoot
  owner both;
/

create association RestTest.ExItems_ExRoot
  from RestTest.ExItems
  to RestTest.ExRoot;
/

create association RestTest.ExItemsItem_ExItems
  from RestTest.ExItemsItem
  to RestTest.ExItems;
/

create export mapping RestTest.EMM_Order
  with json structure RestTest.JSON_Order
  null values LeaveOutElement
{
  RestTest.ExRoot {
    orderId = OrderId,
    RestTest.ExCustomer_ExRoot/RestTest.ExCustomer as customer {
      email = Email,
      name = Name
    },
    RestTest.ExItems_ExRoot/RestTest.ExItems as items {
      RestTest.ExItemsItem_ExItems/RestTest.ExItemsItem as ItemsItem {
        sku = Sku,
        quantity = Quantity,
        price = Price
      }
    }
  }
};

-- ############################################################################
-- PART 15: SEND REST REQUEST WITH MAPPINGS
-- ############################################################################

-- MARK: SEND REST REQUEST with Mappings

-- ============================================================================
-- Level 15.1: GET with Import Mapping via REST CALL
-- ============================================================================
--
-- Combines a consumed REST service with an import mapping to deserialize
-- the JSON response into Mendix entities.

create microflow RestTest.ACT_TestImportMapping ()
returns boolean as $success
begin
  declare $success boolean = false;

  $Result = rest call get 'https://jsonplaceholder.typicode.com/posts/1'
    header Accept = 'application/json'
    timeout 15
    returns string
    on error continue;

  if $Result != '' then
    set $success = true;
    log info node 'RestTest' 'ACT_TestImportMapping: import mapping test passed';
  else
    log warning node 'RestTest' 'ACT_TestImportMapping: empty response';
  end if;

  return $success;
end;
/

-- ############################################################################
-- PART 16: IMPORT/EXPORT MAPPING IN MICROFLOWS
-- ############################################################################

-- MARK: Import/Export Mapping Actions

-- ============================================================================
-- Level 16.1: Import from Mapping (with result variable)
-- ============================================================================
--
-- Applies an import mapping to a JSON string to produce entity objects.
-- The result is stored in a variable for further processing.

create microflow RestTest.ACT_ImportFromMapping ()
returns boolean as $success
begin
  declare $success boolean = false;
  declare $JsonContent string = '{{\"id\": 1, \"name\": \"Fido\", \"status\": \"available\"}';

  $PetResponse = import from mapping RestTest.IMM_Pet($JsonContent);

  if $PetResponse != empty then
    set $success = true;
    log info node 'RestTest' 'Import succeeded: ' + $PetResponse/Name;
  end if;

  return $success;
end;
/

-- ============================================================================
-- Level 16.2: Export to Mapping (entity to JSON string)
-- ============================================================================
--
-- Applies an export mapping to an entity object to produce a JSON string.

create microflow RestTest.ACT_ExportToMapping ($PetResponse: RestTest.PetResponse)
returns string as $JsonOutput
begin
  $JsonOutput = export to mapping RestTest.EMM_Pet($PetResponse);
  log info node 'RestTest' 'Exported JSON: ' + $JsonOutput;
  return $JsonOutput;
end;
/

-- ============================================================================
-- Level 16.3: Import → Process → Export pipeline
-- ============================================================================
--
-- Full pipeline: receive JSON, import to entities, process, export back to JSON.

create microflow RestTest.ACT_ImportProcessExport ()
begin
  declare $JsonContent string = '{{\"id\": 1, \"name\": \"Fido\", \"status\": \"available\"}';
  $PetResponse = import from mapping RestTest.IMM_Pet($JsonContent);
  $PetResponseJson = export to mapping RestTest.EMM_Pet($PetResponse);
  log info node 'RestTest' 'Round-tripped: ' + $PetResponseJson;
end;
/

