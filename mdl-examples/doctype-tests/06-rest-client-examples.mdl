  layout: Atlas_Core.Atlas_Default,
  url: 'rest-client-tests'
)
{
  layoutgrid mainGrid {
    row rowTitle {
      column colTitle (desktopwidth: 12) {
        dynamictext txtTitle (content: 'REST Client Test Runner', rendermode: H2)
        dynamictext txtDesc (content: 'Click a button to run the corresponding REST test microflow. Results are logged to the console.', rendermode: paragraph)
      }
    }
    row rowRunAll {
      column colRunAll (desktopwidth: 4) {
        actionbutton btnRunAll (caption: 'Run All Tests', action: microflow RestTest.ACT_RunAllRestTests, buttonstyle: primary)
      }
    }
    row rowBasicHeader {
      column colBasicHeader (desktopwidth: 12) {
        dynamictext txtBasic (content: 'Basic Operations', rendermode: H4)
      }
    }
    row rowBasicTests {
      column colGet (desktopwidth: 3) {
        actionbutton btnSimpleGet (caption: 'Simple GET', action: microflow RestTest.ACT_TestSimpleGet, buttonstyle: default)
      }
      column colJson (desktopwidth: 3) {
        actionbutton btnJsonGet (caption: 'JSON GET', action: microflow RestTest.ACT_TestJsonGet, buttonstyle: default)
      }
      column colPath (desktopwidth: 3) {
        actionbutton btnPathParams (caption: 'Path Params', action: microflow RestTest.ACT_TestPathParams, buttonstyle: default)
      }
      column colQuery (desktopwidth: 3) {
        actionbutton btnQueryParams (caption: 'Query Params', action: microflow RestTest.ACT_TestQueryParams, buttonstyle: default)
      }
    }
    row rowMethodHeader {
      column colMethodHeader (desktopwidth: 12) {
        dynamictext txtMethods (content: 'HTTP Methods', rendermode: H4)
      }
    }
    row rowMethodTests {
      column colPost (desktopwidth: 4) {
        actionbutton btnPost (caption: 'POST', action: microflow RestTest.ACT_TestPost, buttonstyle: success)
      }
      column colPut (desktopwidth: 4) {
        actionbutton btnPut (caption: 'PUT', action: microflow RestTest.ACT_TestPut, buttonstyle: info)
      }
      column colDelete (desktopwidth: 4) {
        actionbutton btnDelete (caption: 'DELETE', action: microflow RestTest.ACT_TestDelete, buttonstyle: danger)
      }
    }
    row rowAdvHeader {
      column colAdvHeader (desktopwidth: 12) {
        dynamictext txtAdv (content: 'Advanced Features', rendermode: H4)
      }
    }
    row rowAdvTests {
      column colAuth (desktopwidth: 4) {
