-- MARK: Container

-- ============================================================================
-- LEVEL 2b: Container Widget Examples
-- ============================================================================
--
-- CONTAINER creates a Forms$DivContainer - a generic wrapper for grouping
-- widgets. Supports Class: and Style: for CSS styling. Containers can be
-- nested and are essential for card layouts, sections, and spacing.
--

/**
 * Basic container usage for grouping content.
 */
CREATE PAGE PgTest.P013b_Container_Basic
(
  Title: 'Container Examples',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p013b_container_basic',
  Folder: 'Container'
)
{
  LAYOUTGRID mainGrid {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        -- Simple container without styling
        CONTAINER section1 {
          DYNAMICTEXT heading1 (Content: 'Section One', RenderMode: H3)
          DYNAMICTEXT body1 (Content: 'Content inside a basic container', RenderMode: Paragraph)
        }
      }
    }
    ROW row2 {
      COLUMN col2a (DesktopWidth: 6) {
        -- Container with CSS class
        CONTAINER card1 (Class: 'card') {
          DYNAMICTEXT cardTitle1 (Content: 'Card One', RenderMode: H4)
          DYNAMICTEXT cardText1 (Content: 'Styled with card class')
        }
      }
      COLUMN col2b (DesktopWidth: 6) {
        -- Container with class and inline style
        CONTAINER card2 (Class: 'card', Style: 'padding: 16px; background: #f5f5f5;') {
          DYNAMICTEXT cardTitle2 (Content: 'Card Two', RenderMode: H4)
          DYNAMICTEXT cardText2 (Content: 'With inline styling')
        }
      }
    }
    ROW row3 {
      COLUMN col3 (DesktopWidth: 12) {
        -- Nested containers
        CONTAINER outer1 (Class: 'section') {
          DYNAMICTEXT outerTitle (Content: 'Outer Container', RenderMode: H3)
          CONTAINER nested1 (Class: 'card', Style: 'margin-top: 8px;') {
            DYNAMICTEXT nestedTitle (Content: 'Nested Container', RenderMode: H4)
            DYNAMICTEXT nestedBody (Content: 'Content inside a nested container')
          }
        }
      }
    }
  }
}

/**
 * Empty container (no children).
 */
CREATE PAGE PgTest.P013c_Container_Empty
(
  Title: 'Empty Container',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p013c_container_empty',
  Folder: 'Container'
)
{
  CONTAINER spacer1 (Class: 'spacing-outer-bottom-large')
}

