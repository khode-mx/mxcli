/**
 * Show only active products with complex filter.
 */
CREATE PAGE PgTest.P010_2_Product_Sorted_filtered
(
  Title: 'Active Products',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'PgTest.P010_2_Product_Sorted_filtered',
  Folder: 'DataGrid'
)
{
  DATAGRID ProductGrid (
    DataSource: DATABASE FROM PgTest.Product
      WHERE [IsActive = true() AND contains(Code, 'a') AND Price > 10] OR [Stock < 2]
      SORT BY Name ASC, Price DESC
  ) {
    COLUMN colName (Attribute: Name, Caption: 'Product Name')
    COLUMN colCode (Attribute: Code, Caption: 'SKU')
    COLUMN colPrice (Attribute: Price, Caption: 'Unit Price')
    COLUMN colStock (Attribute: Stock, Caption: 'Available')
    COLUMN colActive (Attribute: IsActive, Caption: 'Active')
  }
}

/**
 * Show only active products with complex filter.
 */
CREATE PAGE PgTest.P010_Product_Sorted_filtered_styled
(
  Title: 'Active Products',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'PgTest.P010_Product_Sorted_styled',
  Folder: 'DataGrid'
)
{
  DATAGRID ProductGrid (
    DataSource: DATABASE FROM PgTest.Product
      WHERE [IsActive = true() AND contains(Code, 'a') AND Price > 10] OR [Stock < 2]
      SORT BY Name ASC, Price DESC,
    Class: 'datagrid-striped datagrid-hover datagrid-sm',
    Selection: Multiple,
    PageSize: 10,
    Pagination: buttons,
    PagingPosition: both
  ) {
    COLUMN colName (Attribute: Name, Caption: 'Product Name', Alignment: left, WrapText: false)
    COLUMN colCode (Attribute: Code, Caption: 'SKU')
    COLUMN colPrice (Attribute: Price, Caption: 'Unit Price', Alignment: right, WrapText: false)
    COLUMN colStock (Attribute: Stock, Caption: 'Available', Alignment: right, WrapText: false)
    COLUMN colActive (Attribute: IsActive, Caption: 'Active')
  }
};

/**
 * Show only active products with complex filter.
 */
CREATE PAGE PgTest.P010_Product_Sorted_filtered_styled_2 (
  Title: 'Active Products',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'PgTest.P010_Product_Sorted_styled_2',
  Folder: 'DataGrid'
) {
  DATAGRID ProductGrid ( 
    DataSource:  DATABASE FROM PgTest.Product WHERE (IsActive = true() and contains(Code, 'a') and Price > 10) or (Stock < 2) SORT BY PgTest.Product.Name ASC, PgTest.Product.Price DESC, 
    PageSize: 10, 
    PagingPosition: both, 
    DesignProperties: ['Compact': ON, 'Striped': ON, 'Hover': ON, 'Borders': 'Horizontal']
  ) {
    COLUMN colName (Attribute: Name, Caption: 'Product Name', Alignment: left, WrapText: false, DesignProperties: ['Compact': ON, 'Striped': ON, 'Hover': ON, 'Borders': 'Horizontal'])
    COLUMN colCode (Attribute: Code, Caption: 'SKU')
    COLUMN colPrice (Attribute: Price, Caption: 'Unit Price', Alignment: right, WrapText: false)
    COLUMN colStock (Attribute: Stock, Caption: 'Available', Alignment: right, WrapText: false)
    COLUMN colActive (Attribute: IsActive, Caption: 'Active')
  }
};

/**
 * Helper microflow for DataSource: MICROFLOW reference validation.
 */
CREATE MICROFLOW PgTest.P010_DSO_GetProducts ()
  RETURNS List of PgTest.Product
FOLDER 'DataGrid'
BEGIN
  RETRIEVE $Products FROM PgTest.Product;
  RETURN $Products;
END;
/

/**
 * Show only active products with complex filter.
 */
CREATE PAGE PgTest.P010_Product_Microflow_DataSource (
  Title: 'Active Products',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'PgTest.P010_Product_Microflow_DataSource',
  Folder: 'DataGrid'
) {
  DATAGRID ProductGrid ( 
    DataSource: MICROFLOW PgTest.P010_DSO_GetProducts ,
    PageSize: 10, 
    PagingPosition: both, 
    DesignProperties: ['Compact': ON, 'Striped': ON, 'Hover': ON, 'Borders': 'Horizontal']
  ) {
    COLUMN colName (Attribute: Name, Caption: 'Product Name', Alignment: left, WrapText: false, DesignProperties: ['Compact': ON, 'Striped': ON, 'Hover': ON, 'Borders': 'Horizontal'])
    COLUMN colCode (Attribute: Code, Caption: 'SKU')
    COLUMN colPrice (Attribute: Price, Caption: 'Unit Price', Alignment: right, WrapText: false)
    COLUMN colStock (Attribute: Stock, Caption: 'Available', Alignment: right, WrapText: false)
    COLUMN colActive (Attribute: IsActive, Caption: 'Active')
  }
};
/

