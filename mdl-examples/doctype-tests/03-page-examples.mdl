/**
 * Basic product edit form with text inputs.
 *
 * @param $Product The product to edit
 */
CREATE PAGE PgTest.P012_Product_Manage_Edit
(
  Params: {
    $Product: PgTest.Product
  },
  Title: 'Edit Product',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'DataGrid'
)
{
  LAYOUTGRID buttonRow {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DATAVIEW ProductForm (DataSource: $Product) {
          TEXTBOX txtName (Label: 'Product Name', Attribute: Name)
          TEXTBOX txtCode (Label: 'Product Code', Attribute: Code)
          TEXTAREA txtDescription (Label: 'Description', Attribute: Description)

          FOOTER footer1 {
            ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
            ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
          }
        }
      }
    }
  }
}



/**
 * Full CRUD operations on products.
 */
CREATE PAGE PgTest.P012_Product_Manage
(
  Title: 'Product Management',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'P012_Product_Manage',
  Folder: 'DataGrid'
)
{
  LAYOUTGRID buttonRow {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DYNAMICTEXT textIntro (Content: 'P008_Product_Overview', RenderMode: H3)
        DYNAMICTEXT textIntro2 (Content: 'P008_Product_Overview: {1}', ContentParams: [{1}='abc'], RenderMode: H3)
      }
    }
    ROW row2 {
      COLUMN col2 (DesktopWidth: 12) {
        DATAGRID ProductGrid (DataSource: DATABASE PgTest.Product) {
          CONTROLBAR controlBar1 {
            ACTIONBUTTON btnNew1 (
              Caption: 'New',
              Action: CREATE_OBJECT PgTest.Product THEN SHOW_PAGE PgTest.P012_Product_Manage_Edit,
              ButtonStyle: Primary
            )
          }
          COLUMN colName (Attribute: Name, Caption: 'Product Name')
          COLUMN colCode (Attribute: Code, Caption: 'SKU')
          COLUMN colPrice (Attribute: Price, Caption: 'Price')
          COLUMN colStock (Attribute: Stock, Caption: 'In Stock')
          COLUMN colActive (Attribute: IsActive, Caption: 'Active')
          COLUMN colActions (Caption: 'Actions') {
            ACTIONBUTTON btnEdit (
              Caption: 'Edit',
              Action: SHOW_PAGE PgTest.P012_Product_Manage_Edit (Product: $currentObject),
              ButtonStyle: Default
            )
            ACTIONBUTTON btnDelete (Caption: 'Delete', Action: DELETE_OBJECT, ButtonStyle: Danger)
          }
        }
      }
    }
  }
}

/**
 * DataGrid with domain-specific filtering and sorting.
 */
