-- MARK: GroupBox Examples

-- ============================================================================
-- LEVEL 8: GroupBox Container Examples
-- ============================================================================

/**
 * Customer edit form with GroupBox containers for organizing fields.
 * GroupBox creates a collapsible section with a header caption.
 *
 * @param $Customer The customer to edit
 */
create page PgTest.P037_GroupBox_Example
(
  params: {
    $Customer: PgTest.Customer
  },
  title: 'GroupBox Example',
  layout: Atlas_Core.PopupLayout,
  folder: 'GroupBox'
)
{
  dataview dvCustomer (datasource: $Customer) {
    -- GroupBox with caption and H3 header, collapsible (initially expanded)
    groupbox gbPersonal (caption: 'Personal Information', HeaderMode: H3, Collapsible: YesExpanded) {
      textbox txtName (label: 'Name', attribute: Name)
      textbox txtEmail (label: 'Email', attribute: Email)
      textbox txtPhone (label: 'Phone', attribute: Phone)
    }

    -- GroupBox with caption and H4 header, collapsible (initially collapsed)
    groupbox gbAddress (caption: 'Address', HeaderMode: H4, Collapsible: YesCollapsed) {
      textbox txtAddress (label: 'Address', attribute: Address)
      textbox txtCity (label: 'City', attribute: City)
      combobox cmbCountry (label: 'Country', attribute: Country)
    }

    -- GroupBox with default header (Div), not collapsible
    groupbox gbStatus (caption: 'Status') {
      radiobuttons rbIsActive (label: 'Is Active', attribute: IsActive)
      datepicker dpCreateDate (label: 'Created On', attribute: CreateDate)
    }

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes close_page, buttonstyle: success)
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes close_page, buttonstyle: default)
    }
  }
}

/**
 * Order edit form with ComboBoxes in association mode.
 * Attribute is the association name on the context entity (e.g., Order_Customer).
 * DataSource specifies which entity to load selectable objects from.
 * CaptionAttribute is the display attribute on the target entity (shown in dropdown).
 *
 * - Enum mode: COMBOBOX name (Attribute: EnumAttr)
 * - Association mode: COMBOBOX name (Attribute: AssocName, DataSource: DATABASE TargetEntity, CaptionAttribute: DisplayAttr)
 *
 * @param $Order The order to edit
 */
create page PgTest.P036_ComboBox_Association
(
  params: {
    $Order: PgTest.Order
  },
  title: 'ComboBox Association Selection',
  layout: Atlas_Core.PopupLayout,
  folder: 'ComboBox'
)
{
  dataview dvOrder (datasource: $Order) {
    textbox txtOrderNumber (label: 'Order Number', attribute: OrderNumber)

    -- ComboBox (association mode) selecting a Customer — shows Name in dropdown
    combobox cmbCustomer (label: 'Customer', attribute: Order_Customer, datasource: database PgTest.Customer, CaptionAttribute: Name)

    -- ComboBox (association mode) selecting a Product — shows Name in dropdown
    combobox cmbProduct (label: 'Product', attribute: Order_Product, datasource: database PgTest.Product, CaptionAttribute: Name)

    textbox txtTotal (label: 'Total Amount', attribute: TotalAmount)

    footer footer1 {
      actionbutton btnSave (caption: 'Save', action: save_changes close_page, buttonstyle: success)
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes close_page, buttonstyle: default)
    }
  }
}

-- ============================================================================================ --

-- MARK: ALTER PAGE Variable Examples

-- =============================================================================
-- ALTER PAGE - ADD / DROP Page Variables
-- =============================================================================
--
-- Page variables (Forms$LocalVariable) can be added to or removed from existing
-- pages and snippets using ALTER PAGE / ALTER SNIPPET with ADD/DROP Variables.
--

-- Add a boolean page variable for controlling column visibility
alter page PgTest.P033b_DataGrid_ColumnProperties {
  add variables $showPriceColumn: boolean = 'true';
};

-- Add a string variable with an escaped string default
alter page PgTest.P033b_DataGrid_ColumnProperties {
  add variables $filterMode: string = '''active''';
};

-- Drop a page variable by name
alter page PgTest.P033b_DataGrid_ColumnProperties {
  drop variables $filterMode;
};

-- Multiple variable operations in a single ALTER statement
alter page PgTest.P033b_DataGrid_ColumnProperties {
  add variables $pageSize: integer = '20';
  drop variables $showPriceColumn;
};

-- MARK: ALTER PAGE SET Layout

-- =============================================================================
-- ALTER PAGE - SET Layout (change page layout without rebuilding widgets)
-- =============================================================================

/**
 * Level 8.1: Change page layout (auto-map placeholders)
 */
alter page PgTest.P033b_DataGrid_ColumnProperties {
  set layout = Atlas_Core.Atlas_Default;
};

/**
 * Level 8.2: Change layout back (auto-map)
 */
alter page PgTest.P033b_DataGrid_ColumnProperties {
  set layout = Atlas_Core.Atlas_TopBar;
};

-- MARK: ALTER PAGE DataGrid Column Operations

-- =============================================================================
-- ALTER PAGE - DataGrid Column Operations (dotted widget references)
-- =============================================================================
--
-- DataGrid2 columns are addressable using gridName.columnName syntax.
-- Column names are derived from the attribute short name or caption.

-- DROP a column by dotted reference
-- Note: column names depend on DataGrid2 widget version; disabled for cross-version compat
-- ALTER PAGE PgTest.P033b_DataGrid_ColumnProperties {
--   DROP WIDGET dgProducts.Description
-- };

