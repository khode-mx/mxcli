-- MARK: GroupBox Examples

-- ============================================================================
-- LEVEL 8: GroupBox Container Examples
-- ============================================================================

/**
 * Customer edit form with GroupBox containers for organizing fields.
 * GroupBox creates a collapsible section with a header caption.
 *
 * @param $Customer The customer to edit
 */
CREATE PAGE PgTest.P037_GroupBox_Example
(
  Params: {
    $Customer: PgTest.Customer
  },
  Title: 'GroupBox Example',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'GroupBox'
)
{
  DATAVIEW dvCustomer (DataSource: $Customer) {
    -- GroupBox with caption and H3 header, collapsible (initially expanded)
    GROUPBOX gbPersonal (Caption: 'Personal Information', HeaderMode: H3, Collapsible: YesExpanded) {
      TEXTBOX txtName (Label: 'Name', Attribute: Name)
      TEXTBOX txtEmail (Label: 'Email', Attribute: Email)
      TEXTBOX txtPhone (Label: 'Phone', Attribute: Phone)
    }

    -- GroupBox with caption and H4 header, collapsible (initially collapsed)
    GROUPBOX gbAddress (Caption: 'Address', HeaderMode: H4, Collapsible: YesCollapsed) {
      TEXTBOX txtAddress (Label: 'Address', Attribute: Address)
      TEXTBOX txtCity (Label: 'City', Attribute: City)
      COMBOBOX cmbCountry (Label: 'Country', Attribute: Country)
    }

    -- GroupBox with default header (Div), not collapsible
    GROUPBOX gbStatus (Caption: 'Status') {
      RADIOBUTTONS rbIsActive (Label: 'Is Active', Attribute: IsActive)
      DATEPICKER dpCreateDate (Label: 'Created On', Attribute: CreateDate)
    }

    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

/**
 * Order edit form with ComboBoxes in association mode.
 * Attribute is the association name on the context entity (e.g., Order_Customer).
 * DataSource specifies which entity to load selectable objects from.
 * CaptionAttribute is the display attribute on the target entity (shown in dropdown).
 *
 * - Enum mode: COMBOBOX name (Attribute: EnumAttr)
 * - Association mode: COMBOBOX name (Attribute: AssocName, DataSource: DATABASE TargetEntity, CaptionAttribute: DisplayAttr)
 *
 * @param $Order The order to edit
 */
CREATE PAGE PgTest.P036_ComboBox_Association
(
  Params: {
    $Order: PgTest.Order
  },
  Title: 'ComboBox Association Selection',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'ComboBox'
)
{
  DATAVIEW dvOrder (DataSource: $Order) {
    TEXTBOX txtOrderNumber (Label: 'Order Number', Attribute: OrderNumber)

    -- ComboBox (association mode) selecting a Customer — shows Name in dropdown
    COMBOBOX cmbCustomer (Label: 'Customer', Attribute: Order_Customer, DataSource: DATABASE PgTest.Customer, CaptionAttribute: Name)

    -- ComboBox (association mode) selecting a Product — shows Name in dropdown
    COMBOBOX cmbProduct (Label: 'Product', Attribute: Order_Product, DataSource: DATABASE PgTest.Product, CaptionAttribute: Name)

    TEXTBOX txtTotal (Label: 'Total Amount', Attribute: TotalAmount)

    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

-- ============================================================================================ --

-- MARK: Move Examples

-- =============================================================================
-- MOVE Examples - Moving Documents Between Folders and Modules
-- =============================================================================
--
-- MOVE changes the location of an existing document (page, snippet, microflow,
-- entity) to a different folder or module. Folders are auto-created.
--

-- Create a second module for cross-module move examples
CREATE MODULE PgTest2;

-- Move a page to a different folder within the same module
MOVE PAGE PgTest.P001_Empty_Page TO FOLDER 'Pages/Archive';

-- Move a microflow to a subfolder
MOVE MICROFLOW PgTest.ProcessProducts TO FOLDER 'MasterDetail/Actions';

-- Move a snippet to a nested folder
MOVE SNIPPET PgTest.DashboardHeader TO FOLDER 'Snippets/Dashboard';
MOVE SNIPPET PgTest.DashboardFooter TO FOLDER 'Snippets/Dashboard';

-- Move a page to another module (root of that module)
MOVE PAGE PgTest.P034_ComboBox_Enum TO PgTest2;

-- Move a page to a folder in another module
MOVE PAGE PgTest2.P034_ComboBox_Enum TO FOLDER 'Imported' IN PgTest2;

-- Move a snippet to another module
MOVE SNIPPET PgTest.QuickActions TO PgTest2;

-- Move a snippet to a folder in another module
MOVE SNIPPET PgTest.CustomerSidebar TO FOLDER 'Shared' IN PgTest2;

-- ============================================================================
-- Summary - MDL Page Syntax Features
-- ============================================================================
--
-- Key syntax elements:
-- - Page header uses single () block with Params:, Title:, Layout:, Url:
-- - DataSource: property replaces -> for containers (DATAVIEW, DATAGRID, GALLERY)
-- - Attribute: property replaces -> for input widgets (TEXTBOX, CHECKBOX, etc.)
-- - Action: property replaces -> for buttons and navigation items
-- - Caption: property replaces bare string for button text
-- - Label: property replaces bare string for input widget labels
-- - All layout elements (ROW, COLUMN) require names
-- - ContentParams: and CaptionParams: replace WITH syntax for string templates
-- - Attribute: and Caption: for DATAGRID columns instead of 'caption' -> attr
-- - CONTROLBAR and FILTER are explicit child containers with names
-- - TEMPLATE requires a name
--
-- Core pattern: WIDGET name (Prop: Value, Prop: Value) { children }
--
-- DataSource types:
-- - DataSource: $ParameterName (page parameter)
-- - DataSource: DATABASE Entity (database query)
-- - DataSource: MICROFLOW Module.Flow (microflow source)
-- - DataSource: NANOFLOW Module.Flow (nanoflow source)
-- - DataSource: ASSOCIATION Path (association source)
-- - DataSource: SELECTION widgetName (selection binding)
--
-- Action types:
-- - Action: SAVE_CHANGES
-- - Action: SAVE_CHANGES CLOSE_PAGE
-- - Action: CANCEL_CHANGES
-- - Action: CANCEL_CHANGES CLOSE_PAGE
-- - Action: CLOSE_PAGE
-- - Action: DELETE_OBJECT
-- - Action: CREATE_OBJECT Entity THEN SHOW_PAGE Page
-- - Action: SHOW_PAGE Page
-- - Action: SHOW_PAGE Page(Param: $value)
-- - Action: MICROFLOW Module.Flow
-- - Action: MICROFLOW Module.Flow(Param: $value)
-- - Action: NANOFLOW Module.Flow
-- - Action: NANOFLOW Module.Flow(Param: $value)
--
-- Parameter values in actions:
-- - $ParameterName: Reference page/snippet parameter (e.g., $Product)
-- - $currentObject: Reference current row in DATAGRID/GALLERY/LISTVIEW columns
-- - 'literal': String literal values
--
-- ============================================================================

