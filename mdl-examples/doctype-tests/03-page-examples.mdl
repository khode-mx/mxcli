-- MARK: DATA FORM

/**
 * Edit customer form
 */
CREATE PAGE PgTest.P006_DataForm
(
  Params: {
    $Customer: PgTest.Customer
  },
  Title: 'Edit Customer',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p006_dataform/{Customer/Name}',
  Folder: 'Forms'
)
{
  LAYOUTGRID buttonRow {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DYNAMICTEXT textIntro (Content: 'This is a PgTest page created via MDL', RenderMode: Paragraph)
      }
    }
    ROW row2 {
      COLUMN col2 (DesktopWidth: 12) {
        DATAVIEW dataView5 (DataSource: $Customer) {
          TEXTBOX textBox1 (Label: 'Name', Attribute: Name)
          TEXTBOX textBox2 (Label: 'Email', Attribute: Email)
          TEXTBOX textBox3 (Label: 'Phone', Attribute: Phone)
          TEXTBOX textBox4 (Label: 'Address', Attribute: Address)
          TEXTBOX textBox5 (Label: 'City', Attribute: City)
          COMBOBOX comboBox1 (Label: 'Country', Attribute: Country)
          RADIOBUTTONS radioButtons1 (Label: 'Is active', Attribute: IsActive)
          DATEPICKER datePicker1 (Label: 'Create date', Attribute: CreateDate)

          FOOTER footer1 {
            ACTIONBUTTON actionButton1 (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Primary)
            ACTIONBUTTON actionButton2 (Caption: 'Cancel', Action: CANCEL_CHANGES, ButtonStyle: Default)
          }
        }
      }
    }
    ROW row3 {
      COLUMN col3a (DesktopWidth: 6) { }
      COLUMN col3b (DesktopWidth: 6) {
        ACTIONBUTTON btnSave (Caption: 'Save {1}', CaptionParams: [{1} = 'abc'], Action: SAVE_CHANGES, ButtonStyle: Primary)
      }
    }
  }
}

/**
 * Create a new object for the PgTest.P006_DataForm page
 */
CREATE MICROFLOW PgTest.P006_CreateObject ()
FOLDER 'Forms'
BEGIN
    $NewCustomer = CREATE PgTest.Customer (Email = 'weqw@example.com', City = 'yourcity');
    SHOW PAGE PgTest.P006_DataForm($Customer = $NewCustomer);
END;
/

CREATE MICROFLOW PgTest.P007_DataForm_Getter ()
RETURNS PgTest.Customer AS $Customer
FOLDER 'Forms'
BEGIN
  RETRIEVE $Customer FROM PgTest.Customer LIMIT 1;
  RETURN $Customer;
END;
/

-- TODO: offset limit implementation
CREATE MICROFLOW PgTest.P007_DataForm_Getter_2 ()
RETURNS PgTest.Customer AS $FirstCustomer
FOLDER 'Forms'
BEGIN
  RETRIEVE $CustomerList FROM PgTest.Customer
    WHERE ( starts-with(Name, 'a') )
    LIMIT 2 OFFSET 3;
  SET $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

CREATE MICROFLOW PgTest.P007_DataForm_Getter_3 ()
RETURNS PgTest.Customer AS $FirstCustomer
FOLDER 'Forms'
BEGIN
  RETRIEVE $CustomerList FROM PgTest.Customer
    WHERE (starts-with(Name, 'a'))
    SORT BY PgTest.Customer.Name ASC, PgTest.Customer.Email DESC
    LIMIT 2 +1
    OFFSET 3 + 3;
  $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

CREATE MICROFLOW PgTest.P007_DataForm_Getter_4 ()
RETURNS PgTest.Customer AS $FirstCustomer
FOLDER 'Forms'
BEGIN
  DECLARE $Lim Long = 3;
  DECLARE $Off Long = 5;
  RETRIEVE $CustomerList FROM PgTest.Customer
    WHERE (starts-with(Name, 'a'))
    SORT BY PgTest.Customer.Name ASC, PgTest.Customer.Email DESC
    LIMIT $Lim
    OFFSET $Off;
  $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

/**
 * Process selected products from Gallery multi-select.
 */
CREATE MICROFLOW PgTest.ProcessProducts ()
RETURNS Boolean AS $Success
FOLDER 'MasterDetail'
BEGIN
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

CREATE PAGE PgTest.P007_DataForm_2
(
  Title: 'Edit Customer',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p007_dataform',
  Folder: 'Forms'
)
{
  LAYOUTGRID buttonRow {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DYNAMICTEXT textIntro (Content: 'This is a PgTest page created via MDL', RenderMode: Paragraph)
      }
    }
    ROW row2 {
      COLUMN col2a (DesktopWidth: 6) {
        ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Primary)
      }
      COLUMN col2b (DesktopWidth: 6) {
        DATAVIEW dataView5 (DataSource: MICROFLOW PgTest.P007_DataForm_Getter) {
          TEXTBOX txtName (Label: 'Name', Attribute: Name)
          TEXTBOX txtEmail (Label: 'Email', Attribute: Email)

          FOOTER footer1 {
            ACTIONBUTTON actionButton1 (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Primary)
            ACTIONBUTTON actionButton2 (Caption: 'Cancel', Action: CANCEL_CHANGES, ButtonStyle: Default)
          }
        }
      }
    }
  }
}

