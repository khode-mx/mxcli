-- MARK: Custom Container

-- ============================================================================
-- Custom Container Examples
-- ============================================================================
--
-- CUSTOMCONTAINER is an alias for CONTAINER (both map to Forms$DivContainer).
-- Use it when you want a semantic distinction from layout containers.
--

-- ============================================================================
-- P030: Widget Reference Validation
-- ============================================================================
-- Tests that `mxcli check --references` validates all widget references:
-- - DataSource: MICROFLOW and DataSource: DATABASE
-- - Action: MICROFLOW, Action: SHOW_PAGE
-- - SNIPPETCALL Snippet: reference
--
-- All references point to elements created within this script (PgTest module),
-- so this file should pass `mxcli check script.mdl -p app.mpr --references`.

/**
 * Helper microflow for DataSource: MICROFLOW reference validation.
 */
CREATE MICROFLOW PgTest.DSO_GetProducts ()
  RETURNS List of PgTest.Product
FOLDER 'WidgetReferences'
BEGIN
  RETRIEVE $Products FROM PgTest.Product;
  RETURN $Products;
END;

/**
 * Helper microflow for Action: MICROFLOW reference validation.
 */
CREATE MICROFLOW PgTest.ACT_RefreshProducts ()
FOLDER 'WidgetReferences'
BEGIN
  RETURN;
END;

/**
 * Target page for Action: SHOW_PAGE reference validation.
 */
CREATE PAGE PgTest.P030_ProductDetail
(
  Params: { $Product: PgTest.Product },
  Title: 'Product Detail',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p030_detail/{Product}',
  Folder: 'WidgetReferences'
)
{
  DATAVIEW dvProduct (DataSource: $Product) {
    TEXTBOX txtName (Label: 'Name', Attribute: Name)
  }
}

/**
 * Page exercising all widget reference types for --references validation.
 * References: DataSource MICROFLOW, DataSource DATABASE, Action MICROFLOW,
 * Action SHOW_PAGE, Action CREATE_OBJECT, and SNIPPETCALL.
 */
CREATE PAGE PgTest.P030_WidgetReferences
(
  Title: 'Widget Reference Validation',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p030_widgetrefs',
  Folder: 'WidgetReferences'
)
{
  LAYOUTGRID lg1 {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        -- DataSource: MICROFLOW reference
        LISTVIEW lvProducts (DataSource: MICROFLOW PgTest.DSO_GetProducts) {
          DYNAMICTEXT txtProductName (Content: '{1}', ContentParams: [{1} = Name])
        }
      }
    }
    ROW row2 {
      COLUMN col2 (DesktopWidth: 12) {
        -- DataSource: DATABASE entity reference
        DATAGRID dgProducts (DataSource: DATABASE PgTest.Product) {
          COLUMN colName (Attribute: Name, Caption: 'Product Name')
          COLUMN colPrice (Attribute: Price, Caption: 'Price')
        }
      }
    }
    ROW row3 {
      COLUMN col3 (DesktopWidth: 6) {
        -- Action: MICROFLOW reference
        ACTIONBUTTON btnRefresh (Caption: 'Refresh', Action: MICROFLOW PgTest.ACT_RefreshProducts)
        -- Action: CREATE_OBJECT entity reference (with target page)
        ACTIONBUTTON btnNew (Caption: 'New Product', Action: CREATE_OBJECT PgTest.Product THEN SHOW_PAGE PgTest.P030_ProductDetail)
      }
      COLUMN col4 (DesktopWidth: 6) {
        -- SNIPPETCALL reference
        SNIPPETCALL scStats (Snippet: PgTest.StatsPanel)
      }
    }
    ROW row4 {
      COLUMN col5 (DesktopWidth: 12) {
        -- Action: SHOW_PAGE reference (inside list context for parameter passing)
        LISTVIEW lvForAction (DataSource: MICROFLOW PgTest.DSO_GetProducts) {
          ACTIONBUTTON btnDetail (Caption: 'View Detail', Action: SHOW_PAGE PgTest.P030_ProductDetail (Product: $currentObject))
        }
      }
    }
  }
}

/**
 * Page using CUSTOMCONTAINER for card-style layout.
 */
CREATE PAGE PgTest.P029_CustomContainer
(
  Title: 'Custom Container',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p029_customcontainer',
  Folder: 'Container'
)
{
  LAYOUTGRID mainGrid {
    ROW row1 {
