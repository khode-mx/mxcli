(
  Title: 'Inventory Management',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'DataGrid'
)
{
  DATAGRID ProductGrid (
    DataSource: DATABASE FROM PgTest.Product WHERE [Stock < 10] SORT BY Stock ASC
  ) {
