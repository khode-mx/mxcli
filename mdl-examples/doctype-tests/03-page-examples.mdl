)
{
  dataview dvProduct (datasource: $Product) {
    textbox txtName (label: 'Product Name', attribute: Name)
    textbox txtCode (label: 'SKU', attribute: Code)
    textbox txtPrice (label: 'Price', attribute: Price)
    textbox txtStock (label: 'Stock', attribute: Stock)

    footer footer1 {
      -- Microflow action with page parameter passes the DataView's object
      actionbutton btnProcess (
        caption: 'Process Product',
        action: microflow PgTest.ACT_ProcessProduct(Product: $Product),
        buttonstyle: success
      )
      actionbutton btnSave (caption: 'Save', action: save_changes close_page, buttonstyle: primary)
      actionbutton btnCancel (caption: 'Cancel', action: cancel_changes close_page, buttonstyle: default)
    }
  }
}

-- MARK: String Templates

-- ============================================================================
-- LEVEL 12: String Templates with Data Source References
-- ============================================================================

@position(400,100)
create persistent entity PgTest.OrderItem (
  Quantity: integer,
  UnitPrice: decimal,
  LineTotal: decimal,
  ProductName: string(200)
);

create association PgTest.Order_OrderItem
from PgTest.Order to PgTest.OrderItem
type ReferenceSet
owner both;

create association PgTest.OrderItem_Product
from PgTest.OrderItem to PgTest.Product
type reference
owner both;

/**
 * Demonstrates basic string template with ContentParams syntax.
 *
 * @param $Order The order to display
 */
create page PgTest.P024_Template_Basic
(
  params: {
    $Order: PgTest.Order
  },
  title: 'Order Details',
  layout: Atlas_Core.Atlas_Default,
  url: 'p024_template_basic/{Order/OrderNumber}',
  folder: 'Templates'
)
{
  layoutgrid mainGrid {
    row row1 {
      column col1 (desktopwidth: 12) {
        dataview dvOrder (datasource: $Order) {
          dynamictext txtOrderHeader (
            content: 'Order #{1} - Status: {2}',
            contentparams: [{1} = $order.OrderNumber, {2} = $order.status],
            rendermode: H3
          )

          dynamictext txtOrderDate (
            content: 'Placed on: {1}',
            contentparams: [{1} = $order.OrderDate],
            rendermode: paragraph
          )

          dynamictext txtTotal (
            content: 'Total Amount: ${1}',
            contentparams: [{1} = $order.TotalAmount],
            rendermode: H4
          )

          actionbutton btnProcess (
            caption: 'Process Order #{1}',
            captionparams: [{1} = $order.OrderNumber],
            action: microflow PgTest.ProcessProducts,
            buttonstyle: primary
          )
        }
      }
    }
  }
}



-- MARK: Styling

-- ============================================================================
-- Styling Examples - CSS Class and Inline Style
-- ============================================================================
--
-- Any widget can have Class: and Style: properties for CSS styling.
-- Class: adds CSS classes to the widget's Appearance.
-- Style: adds inline CSS styles to the widget's Appearance.
--

create page PgTest.StyledPage
(
  params: { $Customer: PgTest.Customer },
  title: 'Styled Customer',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Styling'
)
{
  container ctnCard (class: 'card', style: 'padding: 16px; border-radius: 8px;') {
    dataview dvCustomer (datasource: $Customer) {
      textbox txtName (label: 'Name', attribute: Name, class: 'form-control-lg')
      textbox txtEmail (label: 'Email', attribute: Email, style: 'font-style: italic;')
      dynamictext dtCity (content: 'City: {1}', contentparams: [{1} = City], class: 'text-muted', style: 'font-size: 12px;')

      footer footer1 {
        actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary, class: 'btn-block')
        actionbutton btnCancel (caption: 'Cancel', action: cancel_changes, class: 'btn-outline')
      }
    }
  }
}

-- MARK: Image Widgets
-- ============================================================================
-- Image widgets (Forms$StaticImageViewer, Forms$ImageViewer) are deprecated
-- in Mendix 11.x React/optimized client (CE0582). No pluggable replacement
-- exists. Image examples are therefore not included in this test file.
--
-- If Mendix adds a pluggable image widget in the future, examples can be
-- re-added using the same pattern as DATAGRID (pluggable widget template).
-- ============================================================================

-- MARK: Custom Container

-- ============================================================================
-- Custom Container Examples
-- ============================================================================
--
-- CUSTOMCONTAINER is an alias for CONTAINER (both map to Forms$DivContainer).
-- Use it when you want a semantic distinction from layout containers.
--

-- ============================================================================
-- P030: Widget Reference Validation
-- ============================================================================
-- Tests that `mxcli check --references` validates all widget references:
-- - DataSource: MICROFLOW and DataSource: DATABASE
-- - Action: MICROFLOW, Action: SHOW_PAGE
-- - SNIPPETCALL Snippet: reference
--
-- All references point to elements created within this script (PgTest module),
-- so this file should pass `mxcli check script.mdl -p app.mpr --references`.

/**
 * Helper microflow for DataSource: MICROFLOW reference validation.
 */
create microflow PgTest.DSO_GetProducts ()
  returns list of PgTest.Product
folder 'WidgetReferences'
begin
  retrieve $Products from PgTest.Product;
  return $Products;
end;

/**
 * Helper microflow for Action: MICROFLOW reference validation.
 */
create microflow PgTest.ACT_RefreshProducts ()
folder 'WidgetReferences'
begin
  return;
end;

/**
 * Target page for Action: SHOW_PAGE reference validation.
 */
create page PgTest.P030_ProductDetail
(
  params: { $Product: PgTest.Product },
  title: 'Product Detail',
  layout: Atlas_Core.Atlas_Default,
  url: 'p030_detail/{Product}',
  folder: 'WidgetReferences'
)
{
  dataview dvProduct (datasource: $Product) {
    textbox txtName (label: 'Name', attribute: Name)
  }
}

/**
 * Page exercising all widget reference types for --references validation.
 * References: DataSource MICROFLOW, DataSource DATABASE, Action MICROFLOW,
 * Action SHOW_PAGE, Action CREATE_OBJECT, and SNIPPETCALL.
 */
create page PgTest.P030_WidgetReferences
(
  title: 'Widget Reference Validation',
  layout: Atlas_Core.Atlas_Default,
  url: 'p030_widgetrefs',
  folder: 'WidgetReferences'
)
{
  layoutgrid lg1 {
    row row1 {
      column col1 (desktopwidth: 12) {
        -- DataSource: MICROFLOW reference
        listview lvProducts (datasource: microflow PgTest.DSO_GetProducts) {
          dynamictext txtProductName (content: '{1}', contentparams: [{1} = Name])
        }
      }
    }
    row row2 {
      column col2 (desktopwidth: 12) {
        -- DataSource: DATABASE entity reference
        datagrid dgProducts (datasource: database PgTest.Product) {
          column colName (attribute: Name, caption: 'Product Name')
          column colPrice (attribute: Price, caption: 'Price')
        }
      }
    }
    row row3 {
      column col3 (desktopwidth: 6) {
        -- Action: MICROFLOW reference
        actionbutton btnRefresh (caption: 'Refresh', action: microflow PgTest.ACT_RefreshProducts)
        -- Action: CREATE_OBJECT entity reference (with target page)
        actionbutton btnNew (caption: 'New Product', action: create_object PgTest.Product then show_page PgTest.P030_ProductDetail)
      }
      column col4 (desktopwidth: 6) {
        -- SNIPPETCALL reference
        snippetcall scStats (snippet: PgTest.StatsPanel)
      }
    }
    row row4 {
      column col5 (desktopwidth: 12) {
        -- Action: SHOW_PAGE reference (inside list context for parameter passing)
        listview lvForAction (datasource: microflow PgTest.DSO_GetProducts) {
          actionbutton btnDetail (caption: 'View Detail', action: show_page PgTest.P030_ProductDetail (Product: $currentObject))
        }
      }
    }
  }
}

/**
 * Page using CUSTOMCONTAINER for card-style layout.
 */
create page PgTest.P029_CustomContainer
(
  title: 'Custom Container',
  layout: Atlas_Core.Atlas_Default,
  url: 'p029_customcontainer',
  folder: 'Container'
)
{
  layoutgrid mainGrid {
    row row1 {
      column col1 (desktopwidth: 6) {
        customcontainer card1 (class: 'card', style: 'padding: 16px;') {
          dynamictext cardTitle1 (content: 'Card Title', rendermode: H4)
          dynamictext cardBody1 (content: 'Card body content', rendermode: paragraph)
        }
      }
      column col2 (desktopwidth: 6) {
        customcontainer card2 (class: 'card') {
          dynamictext cardTitle2 (content: 'Another Card', rendermode: H4)
          container cardInner (class: 'card-body') {
            dynamictext cardBody2 (content: 'Nested container inside custom container')
          }
        }
      }
    }
  }
}

