-- MARK: DataGrid Column Properties

-- ============================================================================
-- LEVEL 6b: DataGrid Column Properties
-- ============================================================================

/**
 * DataGrid with fully configured column properties.
 *
 * Demonstrates all 13 column properties:
 * - General: Attribute, Caption, ShowContentAs
 * - Column capabilities: Sortable, Resizable, Draggable, Hidable
 * - Appearance: Alignment, WrapText, ColumnWidth, Size, Visible, DynamicCellClass, Tooltip
 */
CREATE PAGE PgTest.P033b_DataGrid_ColumnProperties
(
  Title: 'DataGrid Column Properties',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p033b_datagrid_column_properties',
  Folder: 'DataGrid',
  Variables: { $showStockColumn: Boolean = 'if (3 < 4) then true else false' }
)
{
  DATAGRID dgProducts (DataSource: DATABASE PgTest.Product) {
    -- Default column: only Attribute and Caption, all other properties use defaults
    COLUMN colName (Attribute: Name, Caption: 'Product Name')

    -- Fixed-width price column, right-aligned, not sortable
    COLUMN colPrice (
      Attribute: Price, Caption: 'Unit Price',
      Alignment: right, WrapText: true,
      Sortable: false, Resizable: false, Draggable: false,
      Hidable: hidden,
      ColumnWidth: manual, Size: 150,
      Tooltip: 'Price in USD'
    )

    -- Column with visibility controlled by page variable (not $currentObject!)
    -- and dynamic cell class using Mendix if/then/else expression syntax
    COLUMN colStock (
      Attribute: Stock, Caption: 'In Stock',
      Alignment: center,
      Visible: '$showStockColumn',
      DynamicCellClass: 'if($currentObject/Stock < 10) then ''text-danger'' else '''' '
    )

    -- Non-hidable column with auto-fit width
    COLUMN colCode (
      Attribute: Code, Caption: 'SKU',
      Hidable: no,
      ColumnWidth: autoFit
    )
  }
}

-- MARK: ComboBox Examples

-- ============================================================================
-- LEVEL 7: ComboBox / Dropdown Selection Examples
-- ============================================================================

/**
 * Data form with ComboBox (pluggable widget) selecting from an enumeration,
 * and a native DROPDOWN for comparison.
 *
 * - COMBOBOX uses the pluggable ComboBox widget (optionsSourceType=enumeration)
 * - DROPDOWN uses the native Forms$DropDown widget
 *
 * Both bind to the Country attribute (Enumeration type) on the Customer entity.
 *
 * @param $Customer The customer to edit
 */
CREATE PAGE PgTest.P034_ComboBox_Enum
(
  Params: {
    $Customer: PgTest.Customer
  },
  Title: 'ComboBox Enumeration Selection',
  Layout: Atlas_Core.PopupLayout,
  Folder: 'ComboBox'
)
{
  DATAVIEW dvCustomer (DataSource: $Customer) {
      LAYOUTGRID lg1 {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
    TEXTBOX txtName (Label: 'Customer Name', Attribute: Name)
    TEXTBOX txtEmail (Label: 'Email', Attribute: Email)
    TEXTBOX txtCity (Label: 'City', Attribute: City)

    -- ComboBox (pluggable widget) selecting from the Country enumeration
    COMBOBOX cmbCountry (Label: 'Country (ComboBox)', Attribute: Country)
      }}}
    FOOTER footer1 {
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Success)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

