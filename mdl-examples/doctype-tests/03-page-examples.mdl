          DYNAMICTEXT cardBody1 (Content: 'Card body content', RenderMode: Paragraph)
        }
      }
      COLUMN col2 (DesktopWidth: 6) {
        CUSTOMCONTAINER card2 (Class: 'card') {
          DYNAMICTEXT cardTitle2 (Content: 'Another Card', RenderMode: H4)
          CONTAINER cardInner (Class: 'card-body') {
            DYNAMICTEXT cardBody2 (Content: 'Nested container inside custom container')
          }
        }
      }
    }
  }
}

