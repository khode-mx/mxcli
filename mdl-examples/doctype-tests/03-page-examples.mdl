-- MARK: Microflow Actions with Parameters

-- ============================================================================
-- LEVEL 11b: Microflow Actions with Parameters
-- ============================================================================

/**
 * Process a single product - called from button actions.
 *
 * @param $Product The product to process
 */
CREATE MICROFLOW PgTest.ACT_ProcessProduct (
  $Product: PgTest.Product
)
RETURNS Boolean AS $Success
FOLDER 'MicroflowActions'
BEGIN
  DECLARE $Success Boolean = false;
  LOG INFO NODE 'ProductService' 'Processing product: ' + $Product/Name;
  CHANGE $Product (ModifiedDate = [%CurrentDateTime%]);
  COMMIT $Product;
  SET $Success = true;
  RETURN $Success;
END;
/

/**
 * Delete a product with confirmation - called from button actions.
 *
 * @param $Product The product to delete
 */
CREATE MICROFLOW PgTest.ACT_DeleteProduct (
  $Product: PgTest.Product
)
FOLDER 'MicroflowActions'
BEGIN
  LOG INFO NODE 'ProductService' 'Deleting product: ' + $Product/Name;
  DELETE $Product;
END;
/

/**
 * DataGrid with microflow action buttons using $currentObject.
 * Demonstrates calling microflows with parameters from list widget rows.
 */
CREATE PAGE PgTest.P023b_DataGrid_MicroflowActions
(
  Title: 'Products with Microflow Actions',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p023b_datagrid_microflow_actions',
  Folder: 'MicroflowActions'
)
{
  LAYOUTGRID mainGrid {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DYNAMICTEXT pageTitle (Content: 'Product Management with Microflow Actions', RenderMode: H3)
        DYNAMICTEXT pageDesc (Content: 'Click Process to call microflow with $currentObject', RenderMode: Paragraph)
      }
    }
    ROW row2 {
      COLUMN col2 (DesktopWidth: 12) {
        DATAGRID ProductGrid (DataSource: DATABASE PgTest.Product) {
          CONTROLBAR controlBar1 {
            ACTIONBUTTON btnNew (
              Caption: 'New Product',
              Action: CREATE_OBJECT PgTest.Product THEN SHOW_PAGE PgTest.P012_Product_Manage_Edit,
              ButtonStyle: Primary
            )
          }
          COLUMN colName (Attribute: Name, Caption: 'Product Name')
          COLUMN colCode (Attribute: Code, Caption: 'SKU')
          COLUMN colPrice (Attribute: Price, Caption: 'Price')
          COLUMN colStock (Attribute: Stock, Caption: 'Stock')
          COLUMN colActions (Attribute: Name, Caption: 'Actions', ShowContentAs: customContent) {
            -- Microflow action with $currentObject passes the current row's product
            ACTIONBUTTON btnProcess (
              Caption: 'Process',
              Action: MICROFLOW PgTest.ACT_ProcessProduct(Product: $currentObject),
              ButtonStyle: Success
            )
            ACTIONBUTTON btnDelete (
              Caption: 'Delete',
              Action: MICROFLOW PgTest.ACT_DeleteProduct(Product: $currentObject),
              ButtonStyle: Danger
            )
          }
        }
      }
    }
  }
}

/**
 * Detail page with microflow action using page parameter.
 * Demonstrates calling microflows with parameters from DataView context.
 *
 * @param $Product The product to view/edit
 */
CREATE PAGE PgTest.P023c_Detail_MicroflowAction
(
  Params: {
    $Product: PgTest.Product
  },
  Title: 'Product Details',
  Layout: Atlas_Core.PopupLayout,
  Url: 'p023c_detail_microflow/{Product/Code}',
  Folder: 'MicroflowActions'
)
{
  DATAVIEW dvProduct (DataSource: $Product) {
    TEXTBOX txtName (Label: 'Product Name', Attribute: Name)
    TEXTBOX txtCode (Label: 'SKU', Attribute: Code)
    TEXTBOX txtPrice (Label: 'Price', Attribute: Price)
    TEXTBOX txtStock (Label: 'Stock', Attribute: Stock)

    FOOTER footer1 {
      -- Microflow action with page parameter passes the DataView's object
      ACTIONBUTTON btnProcess (
        Caption: 'Process Product',
        Action: MICROFLOW PgTest.ACT_ProcessProduct(Product: $Product),
        ButtonStyle: Success
      )
      ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES CLOSE_PAGE, ButtonStyle: Primary)
      ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES CLOSE_PAGE, ButtonStyle: Default)
    }
  }
}

-- MARK: String Templates

-- ============================================================================
-- LEVEL 12: String Templates with Data Source References
-- ============================================================================

@Position(400,100)
CREATE PERSISTENT ENTITY PgTest.OrderItem (
  Quantity: Integer,
  UnitPrice: Decimal,
  LineTotal: Decimal,
  ProductName: String(200)
);

CREATE ASSOCIATION PgTest.Order_OrderItem
FROM PgTest.Order TO PgTest.OrderItem
TYPE ReferenceSet
OWNER Both;

CREATE ASSOCIATION PgTest.OrderItem_Product
FROM PgTest.OrderItem TO PgTest.Product
TYPE Reference
OWNER Both;

/**
 * Demonstrates basic string template with ContentParams syntax.
 *
 * @param $Order The order to display
 */
CREATE PAGE PgTest.P024_Template_Basic
(
  Params: {
    $Order: PgTest.Order
  },
  Title: 'Order Details',
  Layout: Atlas_Core.Atlas_Default,
  Url: 'p024_template_basic/{Order/OrderNumber}',
  Folder: 'Templates'
)
{
  LAYOUTGRID mainGrid {
    ROW row1 {
      COLUMN col1 (DesktopWidth: 12) {
        DATAVIEW dvOrder (DataSource: $Order) {
          DYNAMICTEXT txtOrderHeader (
            Content: 'Order #{1} - Status: {2}',
            ContentParams: [{1} = $order.OrderNumber, {2} = $order.Status],
            RenderMode: H3
          )

          DYNAMICTEXT txtOrderDate (
            Content: 'Placed on: {1}',
            ContentParams: [{1} = $order.OrderDate],
            RenderMode: Paragraph
          )

          DYNAMICTEXT txtTotal (
            Content: 'Total Amount: ${1}',
            ContentParams: [{1} = $order.TotalAmount],
            RenderMode: H4
          )

          ACTIONBUTTON btnProcess (
            Caption: 'Process Order #{1}',
            CaptionParams: [{1} = $order.OrderNumber],
            Action: MICROFLOW PgTest.ProcessProducts,
            ButtonStyle: Primary
          )
        }
      }
    }
  }
}



-- MARK: Styling

-- ============================================================================
-- Styling Examples - CSS Class and Inline Style
-- ============================================================================
--
-- Any widget can have Class: and Style: properties for CSS styling.
-- Class: adds CSS classes to the widget's Appearance.
-- Style: adds inline CSS styles to the widget's Appearance.
--

CREATE PAGE PgTest.StyledPage
(
  Params: { $Customer: PgTest.Customer },
  Title: 'Styled Customer',
  Layout: Atlas_Core.Atlas_Default,
  Folder: 'Styling'
)
{
  CONTAINER ctnCard (Class: 'card', Style: 'padding: 16px; border-radius: 8px;') {
    DATAVIEW dvCustomer (DataSource: $Customer) {
      TEXTBOX txtName (Label: 'Name', Attribute: Name, Class: 'form-control-lg')
      TEXTBOX txtEmail (Label: 'Email', Attribute: Email, Style: 'font-style: italic;')
      DYNAMICTEXT dtCity (Content: 'City: {1}', ContentParams: [{1} = City], Class: 'text-muted', Style: 'font-size: 12px;')

      FOOTER footer1 {
        ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Primary, Class: 'btn-block')
        ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES, Class: 'btn-outline')
      }
    }
  }
}

