/**
 * Layout grid with dynamic text
 */
create page PgTest.P003_1_Nested_LayoutGrid_Dynamic_Text_Page
(
  title: 'Layoutgrid dynamic text page',
  layout: Atlas_Core.Atlas_Default,
  url: 'p003_1_nested_layoutgrid_dynamic_text_page',
  folder: 'Basic'
)
{
  layoutgrid LayoutGrid1 {
    row row1 {
      column col1 (desktopwidth: autofill) {
        layoutgrid LayoutGrid2 {
          row row2a {
            column col2a (desktopwidth: autofill) {
              dynamictext text1 (content: 'Just some H4 header', rendermode: H4)
            }
          }
          row row2b {
            column col2b (desktopwidth: autofill) {
              dynamictext text2 (content: 'Just some H4 header', rendermode: H4)
            }
          }
          row row2c {
            column col2c (desktopwidth: autofill) {
              dynamictext text3 (content: 'Just some H4 header', rendermode: H4)
            }
            column col2d (desktopwidth: autofill) {
              dynamictext text4 (content: 'Just some H4 header', rendermode: H4)
            }
          }
        }
      }
    }
    row row3 {
      column col3a (desktopwidth: autofill) {
        actionbutton btnSave1 (caption: 'Save {1}', captionparams: [{1} = 'Hello'], action: save_changes, buttonstyle: primary)
      }
      column col3b (desktopwidth: autofill) {
        actionbutton btnSave2 (caption: 'Cancel {1}', captionparams: [{1} = 'Hello'], action: cancel_changes, buttonstyle: default)
      }
    }
    row row4 {
      column col4 (desktopwidth: autofill) {
        dynamictext text5 (content: 'Just some H4 header: {1}', contentparams: [{1} = 'Hello'], rendermode: H4)
      }
    }
  }
}

