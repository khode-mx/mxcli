-- ============================================================================
-- Page Examples - MDL Syntax
-- ============================================================================
--
-- This file demonstrates the MDL page syntax:
-- - Unified widget pattern: WIDGET name (Prop: Value) { children }
-- - Explicit DataSource:, Attribute:, Action: properties
-- - Page metadata in single () block with Params:, Title:, Layout:, Url:
-- - All properties in (Key: Value) format
-- - Widget names always required
--
-- Core principle: Everything follows WIDGETTYPE name (Prop: Value) { children }
--
-- ============================================================================

-- MARK: Entities

-- ============================================================================
-- Setup: Ensure PgTest Entities Exist
-- ============================================================================

CREATE MODULE PgTest;

/**
 * Country codes with full names as captions.
 */
CREATE ENUMERATION PgTest.Country (
  /** United States */
  US 'United States',
  /** United Kingdom */
  UK 'United Kingdom',
  /** Germany */
  DE 'Germany',
  /** France */
  FR 'France',
  /** Netherlands */
  NL 'Netherlands',
  /** Japan */
  JP 'Japan',
  /** Australia */
  AU 'Australia'
);
/

/**
 * Simple status enumeration for order tracking.
 * Basic enumeration with identifier and caption.
 */
CREATE ENUMERATION PgTest.OrderStatus (
  /** Order received, awaiting processing */
  PENDING 'Pending',
  /** Order is being processed */
  PROCESSING 'Processing',
  /** Order has been shipped */
  SHIPPED 'Shipped',
  /** Order delivered to customer */
  DELIVERED 'Delivered',
  /** Order was cancelled */
  CANCELLED 'Cancelled'
);
/

@Position(100,100)
CREATE PERSISTENT ENTITY PgTest.Product (
  Name: String(200) NOT NULL,
  Code: String(50),
  Description: String(500),
  Price: Decimal,
  IsActive: Boolean DEFAULT true,
  Stock: Integer,
  Category: String(100),
  ImageUrl: String(500),
  CreateDate: DateTime,
  ModifiedDate: DateTime
);

@Position(300,100)
CREATE PERSISTENT ENTITY PgTest.Customer (
  Name: String(200) NOT NULL,
  Email: String(200),
  Phone: String(50),
  Address: String(500),
  City: String(100),
  Country: Enumeration(PgTest.Country),
  IsActive: Boolean DEFAULT true,
  CreateDate: DateTime
);

@Position(500,100)
CREATE PERSISTENT ENTITY PgTest.Order (
  OrderNumber: String(50) NOT NULL,
  OrderDate: DateTime,
  TotalAmount: Decimal,
  Status: Enumeration(PgTest.OrderStatus),
  Notes: String(1000),
  ProcessedDate: DateTime
);

CREATE ASSOCIATION PgTest.Order_Customer
FROM PgTest.Order TO PgTest.Customer
TYPE Reference
OWNER Both;

CREATE ASSOCIATION PgTest.Order_Product
FROM PgTest.Order TO PgTest.Product
TYPE Reference
OWNER Both;

