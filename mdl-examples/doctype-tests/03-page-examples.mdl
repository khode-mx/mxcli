            actionbutton btnNew (
              caption: 'New Order',
              action: create_object PgTest.Order then show_page PgTest.P035_Order_Edit,
              buttonstyle: primary
            )
          }
          column colNumber (attribute: OrderNumber, caption: 'Order #')
          column colDate (attribute: OrderDate, caption: 'Date')
          column colTotal (attribute: TotalAmount, caption: 'Total')
          column colStatus (attribute: status, caption: 'Status')
          column colActions (caption: 'Actions') {
            actionbutton btnEdit (
              caption: 'Edit',
              action: show_page PgTest.P035_Order_Edit (Order: $currentObject),
              buttonstyle: default
            )
          }
        }
      }
    }
  }
