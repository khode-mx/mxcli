-- ============================================================================
-- Fragment Examples - Reusable Widget Groups
-- ============================================================================
--
-- This file demonstrates fragments, which are script-scoped reusable
-- widget groups that can be defined once and inserted into page/snippet
-- bodies.
--
-- Key concepts:
--   DEFINE FRAGMENT Name AS { widgets }     - Define a reusable group
--   USE FRAGMENT Name                       - Insert widgets inline
--   USE FRAGMENT Name AS prefix_            - Insert with name prefix
--   SHOW FRAGMENTS                          - List defined fragments
--   DESCRIBE FRAGMENT Name                  - Show fragment definition
--
-- Fragments are transient — they exist only during script execution
-- and are NOT persisted in the MPR file.
--
-- ============================================================================

-- MARK: Setup

-- ============================================================================
-- Setup: Ensure FragTest Entities Exist
-- ============================================================================

create module FragTest;

@position(100,100)
create persistent entity FragTest.Customer (
  Name: string(200) not null,
  Email: string(200),
  Phone: string(50)
);

@position(300,100)
create persistent entity FragTest.Order (
  OrderNumber: string(50) not null,
  TotalAmount: decimal,
  OrderDate: datetime
);

create association FragTest.Order_Customer
from FragTest.Order to FragTest.Customer
type reference
owner both;

-- MARK: Basic Fragments

-- ============================================================================
-- LEVEL 1: Basic Fragment Definition
-- ============================================================================

/**
 * Simple save/cancel footer — the most common reusable pattern.
 */
define fragment SaveCancelFooter as {
  footer footer1 {
    actionbutton btnSave (caption: 'Save', action: save_changes, buttonstyle: primary)
    actionbutton btnCancel (caption: 'Cancel', action: cancel_changes)
  }
};

/**
 * Fragment with multiple top-level widgets.
 */
define fragment CustomerFields as {
  textbox txtName (label: 'Name', attribute: Name)
  textbox txtEmail (label: 'Email', attribute: Email)
  textbox txtPhone (label: 'Phone', attribute: Phone)
};

-- MARK: Show & Describe

-- ============================================================================
-- LEVEL 2: Show and Describe Fragments
-- ============================================================================

-- List all defined fragments (works without project connection)
show fragments;

-- Show the full MDL definition of a fragment
describe fragment SaveCancelFooter;
describe fragment CustomerFields;

-- MARK: Use in Pages

-- ============================================================================
-- LEVEL 3: Using Fragments in Pages
-- ============================================================================

/**
 * Edit page using a fragment for the footer.
 * The SaveCancelFooter widgets are cloned and inserted inline.
 */
create page FragTest.P001_Customer_Edit
(
  params: { $Customer: FragTest.Customer },
  title: 'Edit Customer',
  layout: Atlas_Core.PopupLayout
)
{
  dataview dvCustomer (datasource: $Customer) {
    use fragment CustomerFields
    use fragment SaveCancelFooter
  }
};

-- Verify the page was created with expanded widgets
describe page FragTest.P001_Customer_Edit;

-- MARK: Prefix

-- ============================================================================
-- LEVEL 4: Fragments with Prefix (Avoiding Name Conflicts)
-- ============================================================================

/**
 * When using the same fragment multiple times on one page,
 * use AS prefix_ to create unique widget names.
 */
define fragment StatusButtons as {
  actionbutton btnApprove (caption: 'Approve', action: save_changes, buttonstyle: success)
  actionbutton btnReject (caption: 'Reject', action: cancel_changes, buttonstyle: danger)
};

/**
 * Page with the same fragment used twice with different prefixes.
 * The first instance creates cust_btnApprove, cust_btnReject.
 * The second creates order_btnApprove, order_btnReject.
 */
create page FragTest.P002_Dual_Fragment
(
  title: 'Dual Fragment Example',
  layout: Atlas_Core.Atlas_Default,
  url: 'frag_002_dual'
)
{
  layoutgrid lgMain {
    row row1 {
      column col1 (desktopwidth: 6) {
        dynamictext txtCustHeader (content: 'Customer Actions', rendermode: H4)
        use fragment StatusButtons as cust_
      }
      column col2 (desktopwidth: 6) {
        dynamictext txtOrderHeader (content: 'Order Actions', rendermode: H4)
        use fragment StatusButtons as order_
      }
    }
  }
};

-- MARK: Nested Use

-- ============================================================================
-- LEVEL 5: Fragments Inside Nested Containers
-- ============================================================================

/**
 * Fragments can be used inside any container widget — DATAVIEW,
 * LAYOUTGRID columns, CONTAINER, etc.
 */
define fragment OrderFields as {
  textbox txtOrderNumber (label: 'Order #', attribute: OrderNumber)
  datepicker dpOrderDate (label: 'Order Date', attribute: OrderDate)
  textbox txtTotal (label: 'Total', attribute: TotalAmount)
};

create page FragTest.P003_Order_Form
(
  params: { $Order: FragTest.Order },
  title: 'Edit Order',
  layout: Atlas_Core.PopupLayout
)
{
  dataview dvOrder (datasource: $Order) {
    layoutgrid lgForm {
      row row1 {
        column col1 (desktopwidth: 12) {
          use fragment OrderFields
        }
      }
    }
    use fragment SaveCancelFooter
  }
};

-- MARK: Multiple Pages

-- ============================================================================
-- LEVEL 6: Sharing Fragments Across Pages
-- ============================================================================

/**
 * The main benefit of fragments: define once, use in many pages.
 * Here we create two different pages reusing the same footer.
 */
create page FragTest.P004_Customer_New
(
  title: 'New Customer',
  layout: Atlas_Core.Atlas_Default,
  url: 'frag_004_customer_new'
)
{
  dataview dvCustomer (datasource: database FragTest.Customer) {
    use fragment CustomerFields
    use fragment SaveCancelFooter
  }
};

create page FragTest.P005_Quick_View
(
  params: { $Customer: FragTest.Customer },
  title: 'Customer Details',
  layout: Atlas_Core.PopupLayout
)
{
  dataview dvCustomer (datasource: $Customer) {
    dynamictext txtHeader (content: 'Customer Details', rendermode: H3)
    use fragment CustomerFields
    footer footer1 {
      actionbutton btnClose (caption: 'Close', action: close_page)
    }
  }
};

-- MARK: Snippets

-- ============================================================================
-- LEVEL 7: Fragments in Snippets
-- ============================================================================

/**
 * Fragments also work inside snippets, not just pages.
 */
create snippet FragTest.CustomerCard
(
  params: { $Customer: FragTest.Customer }
)
{
  container ctnCard (class: 'card') {
    dynamictext txtCardTitle (content: 'Customer', rendermode: H4)
    dataview dvCustomer (datasource: $Customer) {
      use fragment CustomerFields
    }
  }
};

-- MARK: Extract from Page/Snippet

-- ============================================================================
-- LEVEL 8: Extract Widget from Page/Snippet as Fragment
-- ============================================================================

-- Extract a widget subtree from an existing page or snippet as MDL.
-- These commands require a project connection (CONNECT LOCAL).
-- Uncomment and adjust for your project:

-- DESCRIBE FRAGMENT FROM PAGE FragTest.P001_Customer_Edit WIDGET dvCustomer;
-- DESCRIBE FRAGMENT FROM SNIPPET FragTest.CustomerCard WIDGET ctnCard;

-- MARK: ALTER PAGE

-- ============================================================================
-- LEVEL 9: ALTER PAGE — In-Place Widget Modification
-- ============================================================================

-- ALTER PAGE modifies an existing page's widget tree without full round-trip.
-- It works directly on raw BSON, preserving unsupported widget types.
-- These examples require a project connection opened for writing.
-- Uncomment to run against a real project:

-- Drop a widget from a page
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   DROP WIDGET txtPhone
-- };

-- Set property on a widget
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   SET Caption = 'Update Customer' ON btnSave
-- };

-- Set multiple properties at once
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   SET (Caption = 'Save & Close', ButtonStyle = Success) ON btnSave
-- };

-- Insert a widget after another
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   INSERT AFTER txtName {
--     TEXTBOX txtMiddle (Label: 'Middle Name', Attribute: Name)
--   }
-- };

-- Insert a widget before another
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   INSERT BEFORE txtEmail {
--     DYNAMICTEXT txtDivider (Content: '---', RenderMode: P)
--   }
-- };

-- Replace a widget subtree
-- ALTER PAGE FragTest.P001_Customer_Edit {
--   REPLACE footer1 WITH {
--     FOOTER newFooter {
--       ACTIONBUTTON btnSave (Caption: 'Save', Action: SAVE_CHANGES, ButtonStyle: Primary)
--       ACTIONBUTTON btnCancel (Caption: 'Cancel', Action: CANCEL_CHANGES)
--       ACTIONBUTTON btnDelete (Caption: 'Delete', Action: CANCEL_CHANGES, ButtonStyle: Danger)
--     }
--   }
-- };

-- Multiple operations in one ALTER PAGE
-- ALTER PAGE FragTest.P002_Dual_Fragment {
--   SET Caption = 'Approve Order' ON cust_btnApprove;
--   DROP WIDGET order_btnReject;
--   INSERT AFTER cust_btnReject {
--     ACTIONBUTTON btnNew (Caption: 'New', Action: SAVE_CHANGES, ButtonStyle: Info)
--   }
-- };

-- MARK: ALTER SNIPPET

-- ============================================================================
-- LEVEL 10: ALTER SNIPPET — In-Place Snippet Widget Modification
-- ============================================================================

-- ALTER SNIPPET works exactly like ALTER PAGE but targets snippets.
-- It modifies the snippet's widget tree without full round-trip,
-- preserving unsupported widget types in the raw BSON.
-- These examples require a project connection opened for writing.
-- Uncomment to run against a real project:

-- Drop a widget from a snippet
-- ALTER SNIPPET FragTest.CustomerCard {
--   DROP WIDGET txtCardTitle
-- };

-- Set a property on a widget inside a snippet
-- ALTER SNIPPET FragTest.CustomerCard {
--   SET Class = 'card card-highlighted' ON ctnCard
-- };

-- Replace a widget inside a snippet
-- ALTER SNIPPET FragTest.CustomerCard {
--   REPLACE txtCardTitle WITH {
--     DYNAMICTEXT txtCardTitle (Content: 'Customer Info', RenderMode: H3)
--   }
-- };

-- Multiple operations on a snippet
-- ALTER SNIPPET FragTest.CustomerCard {
--   SET Class = 'card-lg' ON ctnCard;
--   INSERT BEFORE dvCustomer {
--     DYNAMICTEXT txtSubtitle (Content: 'Details below', RenderMode: P)
--   }
-- };

-- MARK: Summary

-- ============================================================================
-- Summary
-- ============================================================================
--
-- Fragments provide script-scoped widget reuse:
--
--   DEFINE FRAGMENT Name AS { widgets };   -- Define
--   USE FRAGMENT Name                      -- Use (clone & insert)
--   USE FRAGMENT Name AS prefix_           -- Use with unique names
--   SHOW FRAGMENTS;                        -- List all
--   DESCRIBE FRAGMENT Name;                -- Show definition
--   DESCRIBE FRAGMENT FROM PAGE Mod.Page WIDGET name;   -- Extract from page
--   DESCRIBE FRAGMENT FROM SNIPPET Mod.Snip WIDGET name; -- Extract from snippet
--
-- ALTER PAGE/SNIPPET provides in-place widget modification:
--
--   ALTER PAGE Mod.Page {
--     SET prop = value ON widgetName        -- Modify widget property
--     INSERT AFTER/BEFORE name { widgets }  -- Add widgets
--     DROP WIDGET name1, name2             -- Remove widgets
--     REPLACE name WITH { widgets }        -- Replace widget subtree
--   };
--
--   ALTER SNIPPET Mod.Snippet {
--     -- Same operations as ALTER PAGE
--   };
--
-- Key characteristics:
--   - Not persisted (script-scoped only)
--   - Widgets are deep-cloned on expansion
--   - Prefix support avoids name conflicts
--   - Works in both pages and snippets
--   - Works inside any container (DATAVIEW, COLUMN, CONTAINER, etc.)
--   - No project connection needed for SHOW/DESCRIBE FRAGMENT
--   - DESCRIBE FRAGMENT FROM requires a project connection
--   - ALTER PAGE/SNIPPET works on raw BSON (preserves unsupported widgets)
--   - ALTER PAGE/SNIPPET requires write-mode project connection
