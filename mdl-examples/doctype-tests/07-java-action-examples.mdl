// in production, would add to a task queue
// for demo, just return the generated ID
return taskId;
$$;


-- MARK: Level 3 - Entity Parameters

-- ============================================================================
-- LEVEL 3: Java Actions with Entity Parameters
-- ============================================================================

/**
 * Example 3.1: Single entity parameter
 *
 * Java Action Signature:
 *   JAVA ACTION EmailService.SendEmail(
 *     EmailMsg: JaTest.EmailMessage NOT NULL
 *   ) RETURNS Boolean
 *
 * Passing an entity object to a Java action for processing.
 */
create microflow JaTest.M020_SendEmail ($Email: JaTest.EmailMessage)
returns boolean as $MF20_Success
begin
  declare $MF20_Success boolean = false;

  -- Validate before sending
  if $Email/Recipient != empty then
    $SendResult = call java action JaTest.SendEmail(
      EmailMsg = $Email
    );

    -- Update status based on result
    if $SendResult then
      change $Email (
        EmailStatus = 'Sent',
        SentDate = [%CurrentDateTime%]
      );
      set $MF20_Success = true;
    else
      change $Email (EmailStatus = 'Failed');
    end if;
  end if;

  return $MF20_Success;
end;
/

/**
 * Example 3.2: Entity as output (Java action creates/modifies object)
 *
 * Java Action Signature:
 *   JAVA ACTION LogService.CreateLogEntry(
 *     Level: String NOT NULL,
 *     Msg: String NOT NULL,
 *     Source: String
 *   ) RETURNS JaTest.LogEntry
 */
create microflow JaTest.M021_LogMessage (
  $level: string,
  $Msg: string,
  $source: string
)
returns JaTest.LogEntry as $MF21_LogEntry
begin
  $MF21_LogEntry = call java action JaTest.CreateLogEntry(
    level = $level,
    Msg = $Msg,
    LogSource =$source
  );

  return $MF21_LogEntry;
end;
/

/**
 * Example 3.3: Multiple entity parameters
 *
 * Java Action Signature:
 *   JAVA ACTION FileService.AttachToEmail(
 *     Email: JaTest.EmailMessage NOT NULL,
 *     FileDoc: JaTest.FileInfo NOT NULL
 *   ) RETURNS Boolean
 */
create microflow JaTest.M022_AttachFileToEmail (
  $Email: JaTest.EmailMessage,
  $FileDoc: JaTest.FileInfo
)
returns boolean as $MF22_Success
begin
  $MF22_Success = call java action JaTest.AttachToEmail(
    Email = $Email,
    FileDoc = $FileDoc
  );

  return $MF22_Success;
end;
/

