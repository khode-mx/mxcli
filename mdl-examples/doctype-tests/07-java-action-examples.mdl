/**
 * Example 2.1: String parameter
 *
 * Java Action Signature:
 *   JAVA ACTION StringUtils.ToUpperCase(InputText: String NOT NULL) RETURNS String
 */
create microflow JaTest.M010_StringToUpper ($InputText: string)
returns string as $MF10_Result
begin
  $MF10_Result = call java action JaTest.ToUpperCase(
    InputText = $InputText
  );

  return $MF10_Result;
end;
/

/**
 * Example 2.2: Multiple string parameters
 *
 * Java Action Signature:
 *   JAVA ACTION StringUtils.Concatenate(
 *     FirstPart: String NOT NULL,
 *     SecondPart: String NOT NULL,
 *     Separator: String
 *   ) RETURNS String
 */
create microflow JaTest.M011_ConcatenateStrings (
  $FirstPart: string,
  $SecondPart: string
)
returns string as $MF11_Result
begin
  $MF11_Result = call java action JaTest.Concatenate(
    FirstPart = $FirstPart,
    SecondPart = $SecondPart,
    Separator = ' - '
  );

  return $MF11_Result;
end;
/

/**
 * Example 2.3: Integer parameters with calculation
 *
 * Java Action Signature:
 *   JAVA ACTION MathUtils.CalculatePercentage(
 *     CurrentValue: Integer NOT NULL,
 *     TotalValue: Integer NOT NULL
 *   ) RETURNS Decimal
 */
create microflow JaTest.M012_CalculatePercentage (
  $CurrentValue: integer,
  $TotalValue: integer
)
returns decimal as $MF12_Percentage
begin
  $MF12_Percentage = call java action JaTest.CalculatePercentage(
    CurrentValue = $CurrentValue,
    TotalValue = $TotalValue
  );

  return $MF12_Percentage;
end;
/

/**
 * Example 2.4: Boolean parameter (conditional behavior)
 *
 * Java Action Signature:
 *   JAVA ACTION FormatUtils.FormatDate(
 *     InputDate: DateTime NOT NULL,
 *     IncludeTime: Boolean
 *   ) RETURNS String
 */
create microflow JaTest.M013_FormatDate (
  $InputDate: datetime,
  $IncludeTime: boolean
)
returns string as $MF13_Formatted
begin
  $MF13_Formatted = call java action JaTest.FormatDate(
    InputDate = $InputDate,
    IncludeTime = $IncludeTime
  );

  return $MF13_Formatted;
end;
/

/**
 * Example 2.5: Decimal parameter (financial calculation)
 *
 * Java Action Signature:
 *   JAVA ACTION FinanceUtils.CalculateTax(
 *     Amount: Decimal NOT NULL,
 *     TaxRate: Decimal NOT NULL
 *   ) RETURNS Decimal
 */
create microflow JaTest.M014_CalculateTax (
  $Amount: decimal,
  $TaxRate: decimal
)
returns decimal as $MF14_TaxAmount
begin
  $MF14_TaxAmount = call java action JaTest.CalculateTax(
    Amount = $Amount,
    TaxRate = $TaxRate
  );

  return $MF14_TaxAmount;
end;
/

