-- ============================================================================
-- Java Action Examples - Comprehensive Reference
-- ============================================================================
--
-- This file documents Java action patterns and demonstrates how to call
-- them from microflows. Java actions are defined in Java code but can be
-- invoked from MDL microflows using CALL JAVA ACTION.
--
-- Usage:
--   1. Connect to your project: USE 'path/to/app.mpr';
--   2. List Java actions: SHOW JAVA ACTIONS;
--   3. Describe a Java action: DESCRIBE JAVA ACTION Module.ActionName;
--   4. Execute this script: EXECUTE SCRIPT '07-java-action-examples.mdl';
--
-- Note: Java actions must be defined in Java code first. This file shows
-- how to call existing Java actions and documents common patterns.
--
-- ============================================================================

-- MARK: Setup

create module JaTest;

-- Create entities used by Java action examples
@position(100,100)
create persistent entity JaTest.EmailMessage (
  Recipient: string(500) not null,
  SubjectLine: string(500),
  BodyText: string(2000),
  IsHtml: boolean default false,
  SentDate: datetime,
  EmailStatus: string(50) default 'Pending'
);

@position(300,100)
create persistent entity JaTest.LogEntry (
  LogTimestamp: datetime not null,
  LogLevel: string(20),
  LogMessage: string(2000),
  LogSource: string(200)
);

@position(500,100)
create persistent entity JaTest.FileInfo (
  FileName: string(500) not null,
  MimeType: string(200),
  FileSize: integer
);

@position(100,300)
create persistent entity JaTest.ProcessResult (
  IsSuccess: boolean default false,
  ResultMessage: string(500),
  ProcessedCount: integer,
  ErrorCount: integer,
  DurationMs: long
);

-- MARK: Java Action Definitions

-- ============================================================================
-- Java Action Definitions
-- ============================================================================
-- These CREATE JAVA ACTION statements define the Java actions that are called
-- by the microflows in this file. Each action includes inline Java code.
-- All actions are in the JaTest module for easy cleanup with:
--   DROP MODULE JaTest;

-- ----------------------------------------------------------------------------
-- Level 1: No-Parameter Java Actions
-- ----------------------------------------------------------------------------

/** Returns the current timestamp. */
create java action JaTest.GetCurrentTimestamp() returns datetime
as $$
return new java.util.date();
$$;

/** Checks if the system is in maintenance mode (stub: always returns false). */
create java action JaTest.IsMaintenanceMode() returns boolean
as $$
// in a real implementation, this would check a system configuration
return false;
$$;

/** Returns the application version string. */
create java action JaTest.GetApplicationVersion() returns string
as $$
return "1.0.0-SNAPSHOT";
$$;
/

-- MARK: Level 1 - Basic Calls

-- ============================================================================
-- LEVEL 1: Simple Java Action Calls (No Parameters)
-- ============================================================================

/**
 * Example 1.1: Calling a Java action with no parameters
 *
 * Java Action Signature:
 *   JAVA ACTION Utils.GetCurrentTimestamp() RETURNS DateTime
 *
 * This pattern is common for utility functions that don't need input.
 */
create microflow JaTest.M001_GetTimestamp ()
returns datetime as $MF1_Timestamp
begin
  -- Call Java action with no arguments
  $MF1_Timestamp = call java action JaTest.GetCurrentTimestamp();

  return $MF1_Timestamp;
end;
/

/**
 * Example 1.2: Java action returning Boolean (validation/check)
 *
 * Java Action Signature:
 *   JAVA ACTION Utils.IsMaintenanceMode() RETURNS Boolean
 */
create microflow JaTest.M002_CheckMaintenanceMode ()
returns boolean as $MF2_InMaintenance
begin
  $MF2_InMaintenance = call java action JaTest.IsMaintenanceMode();

  return $MF2_InMaintenance;
end;
/

/**
 * Example 1.3: Java action returning String (configuration/info)
 *
 * Java Action Signature:
 *   JAVA ACTION Utils.GetApplicationVersion() RETURNS String
 */
create microflow JaTest.M003_GetAppVersion ()
returns string as $MF3_Version
begin
  $MF3_Version = call java action JaTest.GetApplicationVersion();

  return $MF3_Version;
end;
/


-- ----------------------------------------------------------------------------
-- Level 2: Primitive Parameter Java Actions
-- ----------------------------------------------------------------------------

/** Converts a string to uppercase. */
create java action JaTest.ToUpperCase(InputText: string not null) returns string
as $$
if (InputText == null) {
    return "";
}
return InputText.toUpperCase();
$$;
/


/** Concatenates two strings with an optional separator. */
create java action JaTest.Concatenate(FirstPart: string not null, SecondPart: string not null, Separator: string) returns string
as $$
string sep = Separator != null ? Separator : "";
string first = FirstPart != null ? FirstPart : "";
string second = SecondPart != null ? SecondPart : "";
return first + sep + second;
$$;

/** Calculates what percentage CurrentValue is of TotalValue. */
create java action JaTest.CalculatePercentage(CurrentValue: integer not null, TotalValue: integer not null) returns decimal
as $$
if (TotalValue == null || TotalValue == 0) {
    return java.math.BigDecimal.ZERO;
}
java.math.BigDecimal current = java.math.BigDecimal.valueOf(CurrentValue != null ? CurrentValue : 0);
java.math.BigDecimal total = java.math.BigDecimal.valueOf(TotalValue);
return current.multiply(java.math.BigDecimal.valueOf(100)).divide(total, 2, java.math.RoundingMode.HALF_UP);
$$;

/** Formats a DateTime as a string, optionally including time. */
create java action JaTest.FormatDate(InputDate: datetime not null, IncludeTime: boolean) returns string
as $$
if (InputDate == null) {
    return "";
}
java.text.SimpleDateFormat formatter;
if (IncludeTime != null && IncludeTime) {
    formatter = new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
} else {
    formatter = new java.text.SimpleDateFormat("yyyy-MM-dd");
}
return formatter.format(InputDate);
$$;

/** Calculates tax amount based on amount and tax rate. */
create java action JaTest.CalculateTax(Amount: decimal not null, TaxRate: decimal not null) returns decimal
as $$
if (Amount == null || TaxRate == null) {
    return java.math.BigDecimal.ZERO;
}
return Amount.multiply(TaxRate).divide(java.math.BigDecimal.valueOf(100), 2, java.math.RoundingMode.HALF_UP);
$$;


/** Validates an email address format using regex. */
create java action JaTest.ValidateEmail(EmailAddress: string) returns boolean
as $$
if (EmailAddress == null || EmailAddress.isEmpty()) {
    return false;
}
string emailRegex = "^[a-zA-Z0-9_+&*-]+(?:\\.[a-zA-Z0-9_+&*-]+)*@(?:[a-zA-Z0-9-]+\\.)+[a-zA-Z]{2,7}$";
return EmailAddress.matches(emailRegex);
$$;


