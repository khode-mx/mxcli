-- @version: 11.0+
-- ============================================================================
-- Database Connection Examples - Formula 1 Database (requires Mendix 11.0+)
-- ============================================================================
--
-- This file demonstrates CREATE DATABASE CONNECTION features using
-- a real Formula 1 database on SQL Server.
--
-- Prerequisites:
--   - SQL Server with F1 database at host.docker.internal:1433
--   - Credentials: sa / Secret1234
--   - Tables: drivers, circuits, constructors, races, results, etc.
--
-- Usage:
--   1. Connect to your project: CONNECT LOCAL 'path/to/app.mpr';
--   2. Execute: EXECUTE SCRIPT 'mdl-examples/doctype-tests/05-database-connection-examples.mdl';
--   3. Verify: DESCRIBE DATABASE CONNECTION DbTest.F1Database;
--   4. View constants: SHOW CONSTANTS IN DbTest;
--
-- ============================================================================


-- ############################################################################
-- PART 0: PREREQUISITES - Module, Constants, and Entities
-- ############################################################################

-- Create module for our database examples
create module DbTest;

-- ============================================================================
-- Constants for F1 SQL Server Connection
-- ============================================================================

/** JDBC connection string for F1 database */
create constant DbTest.F1Database_DBSource type string
  default 'jdbc:sqlserver://host.docker.internal:1433;databaseName=F1;encrypt=false'
  comment 'JDBC connection string for F1 database';

/** Database username */
create constant DbTest.F1Database_DBUsername type string
  default 'sa'
  comment 'Database username for F1 database';

/** Database password */
create constant DbTest.F1Database_DBPassword type string
  default ''
  comment 'Database password for F1 database';

-- ============================================================================
-- Non-Persistent Entities for Query Results
-- ============================================================================

/**
 * Entity to hold driver records from the F1 database.
 * Maps to the drivers table.
 */
create non-persistent entity DbTest.Driver (
  DriverId: integer,
  DriverRef: string(200),
  Forename: string(200),
  Surname: string(200),
  Nationality: string(200),
  DateOfBirth: datetime
);

/**
 * Entity to hold circuit records from the F1 database.
 * Maps to the circuits table.
 */
create non-persistent entity DbTest.Circuit (
  CircuitId: integer,
  CircuitRef: string(200),
  CircuitName: string(200),
  Location: string(200),
  Country: string(200)
);

/**
 * Entity to hold constructor (team) records.
 */
create non-persistent entity DbTest.Constructor (
  ConstructorId: integer,
  ConstructorRef: string(200),
  ConstructorName: string(200),
  Nationality: string(200)
);

/**
 * Entity to hold race records.
 */
create non-persistent entity DbTest.Race (
  RaceId: integer,
  RaceYear: integer,
  Round: integer,
  RaceName: string(200),
  RaceDate: datetime
);

/**
 * Entity for race result summary with custom attribute names.
 * Used to demonstrate column mapping.
 */
create non-persistent entity DbTest.RaceResult (
  ResultId: integer,
  DriverName: string(200),
  TeamName: string(200),
  position: integer,
  Points: decimal default 0
);


-- ############################################################################
-- PART 1: BASIC DATABASE CONNECTIONS
-- ############################################################################

-- ============================================================================
-- Level 1.1: Minimal Database Connection (No Queries)
-- ============================================================================

/**
 * Minimal database connection - type, connection string, and credentials.
 * This is the simplest possible connection definition.
 */
create database connection DbTest.MinimalDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
end;

-- ============================================================================
-- Level 1.2: Connection with Single Simple Query
-- ============================================================================

/**
 * Basic connection with one simple SELECT query.
 * Returns all drivers mapped to the Driver entity.
 */
create database connection DbTest.SimpleQueryDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetAllDrivers
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers ORDER BY surname'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );
end;


-- ############################################################################
-- PART 2: QUERIES WITH RETURN MAPPING
-- ############################################################################

-- ============================================================================
-- Level 2.1: Query with Return Entity (columns match attributes)
-- ============================================================================

/**
 * Connection with query that returns circuits.
 * Demonstrates explicit column-to-attribute mapping.
 */
create database connection DbTest.CircuitQueryDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetAllCircuits
    sql 'SELECT circuitId, circuitRef, name, location, country FROM circuits ORDER BY name'
    returns DbTest.Circuit
    map (
      circuitId as CircuitId,
      circuitRef as CircuitRef,
      name as CircuitName,
      location as Location,
      country as Country
    );
end;

-- ============================================================================
-- Level 2.2: Multiple Queries in One Connection
-- ============================================================================

/**
 * Connection with multiple queries returning different entity types.
 */
create database connection DbTest.MultiQueryDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetDrivers
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers ORDER BY surname'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );

  query GetConstructors
    sql 'SELECT constructorId, constructorRef, name, nationality FROM constructors ORDER BY name'
    returns DbTest.Constructor
    map (
      constructorId as ConstructorId,
      constructorRef as ConstructorRef,
      name as ConstructorName,
      nationality as Nationality
    );
end;


-- ############################################################################
-- PART 3: PARAMETERIZED QUERIES
-- ############################################################################

-- ============================================================================
-- Level 3.1: Single Parameter Query
-- ============================================================================

/**
 * Connection with parameterized query.
 * Demonstrates safe parameter binding for filtering.
 */
create database connection DbTest.ParamQueryDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetDriversByNationality
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers WHERE nationality = {nation} ORDER BY surname'
    parameter nation: string default 'British'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );
end;

-- ============================================================================
-- Level 3.2: Multiple Parameters and Multiple Queries
-- ============================================================================

/**
 * Connection with multiple parameterized queries.
 * Demonstrates filtering by different criteria.
 */
create database connection DbTest.MultiParamDB
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetRacesByYear
    sql 'SELECT raceId, year, round, name, date FROM races WHERE year = {raceYear} ORDER BY round'
    parameter raceYear: integer default '2023'
    returns DbTest.Race
    map (
      raceId as RaceId,
      year as RaceYear,
      round as Round,
      name as RaceName,
      date as RaceDate
    );

  query GetCircuitsByCountry
    sql 'SELECT circuitId, circuitRef, name, location, country FROM circuits WHERE country = {searchCountry} ORDER BY name'
    parameter searchCountry: string null
    returns DbTest.Circuit
    map (
      circuitId as CircuitId,
      circuitRef as CircuitRef,
      name as CircuitName,
      location as Location,
      country as Country
    );
end;


-- ############################################################################
-- PART 4: COMPREHENSIVE DATABASE CONNECTION
-- ############################################################################

/**
 * Comprehensive database connection for Formula 1 data.
 *
 * This connection provides read access to the F1 database,
 * demonstrating all database connector query features:
 * - Simple queries
 * - Parameterized queries (single and multiple parameters)
 * - Column-to-attribute mapping
 * - Multiple entity return types
 *
 * Connection: jdbc:sqlserver://host.docker.internal:1433;databaseName=F1
 * Tables: drivers, circuits, constructors, races, results
 */
create database connection DbTest.F1Database
type 'MSSQL'
connection string @DbTest.F1Database_DBSource
username @DbTest.F1Database_DBUsername
password @DbTest.F1Database_DBPassword
begin
  query GetAllDrivers
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers ORDER BY surname'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );

  query GetDriverById
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers WHERE driverId = {id}'
    parameter id: integer default '1'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );

  query GetDriversByNationality
    sql 'SELECT driverId, driverRef, forename, surname, nationality, dob FROM drivers WHERE nationality = {nation} ORDER BY surname'
    parameter nation: string default 'British'
    returns DbTest.Driver
    map (
      driverId as DriverId,
      driverRef as DriverRef,
      forename as Forename,
      surname as Surname,
      nationality as Nationality,
      dob as DateOfBirth
    );

  query GetAllCircuits
    sql 'SELECT circuitId, circuitRef, name, location, country FROM circuits ORDER BY name'
    returns DbTest.Circuit
    map (
      circuitId as CircuitId,
      circuitRef as CircuitRef,
      name as CircuitName,
      location as Location,
      country as Country
    );

  query GetCircuitsByCountry
    sql 'SELECT circuitId, circuitRef, name, location, country FROM circuits WHERE country = {searchCountry} ORDER BY name'
    parameter searchCountry: string default 'United Kingdom'
    returns DbTest.Circuit
    map (
      circuitId as CircuitId,
      circuitRef as CircuitRef,
      name as CircuitName,
      location as Location,
      country as Country
    );

  query GetAllConstructors
    sql 'SELECT constructorId, constructorRef, name, nationality FROM constructors ORDER BY name'
    returns DbTest.Constructor
    map (
      constructorId as ConstructorId,
      constructorRef as ConstructorRef,
      name as ConstructorName,
      nationality as Nationality
    );

  query GetRacesByYear
    sql 'SELECT raceId, year, round, name, date FROM races WHERE year = {raceYear} ORDER BY round'
    parameter raceYear: integer default '2023'
    returns DbTest.Race
    map (
      raceId as RaceId,
      year as RaceYear,
      round as Round,
      name as RaceName,
      date as RaceDate
    );

  query GetRacesBySeason
    sql 'SELECT raceId, year, round, name, date FROM races WHERE year BETWEEN {startYear} AND {endYear} ORDER BY year, round'
    parameter startYear: integer default '1900'
    parameter endYear: integer null
    returns DbTest.Race
    map (
      raceId as RaceId,
      year as RaceYear,
      round as Round,
      name as RaceName,
      date as RaceDate
    );
end;


-- ############################################################################
-- MICROFLOW EXAMPLES: EXECUTE DATABASE QUERY
-- ############################################################################

-- Microflows can execute database connector queries using the EXECUTE DATABASE QUERY
-- statement. The query is referenced by its 3-part qualified name: Module.Connection.Query.
-- Three patterns are supported:
--   1. Static query (just the query reference)
--   2. Dynamic SQL override (DYNAMIC 'SELECT ...')
--   3. Parameterized query (with argument mappings)

-- ----------------------------------------------------------------------------
-- Example 1: Static query — executes the SQL defined in the query object
-- ----------------------------------------------------------------------------

create microflow DbTest.GetAllDrivers()
begin
  $DriverList = execute database query DbTest.F1Database.GetAllDrivers;
end;

-- ----------------------------------------------------------------------------
-- Example 2: Dynamic SQL — overrides the query's SQL at runtime
-- ----------------------------------------------------------------------------

create microflow DbTest.GetDriversDynamic()
begin
  $DriverList = execute database query DbTest.F1Database.GetAllDrivers
    dynamic 'SELECT driverId, driverRef, forename, surname, nationality FROM drivers ORDER BY surname LIMIT 10';
end;

-- ----------------------------------------------------------------------------
-- Example 3: Parameterized query — passes values for query parameters
-- ----------------------------------------------------------------------------

create microflow DbTest.GetDriversByNationality(Nationality: string)
begin
  $DriverList = execute database query DbTest.F1Database.GetDriversByNationality
    (nation = $Nationality);
end;

-- ----------------------------------------------------------------------------
-- Example 4: Fire-and-forget (no output variable)
-- ----------------------------------------------------------------------------

create microflow DbTest.RefreshDriverCache()
begin
  execute database query DbTest.F1Database.GetAllDrivers;
end;

-- Note: EXECUTE DATABASE QUERY only supports ON ERROR ROLLBACK (default).
-- ON ERROR CONTINUE is not supported for this action type.

-- ----------------------------------------------------------------------------
-- Example 5: Runtime connection override
-- Use case: multiple databases with same schema but different data
-- (e.g., region-specific databases)
-- Note: ConnectionParameterMappings require the connection to have been
-- tested/validated in Studio Pro first. Creating them programmatically
-- may trigger "parameters have been updated" on first open.
-- ----------------------------------------------------------------------------

-- CREATE MICROFLOW DbTest.GetAllDrivers_runtime_connection()
-- BEGIN
--   $DriverList = EXECUTE DATABASE QUERY DbTest.F1Database.GetAllDrivers
--     CONNECTION (DBSource = 'jdbc:sqlserver://host.docker.internal:1433;databaseName=F1;encrypt=false',
--                 DBUsername = 'sa',
--                 DBPassword = 'Secret1234');
-- END;


-- ############################################################################
-- MOVE EXAMPLES: CONSTANTS AND DATABASE CONNECTIONS
-- ############################################################################

-- Move a constant to a folder within the same module
move constant DbTest.F1Database_DBSource to folder 'Resources/Database';

-- Move another constant to the same folder
move constant DbTest.F1Database_DBUsername to folder 'Resources/Database';

-- Move a database connection to a folder
move database connection DbTest.MinimalDB to folder 'Resources';

-- Move another database connection to a folder
move database connection DbTest.SimpleQueryDB to folder 'Resources';


-- ############################################################################
-- VERIFICATION QUERIES
-- ############################################################################

-- After executing this script, verify with:
--
show constants in DbTest;
show database connections;
--
describe database connection DbTest.MinimalDB;
describe database connection DbTest.F1Database;
--
describe microflow DbTest.GetAllDrivers;
describe microflow DbTest.GetDriversDynamic;
describe microflow DbTest.GetDriversByNationality;
--
-- The DESCRIBE output should match the CREATE statements above.

-- ============================================================================
-- END OF DATABASE CONNECTION EXAMPLES
-- ============================================================================
