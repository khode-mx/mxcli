--   RETURN true;
-- END;

-- ============================================================================
-- MARK: Functions
-- ============================================================================

/**
 * contains() function: WHERE [contains(Attr, $search)]
 */
create microflow XpathTest.Retrieve_Contains (
  $SearchStr: string
)
returns boolean
begin
  retrieve $Results from XpathTest.Customer
    where [contains(Name, $SearchStr)];
  return true;
end;

/**
 * starts-with() function
 */
create microflow XpathTest.Retrieve_StartsWith (
  $Prefix: string
)
returns boolean
begin
  retrieve $Results from XpathTest.Customer
    where [starts-with(Name, $Prefix)];
  return true;
end;

/**
 * not() with contains(): WHERE [not(contains(Attr, 'val'))]
 */
create microflow XpathTest.Retrieve_NotContains ()
returns boolean
begin
  retrieve $Results from XpathTest.Customer
    where [not(contains(Name, 'demo'))];
  return true;
end;

/**
 * true() and false() functions
 */
create microflow XpathTest.Retrieve_TrueFalseFunction ()
returns boolean
begin
  retrieve $Active from XpathTest.Customer
    where [IsActive = true()];
  retrieve $Inactive from XpathTest.Customer
    where [IsActive = false()];
  return true;
end;

-- ============================================================================
-- MARK: Tokens ([%CurrentUser%], [%CurrentDateTime%])
-- ============================================================================

/**
 * Token: [%CurrentDateTime%] for date comparisons
 */
create microflow XpathTest.Retrieve_DateTimeToken ()
returns boolean
begin
  retrieve $Recent from XpathTest.Order
    where [OrderDate >= [%CurrentDateTime%]];
  return true;
end;

/**
 * Token in string literal: system owner check
 * Note: In BSON, tokens inside XPath are quoted: '[%CurrentUser%]'
 */
create microflow XpathTest.Retrieve_CurrentUserToken ()
returns boolean
begin
  retrieve $MyOrders from XpathTest.Order
    where [System.owner = '[%CurrentUser%]'];
  return true;
end;

-- ============================================================================
-- MARK: ID Pseudo-Attribute
-- ============================================================================

/**
 * id pseudo-attribute for object identity comparison
 */
create microflow XpathTest.Retrieve_IdComparison (
  $ExistingOrder: XpathTest.Order
)
returns boolean
begin
  retrieve $Others from XpathTest.Order
    where [id != $ExistingOrder];
  return true;
end;

-- ============================================================================
-- MARK: Complex Real-World Patterns
-- ============================================================================

/**
 * Complex filter: multiple conditions with empty checks and OR grouping
 * Pattern: state filter + optional date range + optional category
 */
create microflow XpathTest.Retrieve_ComplexFilter (
  $IgnoreAfterDate: boolean,
  $AfterDate: datetime,
  $IgnoreBeforeDate: boolean,
  $BeforeDate: datetime,
  $SelectedCategory: XpathTest.Category
)
returns boolean
begin
  retrieve $Results from XpathTest.Order
    where [State = 'Completed'
      and ($IgnoreAfterDate or OrderDate >= $AfterDate)
      and ($IgnoreBeforeDate or OrderDate <= $BeforeDate)
      and ($SelectedCategory = empty or XpathTest.Order_Category = $SelectedCategory)];
  return true;
end;

/**
 * Combined text search with active filter
 */
create microflow XpathTest.Retrieve_TextSearch (
  $SearchStr: string
)
returns boolean
begin
  retrieve $Results from XpathTest.Customer
    where [IsActive = true and (contains(Name, $SearchStr) or contains(Email, $SearchStr))];
  return true;
end;

-- ============================================================================
-- MARK: Page Data Sources with XPath WHERE
-- ============================================================================

/**
 * DataGrid with inline XPath WHERE and sorting
 */
create page XpathTest.OrderOverviewPage (
  title: 'Order Overview',
  layout: Atlas_Core.Atlas_Default
) {
  datagrid dgOrders (
    datasource: database from XpathTest.Order where [State != 'Cancelled'] sort by OrderDate desc
  ) {
    column colNumber (attribute: OrderNumber, caption: 'Order #')
    column colAmount (attribute: TotalAmount, caption: 'Amount')
    column colState (attribute: State, caption: 'Status')
  }
};

/**
 * Page with chained XPath predicates using AND/OR between brackets
 */
create page XpathTest.ActiveCustomerPage (
  title: 'Active Customers',
  layout: Atlas_Core.Atlas_Default
) {
  datagrid dgCustomers (
    datasource: database from XpathTest.Customer where [IsActive = true] and [Name != empty] sort by Name asc
  ) {
    column colName (attribute: Name, caption: 'Name')
    column colEmail (attribute: Email, caption: 'Email')
  }
};

