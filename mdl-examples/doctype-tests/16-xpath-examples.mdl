-- ============================================================================
-- XPath Examples - Comprehensive XPath Constraint Feature Showcase
-- ============================================================================
--
-- This file demonstrates all XPath constraint features supported in MDL,
-- covering patterns found in real Mendix projects.
--
-- Usage:
--   1. Connect to your project
--   2. Execute: EXECUTE SCRIPT 'mdl-examples/doctype-tests/16-xpath-examples.mdl';
--   3. Roundtrip with: DESCRIBE MICROFLOW XpathTest.MicroflowName;
--
-- ============================================================================

-- MARK: Setup

create module XpathTest;

-- ============================================================================
-- Setup: Domain Model for XPath Examples
-- ============================================================================

create persistent entity XpathTest.Customer (
  Name: string(200),
  Email: string(200),
  IsActive: boolean,
  RegistrationDate: datetime,
  Country: string(100)
);

create persistent entity XpathTest.Order (
  OrderNumber: string(50),
  TotalAmount: decimal,
  State: string(20),
  OrderDate: datetime,
  IsPaid: boolean,
  Notes: string(2000)
);

-- Enable System.owner so XPath can reference it
alter entity XpathTest.Order add attribute owner: autoowner;

create persistent entity XpathTest.OrderLine (
  Quantity: integer,
  UnitPrice: decimal,
  ProductName: string(200)
);

create persistent entity XpathTest.Category (
  Name: string(100),
  IsVisible: boolean
);

create association XpathTest.Order_Customer
  from XpathTest.Order to XpathTest.Customer
  type reference
  owner default;

create association XpathTest.OrderLine_Order
  from XpathTest.OrderLine to XpathTest.Order
  type reference
  owner default;

create association XpathTest.Order_Category
  from XpathTest.Order to XpathTest.Category
  type reference
  owner default;

-- ============================================================================
-- MARK: Simple Attribute Comparisons
-- ============================================================================

/**
 * Basic string equality: WHERE [Attr = 'value']
 */
create microflow XpathTest.Retrieve_StringEquality ()
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [State = 'Completed'];
  return true;
end;

/**
 * Not-equal comparison: WHERE [Attr != 'value']
 */
create microflow XpathTest.Retrieve_NotEqual ()
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [State != 'Cancelled'];
  return true;
end;

/**
 * Numeric comparisons: <, >, <=, >=
 */
create microflow XpathTest.Retrieve_NumericComparisons (
  $MinAmount: decimal,
  $MaxAmount: decimal
)
returns boolean
begin
  retrieve $HighValue from XpathTest.Order
    where [TotalAmount >= $MinAmount and TotalAmount <= $MaxAmount];
  return true;
end;

/**
 * Variable comparison: WHERE [Attr = $variable]
 */
create microflow XpathTest.Retrieve_VariableComparison (
  $SearchState: string
)
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [State = $SearchState];
  return true;
end;

-- ============================================================================
-- MARK: Empty and Boolean Checks
-- ============================================================================

/**
 * Empty comparison: WHERE [Attr = empty] and [Attr != empty]
 */
create microflow XpathTest.Retrieve_EmptyCheck ()
returns boolean
begin
  retrieve $WithDate from XpathTest.Order
    where [OrderDate != empty];
  retrieve $WithoutDate from XpathTest.Order
    where [OrderDate = empty];
  return true;
end;

/**
 * Boolean attribute comparison: WHERE [Attr = true]
 */
create microflow XpathTest.Retrieve_BooleanCheck ()
returns boolean
begin
  retrieve $Active from XpathTest.Customer
    where [IsActive = true];
  retrieve $Paid from XpathTest.Order
    where [IsPaid = false];
  return true;
end;

/**
 * Bare boolean attribute (existence check): WHERE [Attr]
 */
create microflow XpathTest.Retrieve_BareBoolean ()
returns boolean
begin
  retrieve $Active from XpathTest.Customer
    where [IsActive];
  return true;
end;

-- ============================================================================
-- MARK: Boolean Logic (and, or, not)
-- ============================================================================

/**
 * AND operator: WHERE [A and B]
 */
create microflow XpathTest.Retrieve_And ()
returns boolean
begin
  retrieve $Results from XpathTest.Order
    where [State = 'Completed' and IsPaid = true];
  return true;
end;

/**
 * OR operator: WHERE [A or B]
 */
create microflow XpathTest.Retrieve_Or ()
returns boolean
begin
  retrieve $Results from XpathTest.Order
    where [State = 'Pending' or State = 'Processing'];
  return true;
end;

/**
 * Parenthesized grouping with mixed operators
 */
create microflow XpathTest.Retrieve_GroupedLogic (
  $IgnorePaid: boolean,
  $MinAmount: decimal
)
returns boolean
begin
  retrieve $Results from XpathTest.Order
    where [State = 'Completed' and ($IgnorePaid or IsPaid = true) and TotalAmount >= $MinAmount];
  return true;
end;

/**
 * NOT operator: WHERE [not(expr)]
 */
create microflow XpathTest.Retrieve_Not ()
returns boolean
begin
  retrieve $NotPaid from XpathTest.Order
    where [not(IsPaid)];
  return true;
end;

-- ============================================================================
-- MARK: Association Path Traversal (Bare Paths)
-- ============================================================================

/**
 * Single-hop association: WHERE [Module.Assoc = $var]
 */
create microflow XpathTest.Retrieve_AssociationEquals (
  $Customer: XpathTest.Customer
)
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [XpathTest.Order_Customer = $Customer];
  return true;
end;

/**
 * Multi-hop path: WHERE [Module.Assoc/Module.Entity/Attr = $val]
 */
create microflow XpathTest.Retrieve_MultiHopPath (
  $CustomerName: string
)
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [XpathTest.Order_Customer/XpathTest.Customer/Name = $CustomerName];
  return true;
end;

/**
 * Path existence check (no comparison): WHERE [Module.Assoc/Module.Entity]
 */
create microflow XpathTest.Retrieve_PathExistence ()
returns boolean
begin
  retrieve $WithCustomer from XpathTest.Order
    where [XpathTest.Order_Customer/XpathTest.Customer];
  return true;
end;

/**
 * Negated path existence: WHERE [not(Module.Assoc/Module.Entity)]
 */
create microflow XpathTest.Retrieve_NegatedPathExistence ()
returns boolean
begin
  retrieve $Orphaned from XpathTest.Order
    where [not(XpathTest.Order_Customer/XpathTest.Customer)];
  return true;
end;

-- ============================================================================
-- MARK: Variable Paths
-- ============================================================================

/**
 * Variable attribute path: $var/Attr
 */
create microflow XpathTest.Retrieve_VariablePath (
  $Customer: XpathTest.Customer
)
returns boolean
begin
  retrieve $Orders from XpathTest.Order
    where [XpathTest.Order_Customer/XpathTest.Customer/Name = $Customer/Name];
  return true;
end;

-- ============================================================================
-- MARK: Nested Predicates
-- ============================================================================

-- TODO: Nested XPath predicates with = inside [] are not yet supported by the parser.
-- These examples cause parse errors and produce invalid BSON (CE0161).
--
