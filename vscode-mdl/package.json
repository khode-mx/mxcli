{
  "name": "vscode-mdl",
  "displayName": "MDL - Mendix Definition Language",
  "description": "Language support for MDL (Mendix Definition Language) files",
  "version": "0.0.1",
  "publisher": "mendix",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mendixlabs/mxcli"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mdl",
    "onView:mendixProjectTree"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mendix-explorer",
          "title": "Mendix",
          "icon": "media/mendix-icon.svg"
        }
      ]
    },
    "views": {
      "mendix-explorer": [
        {
          "id": "mendixProjectTree",
          "name": "Project Structure"
        }
      ]
    },
    "commands": [
      {
        "command": "mendix.refreshProjectTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mendix.openElement",
        "title": "Open MDL Source"
      },
      {
        "command": "mendix.runFile",
        "title": "MDL: Run File",
        "icon": "$(play)"
      },
      {
        "command": "mendix.runSelection",
        "title": "MDL: Run Selection",
        "icon": "$(play)"
      },
      {
        "command": "mendix.checkFile",
        "title": "MDL: Check File",
        "icon": "$(check)"
      },
      {
        "command": "mendix.showContext",
        "title": "Show Context",
        "icon": "$(references)"
      },
      {
        "command": "mendix.showImpact",
        "title": "Show Impact",
        "icon": "$(warning)"
      },
      {
        "command": "mendix.showCallers",
        "title": "Show Callers",
        "icon": "$(call-incoming)"
      },
      {
        "command": "mendix.showCallees",
        "title": "Show Callees",
        "icon": "$(call-outgoing)"
      },
      {
        "command": "mendix.showReferences",
        "title": "Show References",
        "icon": "$(search)"
      },
      {
        "command": "mendix.previewDiagram",
        "title": "Show Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "mendix.previewDiagramWithSource",
        "title": "Show Diagram with Source",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mendix.refreshProjectTree",
          "when": "view == mendixProjectTree",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mendix.runFile",
          "when": "resourceLangId == mdl",
          "group": "mdl@1"
        },
        {
          "command": "mendix.runSelection",
          "when": "resourceLangId == mdl && editorHasSelection",
          "group": "mdl@2"
        },
        {
          "command": "mendix.checkFile",
          "when": "resourceLangId == mdl",
          "group": "mdl@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mendix.showContext",
          "when": "view == mendixProjectTree && viewItem =~ /^(entity|microflow|nanoflow|page|snippet|enumeration)$/",
          "group": "mendix@1"
        },
        {
          "command": "mendix.showImpact",
          "when": "view == mendixProjectTree && viewItem =~ /^(entity|microflow|nanoflow|page|snippet|enumeration|association)$/",
          "group": "mendix@2"
        },
        {
          "command": "mendix.showReferences",
          "when": "view == mendixProjectTree && viewItem =~ /^(entity|microflow|nanoflow|page|snippet|enumeration|association)$/",
          "group": "mendix@3"
        },
        {
          "command": "mendix.showCallers",
          "when": "view == mendixProjectTree && viewItem =~ /^(microflow|nanoflow)$/",
          "group": "mendix@4"
        },
        {
          "command": "mendix.showCallees",
          "when": "view == mendixProjectTree && viewItem =~ /^(microflow|nanoflow)$/",
          "group": "mendix@5"
        },
        {
          "command": "mendix.openElement",
          "when": "view == mendixProjectTree && viewItem =~ /^(entity|microflow|nanoflow|page|snippet|enumeration|association|modulerole|userrole|projectsecurity|demouser)$/",
          "group": "mendix@6"
        },
        {
          "command": "mendix.previewDiagram",
          "when": "view == mendixProjectTree && viewItem =~ /^(domainmodel|entity|microflow|page|systemoverview)$/",
          "group": "mendix@7"
        },
        {
          "command": "mendix.previewDiagramWithSource",
          "when": "view == mendixProjectTree && viewItem =~ /^(microflow|entity|domainmodel|externalentity|page)$/",
          "group": "mendix@8"
        }
      ],
      "editor/title": [
        {
          "command": "mendix.previewDiagram",
          "when": "resourceScheme == mendix-mdl",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "mdl",
        "aliases": [
          "MDL",
          "Mendix Definition Language"
        ],
        "extensions": [
          ".mdl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mdl",
        "scopeName": "source.mdl",
        "path": "./syntaxes/mdl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MDL",
      "properties": {
        "mdl.mxcliPath": {
          "type": "string",
          "default": "mxcli",
          "description": "Path to the mxcli executable for the MDL language server"
        },
        "mdl.mprPath": {
          "type": "string",
          "default": "",
          "description": "Path to Mendix .mpr file. If empty, auto-discovers in workspace."
        },
        "mdl.diagramTheme": {
          "type": "string",
          "enum": ["sketch", "clean"],
          "default": "clean",
          "description": "Diagram visual style: 'sketch' for hand-drawn look, 'clean' for professional solid lines."
        }
      }
    }
  },
  "scripts": {
    "compile": "bunx esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "bunx esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "bun run compile && bunx @vscode/vsce package --no-dependencies",
    "lint": "bunx tsc --noEmit"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.3",
    "typescript": "^6.0.2"
  }
}
